@model NuevaNoticiaViewModel
@{
    ViewBag.Title = "Nueva Noticia";
    ViewBag.ActivePage = "noticias";
}

<div class="page-hero">
    <div class="page-hero-icon">✍️</div>
    <div class="page-hero-text">
        <h1>Nueva Noticia</h1>
        <p>Sala de redacción · Torneo Chapitas</p>
    </div>
</div>

<a asp-action="Redaccion" style="display:inline-block;color:var(--color-muted);font-size:13px;margin-bottom:24px;">
    ← Volver a redacción
</a>

@if (ViewBag.Error != null)
{
    <div style="background:rgba(224,85,85,.15);border-left:3px solid var(--color-red);color:var(--color-red);padding:10px 14px;border-radius:6px;margin-bottom:20px;">
        ⚠️ @ViewBag.Error
    </div>
}

<div class="form-card" style="max-width:700px;">
    <form method="post" asp-action="Nueva" enctype="multipart/form-data">
        <div class="form-group">
            <label>Título *</label>
            <input type="text" name="Titulo" value="@Model.Titulo"
                   class="form-control" placeholder="Ej: Nahuel se consolida en lo alto de la tabla" required />
        </div>

        <div class="form-group">
            <label>Contenido *</label>
            <textarea name="Contenido" class="form-control" rows="8"
                      placeholder="Escribí la noticia acá...">@Model.Contenido</textarea>
        </div>

        <!-- Imagen manual -->
        <div class="form-group">
            <label>Subir imagen (opcional)</label>
            <input type="file" name="imagenArchivo" accept="image/*" id="fileInput"
                   style="background:var(--color-bg3);border:1px solid var(--color-border);border-radius:8px;padding:10px;width:100%;color:var(--color-text);font-size:14px;" />
            <p style="font-size:11px;color:var(--color-muted);margin-top:4px;">JPG, PNG o WebP. Máx 5MB.</p>
        </div>

        <div style="background:var(--color-bg3);border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:12px;color:var(--color-muted);">
            — O —
        </div>

        <div class="form-group">
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;">
                <input type="checkbox" name="GenerarImagen" value="true"
                       id="chkGenerar"
                       @(Model.GenerarImagen ? "checked" : "")
                       style="accent-color:var(--color-gold);width:16px;height:16px;" />
                <span>Generar imagen automática (fotos de fútbol de Unsplash)</span>
            </label>
        </div>

        <div class="form-group" id="prompt-group">
            <label>Palabras clave para la imagen (opcional, en inglés)</label>
            <input type="text" name="ImagenPrompt" value="@Model.ImagenPrompt"
                   class="form-control" placeholder="Ej: championship victory celebration" />
        </div>

        <div style="display:flex;gap:12px;margin-top:8px;">
            <button type="submit" class="btn-primary">Publicar Noticia</button>
            <a asp-action="Redaccion" class="btn-cancelar">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
const chk     = document.getElementById('chkGenerar');
const grp     = document.getElementById('prompt-group');
const fileInp = document.getElementById('fileInput');

function togglePrompt() { grp.style.display = chk.checked ? 'block' : 'none'; }
chk.addEventListener('change', togglePrompt);
// Si sube archivo, desmarcar "generar automática"
fileInp.addEventListener('change', () => { if (fileInp.files.length > 0) { chk.checked = false; togglePrompt(); } });
togglePrompt();
</script>
}
