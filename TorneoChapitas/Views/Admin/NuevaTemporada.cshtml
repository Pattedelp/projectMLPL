@model NuevaTemporadaViewModel
@{
    ViewBag.Title = "Nueva Temporada";
    ViewBag.ActivePage = "admin";
}

<div class="page-hero">
    <div class="page-hero-icon">🔄</div>
    <div class="page-hero-text">
        <h1>Nueva Temporada</h1>
        <p>Configurá los equipos y generá el fixture automáticamente</p>
    </div>
</div>

<form method="post" asp-action="NuevaTemporada">
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:24px;margin-bottom:24px;">
        <div class="form-group">
            <label>Nombre de la temporada</label>
            <input type="text" name="nombreTemporada"
                   value="Temporada @Model.NumeroTemporada"
                   class="form-control" style="max-width:300px" required />
        </div>
    </div>

    <!-- PRIMERA DIVISIÓN -->
    <div class="admin-section">
        <h2 class="admin-section-title">🏆 Primera División</h2>
        <p style="color:var(--color-muted);font-size:13px;margin-bottom:16px;">
            Destildá los equipos que no participen.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;">
            @foreach (var e in Model.EquiposPrimera)
            {
                <label style="display:flex;align-items:center;gap:8px;background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:10px 14px;cursor:pointer;font-size:13px;">
                    <input type="checkbox" name="equiposPrimera" value="@e.Id" checked
                           style="accent-color:var(--color-gold);width:16px;height:16px;" />
                    @if (!string.IsNullOrEmpty(e.FlagCode))
                    {
                        <img src="https://flagcdn.com/20x15/@(e.FlagCode).png" class="flag-img" alt="" />
                    }
                    <span>@e.Nombre</span>
                </label>
            }
        </div>
    </div>

    <!-- PRIMERA NACIONAL -->
    <div class="admin-section">
        <h2 class="admin-section-title">🥈 Primera Nacional</h2>
        <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;">
            @foreach (var e in Model.EquiposNacionalB)
            {
                <label style="display:flex;align-items:center;gap:8px;background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:10px 14px;cursor:pointer;font-size:13px;">
                    <input type="checkbox" name="equiposB" value="@e.Id" checked
                           style="accent-color:var(--color-gold);width:16px;height:16px;" />
                    @if (!string.IsNullOrEmpty(e.FlagCode))
                    {
                        <img src="https://flagcdn.com/20x15/@(e.FlagCode).png" class="flag-img" alt="" />
                    }
                    <span>@e.Nombre</span>
                </label>
            }
        </div>
    </div>

    <!-- AGREGAR NUEVOS JUGADORES -->
    <div class="admin-section">
        <h2 class="admin-section-title">➕ Agregar Jugadores Nuevos</h2>
        <p style="color:var(--color-muted);font-size:13px;margin-bottom:16px;">
            Ingresá nombre, elegí el país y la división. Los países ya tomados aparecen bloqueados.
        </p>
        <div id="nuevos-container"></div>
        <button type="button" class="btn-outline" onclick="agregarNuevo()">+ Agregar jugador</button>
    </div>

    <div style="display:flex;gap:12px;margin-top:24px;">
        <button type="submit" class="btn-primary" onclick="return confirm('¿Generar el fixture para esta temporada?')">
            🎲 Generar Fixture
        </button>
        <a asp-action="Index" class="btn-cancelar">Cancelar</a>
    </div>
</form>

@section Scripts {
<script>
// Países disponibles
const PAISES = [
    {code:'se',name:'Suecia 🇸🇪'},{code:'rs',name:'Serbia 🇷🇸'},{code:'sn',name:'Senegal 🇸🇳'},{code:'cm',name:'Camerún 🇨🇲'},
    {code:'ca',name:'Canadá 🇨🇦'},{code:'qa',name:'Qatar 🇶🇦'},{code:'gh',name:'Ghana 🇬🇭'},
    {code:'dz',name:'Argelia 🇩🇿'},{code:'au',name:'Australia 🇦🇺'},{code:'cn',name:'China 🇨🇳'},
    {code:'hr',name:'Croacia 🇭🇷'},{code:'eg',name:'Egipto 🇪🇬'},{code:'gb',name:'Inglaterra 🏴󠁧󠁢󠁥󠁮󠁧󠁿'},
    {code:'fr',name:'Francia 🇫🇷'},{code:'id',name:'Indonesia 🇮🇩'},{code:'jp',name:'Japón 🇯🇵'},
    {code:'my',name:'Malasia 🇲🇾'},{code:'mx',name:'México 🇲🇽'},{code:'ma',name:'Marruecos 🇲🇦'},
    {code:'ng',name:'Nigeria 🇳🇬'},{code:'pe',name:'Perú 🇵🇪'},{code:'pt',name:'Portugal 🇵🇹'},
    {code:'ru',name:'Rusia 🇷🇺'},{code:'sa',name:'Arabia Saudita 🇸🇦'},{code:'kr',name:'Corea del Sur 🇰🇷'},
    {code:'th',name:'Tailandia 🇹🇭'},{code:'tn',name:'Túnez 🇹🇳'},{code:'tr',name:'Turquía 🇹🇷'},
    {code:'pl',name:'Polonia 🇵🇱'}
];

let paisesTomados = {};

// Cargar países tomados
fetch('/Admin/GetPaisesTomados')
    .then(r => r.json())
    .then(data => {
        data.forEach(e => { paisesTomados[e.flagCode] = e.equipo; });
    });

function buildSelectPaises(selectedCode) {
    let html = '<option value="">-- Sin bandera --</option>';
    PAISES.forEach(p => {
        const tomado = paisesTomados[p.code];
        if (tomado) {
            html += `<option value="${p.code}" disabled style="color:#666;">${p.name} (${tomado})</option>`;
        } else {
            html += `<option value="${p.code}" ${p.code === selectedCode ? 'selected' : ''}>${p.name}</option>`;
        }
    });
    return html;
}

function agregarNuevo() {
    const div = document.createElement('div');
    div.className = 'nuevo-equipo-row';
    div.style.cssText = 'display:flex;gap:10px;align-items:center;margin-bottom:10px;flex-wrap:wrap;';
    div.innerHTML = `
        <input type="text" name="nuevosNombres" placeholder="Nombre del jugador"
               class="form-control" style="width:180px" />
        <select name="nuevasPaisCodesN" class="form-control" style="width:200px">
            ${buildSelectPaises('')}
        </select>
        <select name="nuevasDivisiones" class="form-control" style="width:160px">
            <option value="1">Primera División</option>
            <option value="2" selected>Primera Nacional</option>
        </select>
        <button type="button" onclick="this.parentElement.remove()"
                class="btn-cancelar" style="padding:8px 12px;">✕</button>
    `;
    document.getElementById('nuevos-container').appendChild(div);
}
</script>
}
