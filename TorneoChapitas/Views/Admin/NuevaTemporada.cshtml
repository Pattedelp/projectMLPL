@model NuevaTemporadaViewModel
@{
    ViewBag.Title = "Nueva Temporada";
    ViewBag.ActivePage = "admin";
}

<div class="page-hero">
    <div class="page-hero-icon">🔄</div>
    <div class="page-hero-text">
        <h1>Nueva Temporada</h1>
        <p>Configurá los equipos y generá el fixture automáticamente</p>
    </div>
</div>

<form method="post" asp-action="NuevaTemporada">
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:24px;margin-bottom:24px;">
        <div class="form-group">
            <label>Nombre de la temporada</label>
            <input type="text" name="nombreTemporada"
                   value="Temporada @Model.NumeroTemporada"
                   class="form-control" style="max-width:300px" required />
        </div>
    </div>

    <!-- PRIMERA DIVISIÓN -->
    <div class="admin-section">
        <h2 class="admin-section-title">🏆 Primera División</h2>
        <p style="color:var(--color-muted);font-size:13px;margin-bottom:16px;">
            Destildá los equipos que no participen.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;">
            @foreach (var e in Model.EquiposPrimera)
            {
                <label style="display:flex;align-items:center;gap:8px;background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:10px 14px;cursor:pointer;font-size:13px;">
                    <input type="checkbox" name="equiposPrimera" value="@e.Id" checked
                           style="accent-color:var(--color-gold);width:16px;height:16px;" />
                    @if (!string.IsNullOrEmpty(e.FlagCode))
                    {
                        <img src="https://flagcdn.com/20x15/@(e.FlagCode).png" class="flag-img" alt="" />
                    }
                    <span>@e.Nombre</span>
                </label>
            }
        </div>
    </div>

    <!-- PRIMERA NACIONAL -->
    <div class="admin-section">
        <h2 class="admin-section-title">🥈 Primera Nacional</h2>
        <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;">
            @foreach (var e in Model.EquiposNacionalB)
            {
                <label style="display:flex;align-items:center;gap:8px;background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:10px 14px;cursor:pointer;font-size:13px;">
                    <input type="checkbox" name="equiposB" value="@e.Id" checked
                           style="accent-color:var(--color-gold);width:16px;height:16px;" />
                    @if (!string.IsNullOrEmpty(e.FlagCode))
                    {
                        <img src="https://flagcdn.com/20x15/@(e.FlagCode).png" class="flag-img" alt="" />
                    }
                    <span>@e.Nombre</span>
                </label>
            }
        </div>
    </div>

    <!-- PRIMERA C (solo si está activa) -->
    @if (ViewBag.PrimeraCActiva == true)
    {
        var equiposC = ViewBag.EquiposC as List<EquipoCheckbox> ?? new();
        <div class="admin-section">
            <h2 class="admin-section-title">🏟️ Primera C Nacional</h2>
            <p style="color:var(--color-muted);font-size:13px;margin-bottom:16px;">
                Destildá los equipos que no participen.
            </p>
            @if (equiposC.Any())
            {
                <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;">
                    @foreach (var e in equiposC)
                    {
                        <label style="display:flex;align-items:center;gap:8px;background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:10px 14px;cursor:pointer;font-size:13px;">
                            <input type="checkbox" name="equiposC" value="@e.Id" checked
                                   style="accent-color:#7c3aed;width:16px;height:16px;" />
                            @if (!string.IsNullOrEmpty(e.FlagCode))
                            {
                                <img src="https://flagcdn.com/20x15/@(e.FlagCode).png" class="flag-img" alt="" />
                            }
                            <span>@e.Nombre</span>
                        </label>
                    }
                </div>
            }
            else
            {
                <p style="font-size:13px;color:var(--color-muted);">No hay equipos en Primera C todavía. Podés agregar nuevos jugadores abajo.</p>
            }
        </div>
    }

    <!-- AGREGAR NUEVOS JUGADORES -->
    <div class="admin-section">
        <h2 class="admin-section-title">➕ Agregar Jugadores Nuevos</h2>
        <p style="color:var(--color-muted);font-size:13px;margin-bottom:16px;">
            Ingresá nombre, elegí el país y la división. Los países ya tomados aparecen bloqueados.
        </p>
        <div id="nuevos-container"></div>
        <button type="button" class="btn-outline" onclick="agregarNuevo()">+ Agregar jugador</button>
    </div>

    <!-- CONFIGURACIÓN DE MOVIMIENTOS -->
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px;margin-top:20px;">
        <h3 style="font-family:var(--font-heading);font-size:13px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:16px;">
            ⚙️ Configuración de Descensos y Ascensos
        </h3>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
            <div>
                <label style="font-size:12px;color:var(--color-muted);display:block;margin-bottom:6px;">Descensos directos</label>
                <select name="cantDescensos" class="form-control" style="font-size:13px;">
                    <option value="0">Sin descensos</option>
                    <option value="1">1 descenso</option>
                    <option value="2" selected>2 descensos</option>
                </select>
            </div>
            <div>
                <label style="font-size:12px;color:var(--color-muted);display:block;margin-bottom:6px;">Ascensos directos</label>
                <select name="cantAscensos" class="form-control" style="font-size:13px;">
                    <option value="1">1 ascenso</option>
                    <option value="2" selected>2 ascensos</option>
                </select>
            </div>
        </div>

        <label style="display:flex;align-items:center;gap:10px;cursor:pointer;margin-bottom:12px;">
            <input type="checkbox" name="tienePromocion" id="chk-promocion" value="true"
                   style="accent-color:var(--color-gold);width:16px;height:16px;" onchange="togglePromocion(this)" />
            <span style="font-size:13px;">
                🔁 <strong>Partido de promoción</strong>
                <span style="color:var(--color-muted);font-size:11px;display:block;">Un equipo de Primera juega contra uno de la B — el ganador queda en Primera.</span>
            </span>
        </label>

        <div id="config-promocion" style="display:none;background:var(--color-bg3);border-radius:8px;padding:14px;display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div>
                <label style="font-size:11px;color:var(--color-muted);display:block;margin-bottom:6px;">Posición en Primera que va a promoción</label>
                <input type="number" name="posPromocionPrimera" value="8" min="1" max="20"
                       class="form-control" style="font-size:13px;" />
                <span style="font-size:10px;color:var(--color-muted);">ej: 8 = el 8vo de Primera</span>
            </div>
            <div>
                <label style="font-size:11px;color:var(--color-muted);display:block;margin-bottom:6px;">Posición en la B que va a promoción</label>
                <input type="number" name="posPromocionB" value="3" min="1" max="20"
                       class="form-control" style="font-size:13px;" />
                <span style="font-size:10px;color:var(--color-muted);">ej: 3 = el 3ro de la B</span>
            </div>
        </div>
    </div>

    <div style="display:flex;gap:12px;margin-top:24px;">
        <button type="submit" class="btn-primary" onclick="return confirm('¿Generar el fixture para esta temporada?')">
            🎲 Generar Fixture
        </button>
        <a asp-action="Index" class="btn-cancelar">Cancelar</a>
    </div>
</form>

@section Scripts {
<script>
function togglePromocion(chk) {
    document.getElementById('config-promocion').style.display = chk.checked ? 'grid' : 'none';
}

const PAISES = [
    {code:'de',name:'Alemania'},{code:'dz',name:'Argelia'},{code:'sa',name:'Arabia Saudita'},
    {code:'ar',name:'Argentina'},{code:'au',name:'Australia'},{code:'be',name:'Bélgica'},
    {code:'br',name:'Brasil'},{code:'ca',name:'Canadá'},{code:'cm',name:'Camerún'},
    {code:'cn',name:'China'},{code:'co',name:'Colombia'},{code:'kr',name:'Corea del Sur'},
    {code:'cr',name:'Costa Rica'},{code:'hr',name:'Croacia'},{code:'dk',name:'Dinamarca'},
    {code:'ec',name:'Ecuador'},{code:'eg',name:'Egipto'},{code:'es',name:'España'},
    {code:'us',name:'Estados Unidos'},{code:'ph',name:'Filipinas'},{code:'fr',name:'Francia'},
    {code:'gh',name:'Ghana'},{code:'gb-wls',name:'Gales'},{code:'gb',name:'Inglaterra'},
    {code:'id',name:'Indonesia'},{code:'ir',name:'Irán'},{code:'it',name:'Italia'},
    {code:'jp',name:'Japón'},{code:'my',name:'Malasia'},{code:'ma',name:'Marruecos'},
    {code:'mx',name:'México'},{code:'ng',name:'Nigeria'},{code:'nl',name:'Países Bajos'},
    {code:'pe',name:'Perú'},{code:'pl',name:'Polonia'},{code:'pt',name:'Portugal'},
    {code:'qa',name:'Qatar'},{code:'ru',name:'Rusia'},{code:'sn',name:'Senegal'},
    {code:'rs',name:'Serbia'},{code:'se',name:'Suecia'},{code:'ch',name:'Suiza'},
    {code:'th',name:'Tailandia'},{code:'tn',name:'Túnez'},{code:'tr',name:'Turquía'},
    {code:'ua',name:'Ucrania'},{code:'uy',name:'Uruguay'},{code:'vn',name:'Vietnam'},
];

let paisesTomados = {};

fetch('/Admin/GetPaisesTomados')
    .then(r => r.json())
    .then(data => { data.forEach(e => { paisesTomados[e.flagCode] = e.equipo; }); });

function buildSelectPaises() {
    let html = '<option value="">-- Sin bandera --</option>';
    PAISES.forEach(p => {
        const tomado = paisesTomados[p.code];
        if (tomado) {
            html += `<option value="${p.code}" disabled style="color:#666;">${p.name} (${tomado})</option>`;
        } else {
            html += `<option value="${p.code}">${p.name}</option>`;
        }
    });
    return html;
}

function agregarNuevo() {
    const primeraCActiva = @(ViewBag.PrimeraCActiva == true ? "true" : "false");
    const div = document.createElement('div');
    div.className = 'nuevo-equipo-row';
    div.style.cssText = 'display:flex;gap:10px;align-items:center;margin-bottom:10px;flex-wrap:wrap;';
    div.innerHTML = `
        <input type="text" name="nuevosNombres" placeholder="Nombre del jugador"
               class="form-control" style="width:180px" />
        <select name="nuevasPaisCodesN" class="form-control" style="width:200px">
            ${buildSelectPaises()}
        </select>
        <select name="nuevasDivisiones" class="form-control" style="width:160px">
            <option value="1">Primera División</option>
            <option value="2" selected>Primera Nacional</option>
            ${primeraCActiva ? '<option value="3">Primera C Nacional</option>' : ''}
        </select>
        <button type="button" onclick="this.parentElement.remove()"
                class="btn-cancelar" style="padding:8px 12px;">✕</button>
    `;
    document.getElementById('nuevos-container').appendChild(div);
}
</script>
}
