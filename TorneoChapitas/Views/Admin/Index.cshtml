@model HistorialViewModel
@{
    ViewBag.Title = "Panel Admin";
    ViewBag.ActivePage = "admin";
}

<div class="page-hero">
    <div class="page-hero-icon">⚙️</div>
    <div class="page-hero-text">
        <h1>Panel de Administración</h1>
        <p>Torneo Chapitas · AAC</p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div style="background:rgba(224,85,85,.15);border-left:3px solid var(--color-red);color:var(--color-red);padding:12px 20px;border-radius:6px;margin-bottom:20px;">
        ⚠️ @TempData["Error"]
    </div>
}

@if (Model.TemporadaActiva != null)
{
    <div class="admin-section">
        <h2 class="admin-section-title">📅 Temporada Activa: @Model.TemporadaActiva.Nombre</h2>

        <div style="display:flex;flex-direction:column;gap:12px;">

            <!-- FINALIZAR TEMPORADA -->
            <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px 24px;">
                <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
                    <div style="width:44px;height:44px;border-radius:50%;background:rgba(224,85,85,.2);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">🏁</div>
                    <div>
                        <div style="font-family:var(--font-heading);font-size:14px;letter-spacing:1px;color:var(--color-text);">Finalizar Temporada</div>
                        <div style="font-size:12px;color:var(--color-muted);margin-top:2px;">Guarda historial, mueve equipos, registra campeones</div>
                    </div>
                </div>

                <!-- Opciones de finalización -->
                <div style="background:var(--color-bg3);border-radius:8px;padding:16px;margin-bottom:16px;">
                    <label style="display:flex;align-items:center;gap:10px;cursor:pointer;margin-bottom:12px;">
                        <input type="checkbox" id="chk-sin-descensos"
                               style="accent-color:var(--color-gold);width:16px;height:16px;" />
                        <span style="font-size:13px;color:var(--color-text);">
                            ⚠️ <strong>Sin descensos esta temporada</strong>
                            <span style="color:var(--color-muted);font-size:11px;display:block;margin-top:2px;">
                                Los ascensos de la B se aplican normalmente, pero nadie baja de Primera.
                            </span>
                        </span>
                    </label>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div>
                            <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:6px;">🏆 Campeón Copa Argentina</label>
                            <select id="sel-campeon-copa" class="form-control" style="font-size:13px;">
                                <option value="0">-- No se jugó --</option>
                            </select>
                        </div>
                        <div>
                            <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:6px;">⭐ Campeón Supercopa</label>
                            <select id="sel-campeon-supercopa" class="form-control" style="font-size:13px;">
                                <option value="0">-- No se jugó --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <button onclick="confirmarFinalizar()"
                        style="background:var(--color-red);color:#fff;border:none;border-radius:8px;padding:10px 20px;font-family:var(--font-heading);font-size:13px;letter-spacing:1px;cursor:pointer;">
                    Finalizar Temporada
                </button>
            </div>

            <!-- COPA ARGENTINA -->
            <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px 24px;display:flex;align-items:center;gap:16px;">
                <div style="width:44px;height:44px;border-radius:50%;background:rgba(240,192,64,.2);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">🏆</div>
                <div style="flex:1;">
                    <div style="font-family:var(--font-heading);font-size:14px;letter-spacing:1px;color:var(--color-text);">Sortear Copa Argentina</div>
                    <div style="font-size:12px;color:var(--color-muted);margin-top:2px;">Primera vs B · fase previa si sobran equipos de la B</div>
                </div>
                <a asp-action="SortearCopa" style="background:var(--color-gold);color:var(--color-bg);border:none;border-radius:8px;padding:10px 20px;font-family:var(--font-heading);font-size:13px;letter-spacing:1px;cursor:pointer;text-decoration:none;flex-shrink:0;">
                    Configurar
                </a>
            </div>

            <!-- SUPERCOPA -->
            <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px 24px;display:flex;align-items:center;gap:16px;">
                <div style="width:44px;height:44px;border-radius:50%;background:rgba(58,130,200,.2);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">⭐</div>
                <div style="flex:1;">
                    <div style="font-family:var(--font-heading);font-size:14px;letter-spacing:1px;color:var(--color-text);">Configurar Supercopa</div>
                    <div style="font-size:12px;color:var(--color-muted);margin-top:2px;">Campeón vs Subcampeón → ganador vs Campeón Copa</div>
                </div>
                <a asp-action="ConfigurarSupercopa" style="background:#3a82c8;color:#fff;border:none;border-radius:8px;padding:10px 20px;font-family:var(--font-heading);font-size:13px;letter-spacing:1px;cursor:pointer;text-decoration:none;flex-shrink:0;">
                    Configurar
                </a>
            </div>

        </div>
    </div>
}
else
{
    <div class="admin-section">
        <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:24px;text-align:center;">
            <div style="font-size:32px;margin-bottom:12px;">⚠️</div>
            <h3 style="font-family:var(--font-heading);color:var(--color-gold);margin-bottom:8px;">No hay temporada activa</h3>
            <a asp-action="NuevaTemporada" class="btn-primary">+ Nueva Temporada</a>
        </div>
    </div>
}

<!-- AGREGAR JUGADORES -->
<div class="admin-section">
    <h2 class="admin-section-title">👤 Jugadores</h2>
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px 24px;display:flex;align-items:center;gap:16px;">
        <div style="width:44px;height:44px;border-radius:50%;background:rgba(240,192,64,.2);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">👤</div>
        <div style="flex:1;">
            <div style="font-family:var(--font-heading);font-size:14px;letter-spacing:1px;color:var(--color-text);">Agregar Jugador Nuevo</div>
            <div style="font-size:12px;color:var(--color-muted);margin-top:2px;">Ingresá nombre y país — se inserta directo en la BD</div>
        </div>
        <a asp-action="AgregarJugador" style="background:var(--color-gold);color:var(--color-bg);border:none;border-radius:8px;padding:10px 20px;font-family:var(--font-heading);font-size:13px;letter-spacing:1px;cursor:pointer;text-decoration:none;flex-shrink:0;">
            Agregar
        </a>
    </div>
</div>

<!-- REDACTORES -->
<div class="admin-section">
    <h2 class="admin-section-title">✏️ Redactores de Noticias</h2>
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px 24px;display:flex;align-items:center;gap:16px;">
        <div style="width:44px;height:44px;border-radius:50%;background:rgba(76,175,130,.2);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">✏️</div>
        <div style="flex:1;">
            <div style="font-family:var(--font-heading);font-size:14px;letter-spacing:1px;color:var(--color-text);">Gestionar Redactores</div>
            <div style="font-size:12px;color:var(--color-muted);margin-top:2px;">Crear usuarios con acceso a la sala de noticias</div>
        </div>
        <a asp-controller="Redactores" asp-action="Index" style="background:var(--color-green);color:#fff;border:none;border-radius:8px;padding:10px 20px;font-family:var(--font-heading);font-size:13px;letter-spacing:1px;cursor:pointer;text-decoration:none;flex-shrink:0;">
            Gestionar
        </a>
    </div>
</div>

<!-- NUEVA TEMPORADA -->
<div class="admin-section">
    <h2 class="admin-section-title">🔄 Nueva Temporada</h2>
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:24px;">
        <p style="color:var(--color-muted);font-size:14px;margin-bottom:16px;">
            Disponible una vez finalizada la temporada actual.
        </p>
        <a asp-action="NuevaTemporada"
           style="@(Model.TemporadaActiva != null ? "opacity:0.4;pointer-events:none;" : "")"
           class="btn-primary">
            Iniciar Nueva Temporada
        </a>
    </div>
</div>

<!-- HISTORIAL -->
<div class="admin-section">
    <h2 class="admin-section-title">📚 Historial de Temporadas</h2>
    @if (!Model.Temporadas.Any(t => t.Finalizada))
    {
        <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:24px;text-align:center;">
            <p style="color:var(--color-muted);font-size:14px;">Aún no hay temporadas finalizadas.</p>
        </div>
    }
    else
    {
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;">
            @foreach (var t in Model.Temporadas.Where(t => t.Finalizada))
            {
                <a asp-action="TemporadaDetalle" asp-route-id="@t.Id"
                   style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px;text-decoration:none;display:block;">
                    <div style="font-family:var(--font-heading);font-size:28px;font-weight:700;color:var(--color-gold);">T@t.Numero</div>
                    <div style="font-size:14px;font-weight:500;color:var(--color-text);margin:4px 0;">@t.Nombre</div>
                    <div style="font-size:12px;color:var(--color-muted);">@t.FechaFin?.ToString("MMM yyyy")</div>
                    <div style="font-size:12px;color:var(--color-gold);margin-top:12px;">Ver detalle →</div>
                </a>
            }
        </div>
    }
</div>

@section Scripts {
<script>
// Cargar equipos para los selectores de campeones
fetch('/Admin/GetEquiposTodos')
    .then(r => r.json())
    .then(equipos => {
        ['sel-campeon-copa', 'sel-campeon-supercopa'].forEach(id => {
            const sel = document.getElementById(id);
            equipos.forEach(e => {
                const opt = document.createElement('option');
                opt.value = e.id;
                opt.textContent = e.nombre;
                sel.appendChild(opt);
            });
        });
    });

async function confirmarFinalizar() {
    const sinDesc   = document.getElementById('chk-sin-descensos').checked;
    const copaId    = parseInt(document.getElementById('sel-campeon-copa').value);
    const supercopaId = parseInt(document.getElementById('sel-campeon-supercopa').value);

    let msg = '¿Finalizar la temporada?';
    if (sinDesc) msg += '\n⚠️ Sin descensos esta temporada.';
    if (copaId > 0) msg += '\n🏆 Se registrará el campeón de Copa.';
    if (supercopaId > 0) msg += '\n⭐ Se registrará el campeón de Supercopa.';

    if (!confirm(msg)) return;

    const r = await fetch('/Admin/FinalizarTemporada', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            sinDescensos: sinDesc,
            campeonCopaId: copaId,
            campeonSupercopaId: supercopaId
        })
    });
    const d = await r.json();
    if (d.ok) { alert('✅ Temporada finalizada correctamente.'); location.reload(); }
    else alert('Error: ' + d.msg);
}
</script>
}
