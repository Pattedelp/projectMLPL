<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Torneo Chapitas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;700&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" href="~/favicon.ico" type="image/x-icon" />
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="~/img/apple-touch-icon.png" />
    <meta property="og:title" content="@ViewBag.Title - Torneo Chapitas" />
    <meta property="og:description" content="Torneo Chapitas - AAC" />
    <meta property="og:image" content="https://torneochapitas.up.railway.app/img/og-image.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="stylesheet" href="~/css/torneo.css" />
    <style>
        .zona-descenso-c { border-left: 3px solid #7c3aed; background: rgba(124,58,237,0.06); }
    </style>
</head>
<body>

<header class="topbar">
    <div class="topbar-inner">
        <a asp-controller="Home" asp-action="Index" class="logo">
            <span class="logo-icon">🏆</span>
            <span class="logo-text">Torneo Chapitas <em>AAC</em></span>
        </a>

        <nav class="main-nav">
            <a asp-controller="Home" asp-action="Index"
               class="@(ViewBag.ActivePage=="home"?"active":"")">Inicio</a>

            <div class="nav-dropdown">
                <span class="@(ViewBag.ActivePage=="primera"?"active":"")">1ra División ▾</span>
                <div class="dropdown-menu">
                    <a asp-controller="PrimeraDivision" asp-action="Posiciones">Posiciones</a>
                    <a asp-controller="PrimeraDivision" asp-action="Fixture">Fixture</a>
                    <a asp-controller="PrimeraDivision" asp-action="Equipos">Equipos</a>
                </div>
            </div>

            <div class="nav-dropdown">
                <span class="@(ViewBag.ActivePage=="nacb"?"active":"")">1ra Nacional ▾</span>
                <div class="dropdown-menu">
                    <a asp-controller="NacionalB" asp-action="Posiciones">Posiciones</a>
                    <a asp-controller="NacionalB" asp-action="Fixture">Fixture</a>
                    <a asp-controller="NacionalB" asp-action="Equipos">Equipos</a>
                </div>
            </div>

            @if (ViewBag.PrimeraCActiva == true)
            {
            <div class="nav-dropdown">
                <span class="@(ViewBag.ActivePage=="primera-c"?"active":"")">1ra C Nacional ▾</span>
                <div class="dropdown-menu">
                    <a asp-controller="PrimeraC" asp-action="Posiciones">Posiciones</a>
                    <a asp-controller="PrimeraC" asp-action="Fixture">Fixture</a>
                    <a asp-controller="PrimeraC" asp-action="Equipos">Equipos</a>
                </div>
            </div>
            }

            <div class="nav-dropdown">
                <span class="@(ViewBag.ActivePage=="copas"?"active":"")">Copas ▾</span>
                <div class="dropdown-menu">
                    <a asp-controller="Copas" asp-action="CopaArgentina">Copa Argentina</a>
                    <a asp-controller="Copas" asp-action="SupercopaArgentina">Supercopa Argentina</a>
                </div>
            </div>

            <a asp-controller="Noticias" asp-action="Index"
               class="@(ViewBag.ActivePage=="noticias"?"active":"")">Noticias</a>

            <div class="nav-dropdown">
                <span class="@((ViewBag.ActivePage=="historial"||ViewBag.ActivePage=="estadisticas"||ViewBag.ActivePage=="trofeos"||ViewBag.ActivePage=="predicciones"||ViewBag.ActivePage=="legacy"||ViewBag.ActivePage=="ranking"||ViewBag.ActivePage=="practica")?"active":"")">Más ▾</span>
                <div class="dropdown-menu">
                    <a asp-controller="Historial" asp-action="Index">📚 Historial de Temporadas</a>
                    <a asp-controller="Estadisticas" asp-action="Index">📈 Estadísticas</a>
                    <a asp-controller="Trofeos" asp-action="Index">🏆 Vidriera de Copas</a>
                    <a asp-controller="Predicciones" asp-action="Index">🔮 Predicciones</a>
                    <a asp-controller="Legacy" asp-action="Index">📜 Amateurismo</a>
                    <a asp-controller="Ranking" asp-action="Index">🌍 Ranking AAC</a>
                    <a asp-controller="Practica" asp-action="Index">🎯 Modo Práctica</a>
                </div>
            </div>
        </nav>

        <div class="nav-auth">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index"
                   class="btn-login @(ViewBag.ActivePage == "admin" ? "active" : "")">⚙️ Admin</a>
                <form method="post" asp-controller="Auth" asp-action="Logout" style="display:inline">
                    <button type="submit" class="btn-logout">Salir</button>
                </form>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="btn-login">🔐 Admin</a>
            }
        </div>

        <div class="nav-auth-mobile">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index" class="btn-auth-mobile">⚙️</a>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="btn-auth-mobile">🔐</a>
            }
        </div>

        <button class="nav-toggle" id="navToggle" aria-label="Menú">
            <span></span><span></span><span></span>
        </button>
    </div>
</header>

<div class="drawer-overlay" id="drawerOverlay"></div>

<nav class="drawer" id="drawer" aria-hidden="true">
    <div class="drawer-header">
        <span class="drawer-logo">🏆 Torneo Chapitas</span>
        <button class="drawer-close" id="drawerClose" aria-label="Cerrar menú">✕</button>
    </div>
    <div class="drawer-body">
        <a asp-controller="Home" asp-action="Index" class="drawer-item">🏠 Inicio</a>

        <div class="drawer-section-label">🏆 Primera División</div>
        <a asp-controller="PrimeraDivision" asp-action="Posiciones" class="drawer-item drawer-sub">Posiciones</a>
        <a asp-controller="PrimeraDivision" asp-action="Fixture" class="drawer-item drawer-sub">Fixture</a>
        <a asp-controller="PrimeraDivision" asp-action="Equipos" class="drawer-item drawer-sub">Equipos</a>

        <div class="drawer-section-label">🥈 Primera Nacional</div>
        <a asp-controller="NacionalB" asp-action="Posiciones" class="drawer-item drawer-sub">Posiciones</a>
        <a asp-controller="NacionalB" asp-action="Fixture" class="drawer-item drawer-sub">Fixture</a>
        <a asp-controller="NacionalB" asp-action="Equipos" class="drawer-item drawer-sub">Equipos</a>

        @if (ViewBag.PrimeraCActiva == true)
        {
        <div class="drawer-section-label">🏟️ Primera C Nacional</div>
        <a asp-controller="PrimeraC" asp-action="Posiciones" class="drawer-item drawer-sub">Posiciones</a>
        <a asp-controller="PrimeraC" asp-action="Fixture" class="drawer-item drawer-sub">Fixture</a>
        <a asp-controller="PrimeraC" asp-action="Equipos" class="drawer-item drawer-sub">Equipos</a>
        }

        <div class="drawer-section-label">🏅 Copas</div>
        <a asp-controller="Copas" asp-action="CopaArgentina" class="drawer-item drawer-sub">Copa Argentina</a>
        <a asp-controller="Copas" asp-action="SupercopaArgentina" class="drawer-item drawer-sub">Supercopa Argentina</a>

        <div class="drawer-divider"></div>
        <a asp-controller="Noticias" asp-action="Index" class="drawer-item">📰 Noticias</a>
        <a asp-controller="Historial" asp-action="Index" class="drawer-item">📚 Historial de Temporadas</a>
        <a asp-controller="Estadisticas" asp-action="Index" class="drawer-item">📈 Estadísticas</a>
        <a asp-controller="Trofeos" asp-action="Index" class="drawer-item">🏆 Vidriera de Copas</a>
        <a asp-controller="Predicciones" asp-action="Index" class="drawer-item">🔮 Predicciones</a>
        <a asp-controller="Legacy" asp-action="Index" class="drawer-item">📜 Amateurismo</a>
        <a asp-controller="Ranking" asp-action="Index" class="drawer-item">🌍 Ranking AAC</a>
        <a asp-controller="Practica" asp-action="Index" class="drawer-item">🎯 Modo Práctica</a>

        <div class="drawer-divider"></div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Index" class="drawer-item">⚙️ Panel Admin</a>
            <form method="post" asp-controller="Auth" asp-action="Logout" style="margin:0">
                <button type="submit" class="drawer-item drawer-item-btn">🚪 Cerrar sesión</button>
            </form>
        }
        else
        {
            <a asp-controller="Auth" asp-action="Login" class="drawer-item">🔐 Acceso Admin</a>
        }
        <div style="height:40px"></div>
    </div>
</nav>

@if (TempData["Mensaje"] != null)
{
    <div class="alert-success"><span>✓</span> @TempData["Mensaje"]</div>
}

<main class="site-main">
    @RenderBody()
</main>

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-left">
            <img src="~/img/aac-logo.png" alt="AAC"
                 style="width:36px;height:36px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
            <div class="footer-brand">
                Torneo Chapitas
                <span>Asociación Argentina de Chapitas</span>
            </div>
        </div>
        <div class="footer-copy">
            © 2025 Torneo Chapitas. Todos los derechos reservados.
            <span id="online-count" style="color:var(--color-green);font-size:12px;margin-left:12px;">● <span id="online-num">0</span> en línea</span>
        </div>
        <div class="footer-social">
            <a href="#">📘</a><a href="#">📷</a><a href="#">▶️</a>
        </div>
    </div>
</footer>

<script>
async function pingOnline() {
    try {
        const r = await fetch('/api/online');
        const d = await r.json();
        const el = document.getElementById('online-num');
        if (el) el.textContent = d.count;
    } catch {}
}
pingOnline();
setInterval(pingOnline, 30000);

const drawer        = document.getElementById('drawer');
const drawerOverlay = document.getElementById('drawerOverlay');
const navToggle     = document.getElementById('navToggle');
const drawerClose   = document.getElementById('drawerClose');

function openDrawer() {
    drawer.classList.add('open');
    drawerOverlay.classList.add('open');
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
}
function closeDrawer() {
    drawer.classList.remove('open');
    drawerOverlay.classList.remove('open');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
}

navToggle.addEventListener('click', function(e) { e.stopPropagation(); openDrawer(); });
drawerClose.addEventListener('click', closeDrawer);
drawerOverlay.addEventListener('click', closeDrawer);

let txStart = 0;
drawer.addEventListener('touchstart', e => { txStart = e.touches[0].clientX; }, { passive: true });
drawer.addEventListener('touchend',   e => {
    if (e.changedTouches[0].clientX - txStart > 60) closeDrawer();
}, { passive: true });

document.querySelectorAll('.nav-dropdown').forEach(function(dropdown) {
    var span  = dropdown.querySelector('span');
    var menu  = dropdown.querySelector('.dropdown-menu');
    var timer = null;

    function showMenu() {
        clearTimeout(timer);
        document.querySelectorAll('.dropdown-menu').forEach(function(m) {
            if (m !== menu) { m.style.display = 'none'; }
        });
        var rect = span.getBoundingClientRect();
        menu.style.position = 'fixed';
        menu.style.top      = rect.bottom + 'px';
        menu.style.left     = rect.left + 'px';
        menu.style.minWidth = Math.max(180, rect.width) + 'px';
        menu.style.zIndex   = '99999';
        menu.style.display  = 'block';
    }

    function hideMenu() {
        timer = setTimeout(function() { menu.style.display = 'none'; }, 150);
    }

    span.addEventListener('mouseenter', showMenu);
    span.addEventListener('mouseleave', hideMenu);
    menu.addEventListener('mouseenter', function() { clearTimeout(timer); });
    menu.addEventListener('mouseleave', hideMenu);
});
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
