@{
    ViewBag.Title = "Modo Práctica";
    ViewBag.ActivePage = "practica";
}

<div class="page-hero">
    <div class="page-hero-icon">🎯</div>
    <div class="page-hero-text">
        <h1>Modo Práctica</h1>
        <p>Practicá rebotes y pases · Sandbox libre, no se guarda nada</p>
    </div>
</div>

<div class="practica-wrap">
    <div class="practica-board-col">
        <div class="practica-scoreboard">
            <span class="practica-score-team">Vos <strong id="score-yo">0</strong></span>
            <span class="practica-score-sep">-</span>
            <span class="practica-score-team"><strong id="score-rival">0</strong> Rival</span>
        </div>
        <div class="practica-canvas-holder">
            <canvas id="practica-canvas"></canvas>
            <div id="practica-gol" class="practica-gol-msg">¡GOL!</div>
            <div id="practica-passes" class="practica-passes">Passes: 0/3</div>
            <div id="formacion-overlay" class="formacion-overlay">
                <h2 class="formacion-title">ELEGÍ TU FORMACIÓN</h2>
                <div id="formacion-step-title" class="formacion-step">TU EQUIPO</div>
                <div class="formacion-section-label">ATAQUE</div>
                <div class="formacion-grid" data-variant="atq"></div>
                <div class="formacion-section-label">DEFENSA</div>
                <div class="formacion-grid" data-variant="def"></div>
            </div>
        </div>
        <div class="practica-toolbar">
            <button id="practica-reset" class="btn-editar practica-btn">↺ Reiniciar</button>
            <button id="practica-cambiar-form" class="btn-editar practica-btn">⇄ Cambiar formación</button>
        </div>
    </div>
    <div class="practica-info-col">
        <div class="practica-info-card">
            <h3>Cómo jugar</h3>
            <ul>
                <li><strong>Elegí tu formación</strong> y la del rival antes de empezar</li>
                <li><strong>Tocá una chapita tuya</strong> y arrastrá hacia atrás (como un flick), soltá para disparar</li>
                <li>Todas las fichas y la pelota chocan con física real</li>
                <li><strong>Pases (máx 3):</strong> si la pelota toca a un compañero, la chapita se reacomoda detrás del balón lista para seguir</li>
            </ul>
        </div>
    </div>
</div>

<style>
.practica-wrap { display:flex; gap:24px; padding:0 16px 40px; flex-wrap:wrap; align-items:flex-start; justify-content:center; }
.practica-board-col { flex:0 1 420px; min-width:280px; }
.practica-scoreboard { display:flex; justify-content:center; align-items:center; gap:14px; background:var(--color-bg3); border:1px solid var(--color-border); border-radius:var(--radius) var(--radius) 0 0; padding:8px; font-family:var(--font-heading); letter-spacing:1px; font-size:14px; }
.practica-score-team strong { color:var(--color-gold); font-size:18px; }
.practica-score-sep { color:var(--color-muted); }
.practica-canvas-holder { position:relative; width:100%; aspect-ratio:390/660; background:#0a2e1f; border:1px solid var(--color-border); border-top:none; border-radius:0 0 var(--radius-lg) var(--radius-lg); overflow:hidden; touch-action:none; box-shadow:0 8px 24px rgba(0,0,0,.35); }
#practica-canvas { display:block; width:100%; height:100%; cursor:grab; }
.practica-gol-msg { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%) scale(0.6); font-family:var(--font-heading); font-size:42px; color:var(--color-gold); letter-spacing:4px; text-shadow:0 0 20px rgba(240,192,64,.8); opacity:0; pointer-events:none; transition:opacity .15s,transform .15s; z-index:3; }
.practica-gol-msg.show { opacity:1; transform:translate(-50%,-50%) scale(1); }
.practica-passes { position:absolute; bottom:8px; right:10px; background:rgba(0,0,0,0.55); color:#fff; font-size:11px; padding:3px 10px; border-radius:10px; pointer-events:none; z-index:2; }
.formacion-overlay { position:absolute; inset:0; z-index:5; background:rgba(5,8,12,0.96); display:flex; flex-direction:column; align-items:center; padding:18px 10px; overflow-y:auto; }
.formacion-title { font-family:var(--font-heading); color:var(--color-gold); font-size:20px; letter-spacing:2px; margin-bottom:2px; }
.formacion-step { color:#fff; font-size:12px; letter-spacing:2px; margin-bottom:12px; opacity:.8; }
.formacion-section-label { font-family:var(--font-heading); color:#fff; font-size:15px; letter-spacing:2px; margin:10px 0 8px; }
.formacion-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; width:100%; max-width:360px; }
.formacion-opt { text-align:center; cursor:pointer; }
.formacion-opt canvas { width:100%; border-radius:4px; display:block; border:2px solid transparent; transition:border-color .15s; }
.formacion-opt:hover canvas { border-color:var(--color-gold); }
.formacion-opt-name { color:#aaa; font-size:12px; margin-top:4px; }
.practica-toolbar { display:flex; align-items:center; gap:12px; margin-top:14px; flex-wrap:wrap; }
.practica-btn { padding:8px 16px; font-size:13px; }
.practica-info-col { flex:1 1 260px; min-width:240px; max-width:340px; }
.practica-info-card { background:var(--color-bg2); border:1px solid var(--color-border); border-radius:var(--radius-lg); padding:18px; }
.practica-info-card h3 { font-family:var(--font-heading); color:var(--color-gold); font-size:15px; letter-spacing:1px; margin-bottom:10px; text-transform:uppercase; }
.practica-info-card ul { padding-left:18px; display:flex; flex-direction:column; gap:8px; }
.practica-info-card li { font-size:13px; color:var(--color-muted); }
.practica-info-card li strong { color:var(--color-text); }
</style>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.19.0/matter.min.js"></script>
<script>
(function () {
    const canvas   = document.getElementById('practica-canvas');
    const ctx      = canvas.getContext('2d');
    const holder   = canvas.parentElement;
    const golMsg   = document.getElementById('practica-gol');
    const passesEl = document.getElementById('practica-passes');
    const scoreYoEl    = document.getElementById('score-yo');
    const scoreRivalEl = document.getElementById('score-rival');
    const overlay  = document.getElementById('formacion-overlay');
    const stepTitle= document.getElementById('formacion-step-title');

    // ── Espacio lógico ───────────────────────────────────────────────
    const W = 390, H = 660;
    const STAND_W   = 34;
    const GOAL_W    = 112;
    const GOAL_DEPTH= 24;
    const bounds    = { left: STAND_W, right: W-STAND_W, top: GOAL_DEPTH+8, bottom: H-GOAL_DEPTH-8 };
    const CX        = W / 2;
    const goalTop    = { xMin: CX-GOAL_W/2, xMax: CX+GOAL_W/2, y: bounds.top,    depth: GOAL_DEPTH };
    const goalBottom = { xMin: CX-GOAL_W/2, xMax: CX+GOAL_W/2, y: bounds.bottom, depth: GOAL_DEPTH };

    // ── Matter.js ────────────────────────────────────────────────────
    const { Engine, Bodies, Body, Composite, Events, Runner, Vector } = Matter;
    // positionIterations/velocityIterations altos → colisiones de roce (tangenciales)
    // se resuelven con precisión, sin rebotes bruscos en direcciones raras
    const engine = Engine.create({
        gravity: { x:0, y:0 },
        positionIterations: 12,
        velocityIterations: 10,
        constraintIterations: 4
    });
    const world  = engine.world;
    Runner.run(Runner.create(), engine);

    // ── Constantes físicas ───────────────────────────────────────────
    const PIECE_R   = 15;
    const BALL_R    = 9;
    const PASS_MAX  = 3;

    // Físicas copiadas de Gemini (pelota con menos fricción para que llegue lejos tras un roce)
    const PIECE_OPT = { frictionAir: 0.035, restitution: 0.4, friction: 0, frictionStatic: 0 };
    const BALL_OPT  = { frictionAir: 0.014, restitution: 0.85, friction: 0, frictionStatic: 0 };
    const WALL_OPT  = { isStatic: true, restitution: 0.6, friction: 0 };
    const POST_OPT  = { isStatic: true, restitution: 0.4, friction: 0 };
    const MASA_PIEZA= 5;
    const MASA_BOLA = 0.5;

    // Potencia copiada de Gemini: magnitud * 0.0008, tope
    const POT_FACTOR= 0.0008;
    const POT_MAX   = 0.32;
    const REST_V    = 1.5;   // velocidad Matter bajo la cual se considera quieto

    // ── Formaciones ──────────────────────────────────────────────────
    function stripeY(s)      { const sH=(bounds.bottom-bounds.top)/13; return bounds.bottom-(s-0.5)*sH; }
    function stripeYRival(s) { const sH=(bounds.bottom-bounds.top)/13; return bounds.top+(s-0.5)*sH; }

    const FORMACIONES = {
        // Medido del selector oficial. La SEPARACIÓN entre fichas de una misma línea
        // es funcional: deja un hueco por donde la pelota pasa rozando, lo que permite
        // hacer saques de costado que vuelven a un compañero.
        // s = franja (1=arco propio, 6=línea de medio). x = offset px desde centro.
        '1-3-2': {
            atq:[{x:0,s:1}, {x:-58,s:3},{x:0,s:3},{x:58,s:3}, {x:-30,s:5},{x:30,s:5}],
            def:[{x:0,s:1}, {x:-58,s:2},{x:0,s:2},{x:58,s:2}, {x:-30,s:3},{x:30,s:3}]
        },
        '1-2-3': {
            atq:[{x:0,s:1}, {x:-38,s:3},{x:38,s:3}, {x:-78,s:5},{x:0,s:5},{x:78,s:5}],
            def:[{x:0,s:1}, {x:-38,s:2},{x:38,s:2}, {x:-78,s:3},{x:0,s:3},{x:78,s:3}]
        },
        '1-4-1': {
            atq:[{x:0,s:1}, {x:-96,s:3},{x:-34,s:3},{x:34,s:3},{x:96,s:3}, {x:0,s:5}],
            def:[{x:0,s:1}, {x:0,s:4}, {x:-96,s:2},{x:-34,s:2},{x:34,s:2},{x:96,s:2}]
        },
        '1-2-1-2': {
            atq:[{x:0,s:1}, {x:-52,s:2},{x:52,s:2}, {x:0,s:4}, {x:-40,s:5},{x:40,s:5}],
            def:[{x:0,s:1}, {x:-52,s:2},{x:52,s:2}, {x:0,s:3}, {x:-40,s:4},{x:40,s:4}]
        }
    };
    const NOMBRES = ['1-3-2','1-2-3','1-4-1','1-2-1-2'];

    // ── Banderas ─────────────────────────────────────────────────────
    const flagYo    = new Image(); flagYo.crossOrigin='anonymous';    flagYo.src='https://flagcdn.com/64x48/ar.png';
    const flagRival = new Image(); flagRival.crossOrigin='anonymous'; flagRival.src='https://flagcdn.com/64x48/de.png';

    // ── Estado del juego ─────────────────────────────────────────────
    let pieces=[], mBall=null, walls=[];
    let formYo=null, formRival=null, selStep=0;
    let scoreYo=0, scoreRival=0, passes=0;
    let lastFlicked=null, pendingReceiver=null, scored=false;
    let aiming=null, dragStart=null, dragCur=null;

    // ── Coordenadas: getMouse devuelve espacio lógico W×H ────────────
    // Matter posiciona cuerpos en el mismo espacio porque los creamos con stripeY()
    function getMouse(e) {
        const r   = canvas.getBoundingClientRect();
        const src = e.touches ? e.touches[0] : e;
        return {
            x: (src.clientX - r.left) * (W / r.width),
            y: (src.clientY - r.top)  * (H / r.height)
        };
    }

    // ── Resize ───────────────────────────────────────────────────────
    function resizeCanvas() {
        const r   = holder.getBoundingClientRect();
        const dpr = window.devicePixelRatio || 1;
        canvas.width  = Math.round(r.width  * dpr);
        canvas.height = Math.round(r.height * dpr);
        ctx.setTransform((r.width * dpr) / W, 0, 0, (r.width * dpr) / W, 0, 0);
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    // ── Crear paredes Matter (en el mundo indicado) ──────────────────
    function makeWalls() {
        const T = 12;
        const gapLeft  = CX - GOAL_W/2 - bounds.left;
        const gapRight = bounds.right - (CX + GOAL_W/2);
        const midLeft  = bounds.left  + gapLeft/2;
        const midRight = bounds.right - gapRight/2;
        return [
            Bodies.rectangle(bounds.left  - T/2, H/2, T, H, WALL_OPT),
            Bodies.rectangle(bounds.right + T/2, H/2, T, H, WALL_OPT),
            Bodies.rectangle(midLeft,  bounds.top - T/2, gapLeft,  T, WALL_OPT),
            Bodies.rectangle(midRight, bounds.top - T/2, gapRight, T, WALL_OPT),
            Bodies.rectangle(midLeft,  bounds.bottom + T/2, gapLeft,  T, WALL_OPT),
            Bodies.rectangle(midRight, bounds.bottom + T/2, gapRight, T, WALL_OPT),
            Bodies.rectangle(CX, bounds.top    - GOAL_DEPTH + T/2, GOAL_W, T, { isStatic:true, restitution:0.1, friction:0 }),
            Bodies.rectangle(CX, bounds.bottom + GOAL_DEPTH - T/2, GOAL_W, T, { isStatic:true, restitution:0.1, friction:0 }),
            Bodies.circle(CX-GOAL_W/2, bounds.top,    5, POST_OPT),
            Bodies.circle(CX+GOAL_W/2, bounds.top,    5, POST_OPT),
            Bodies.circle(CX-GOAL_W/2, bounds.bottom, 5, POST_OPT),
            Bodies.circle(CX+GOAL_W/2, bounds.bottom, 5, POST_OPT)
        ];
    }

    function buildWalls() {
        if (walls.length) { walls.forEach(w => Composite.remove(world, w)); walls=[]; }
        walls = makeWalls();
        Composite.add(world, walls);
    }

    // ── Armar equipos ────────────────────────────────────────────────
    function makePiece(x, y, team) {
        const b = Bodies.circle(x, y, PIECE_R, PIECE_OPT);
        Body.setMass(b, MASA_PIEZA);
        b.team = team;
        return b;
    }

    function armarEquipos() {
        Composite.clear(world, false);
        pieces = []; buildWalls();

        FORMACIONES[formRival.nombre][formRival.variant].forEach(p => {
            const b = makePiece(CX + p.x, stripeYRival(p.s), 1);
            pieces.push(b); Composite.add(world, b);
        });
        FORMACIONES[formYo.nombre][formYo.variant].forEach(p => {
            const b = makePiece(CX + p.x, stripeY(p.s), 0);
            pieces.push(b); Composite.add(world, b);
        });

        mBall = Bodies.circle(CX, H/2, BALL_R, BALL_OPT);
        Body.setMass(mBall, MASA_BOLA);
        Composite.add(world, mBall);

        passes=0; lastFlicked=null; pendingReceiver=null; scored=false;
        passesEl.textContent = 'Passes: 0/'+PASS_MAX;

        Events.off(engine, 'collisionStart');
        Events.on(engine, 'collisionStart', onCollision);
    }

    function onCollision(ev) {
        ev.pairs.forEach(({ bodyA, bodyB }) => {
            const isBall = b => b === mBall;
            if (!isBall(bodyA) && !isBall(bodyB)) return;
            const other = isBall(bodyA) ? bodyB : bodyA;
            if (!pieces.includes(other)) return;
            if (other.team === 0) {
                // La pelota tocó una ficha MÍA → buen pase (si hubo un tiro y no es la misma ficha)
                if (lastFlicked && other !== lastFlicked && !pendingReceiver && passes < PASS_MAX) {
                    pendingReceiver = other;
                    passes++;
                    passesEl.textContent = 'Passes: '+passes+'/'+PASS_MAX;
                    mostrarBuenPase();
                }
            } else {
                // La pelota tocó una ficha RIVAL → se pierde la posesión
                passes=0; pendingReceiver=null; lastFlicked=null;
                passesEl.textContent = 'Passes: 0/'+PASS_MAX;
            }
        });
    }

    function mostrarBuenPase() {
        golMsg.textContent = '¡BUEN PASE!';
        golMsg.style.fontSize = '30px';
        golMsg.classList.add('show');
        setTimeout(()=>{
            golMsg.classList.remove('show');
            golMsg.textContent = '¡GOL!';
            golMsg.style.fontSize = '';
        }, 900);
    }

    // ── Selector de formación ────────────────────────────────────────
    function drawThumb(cv, nombre, variant) {
        const c=cv.getContext('2d'), tw=90, th=110;
        cv.width=tw; cv.height=th;
        for(let i=0;i<6;i++){c.fillStyle=i%2===0?'#3f9142':'#357a39'; c.fillRect(0,i*th/6,tw,th/6+1);}
        c.strokeStyle='rgba(255,255,255,.7)'; c.lineWidth=1.5;
        c.strokeRect(tw/2-20,th-14,40,14);
        c.beginPath(); c.arc(tw/2,0,22,0,Math.PI); c.stroke();
        FORMACIONES[nombre][variant].forEach(p=>{
            c.beginPath();
            c.arc(tw/2+p.x*(tw/(W-2*STAND_W))*0.9, th-(p.s/13)*(th-16)-4, 6, 0, Math.PI*2);
            c.fillStyle='#3a82c8'; c.fill();
            c.strokeStyle='#fff'; c.lineWidth=1.2; c.stroke();
        });
    }

    function buildOverlay() {
        overlay.querySelectorAll('.formacion-grid').forEach(grid => {
            grid.innerHTML='';
            NOMBRES.forEach(nombre => {
                const opt=document.createElement('div'); opt.className='formacion-opt';
                const cv=document.createElement('canvas'); drawThumb(cv,nombre,grid.dataset.variant);
                const lbl=document.createElement('div'); lbl.className='formacion-opt-name'; lbl.textContent=nombre;
                opt.appendChild(cv); opt.appendChild(lbl);
                opt.addEventListener('click',()=>elegirFormacion(nombre,grid.dataset.variant));
                grid.appendChild(opt);
            });
        });
    }

    function elegirFormacion(nombre, variant) {
        if (selStep===0) { formYo={nombre,variant}; selStep=1; stepTitle.textContent='FORMACIÓN DEL RIVAL'; }
        else { formRival={nombre,variant}; overlay.style.display='none'; armarEquipos(); }
    }

    buildOverlay();
    document.getElementById('practica-cambiar-form').addEventListener('click',()=>{ selStep=0; stepTitle.textContent='TU EQUIPO'; overlay.style.display='flex'; });
    document.getElementById('practica-reset').addEventListener('click',()=>{ if(formYo&&formRival) armarEquipos(); });

    // ── Input: copiado de Gemini ─────────────────────────────────────
    canvas.addEventListener('mousedown', pointerDown);
    canvas.addEventListener('mousemove', pointerMove);
    window .addEventListener('mouseup',  pointerUp);
    canvas.addEventListener('touchstart', pointerDown, { passive:false });
    canvas.addEventListener('touchmove',  pointerMove, { passive:false });
    window .addEventListener('touchend',  pointerUp);

    function pointerDown(e) {
        if (!formYo || !formRival || !mBall) return;
        const m = getMouse(e);
        let best=null, bestD=Infinity;
        pieces.forEach(p => {
            if (p.team !== 0) return;
            const d = Math.hypot(p.position.x - m.x, p.position.y - m.y);
            if (d < bestD) { bestD=d; best=p; }
        });
        if (!best || bestD > PIECE_R * 3) return;
        const bv = best.velocity, ballV = mBall.velocity;
        if (Math.hypot(bv.x,bv.y)>REST_V*3 || Math.hypot(ballV.x,ballV.y)>REST_V*3) return;
        aiming = best;
        dragStart = { x: best.position.x, y: best.position.y };
        dragCur   = m;
        e.preventDefault();
    }

    function pointerMove(e) {
        if (!aiming) return;
        dragCur = getMouse(e);
        e.preventDefault();
    }

    function pointerUp(e) {
        if (!aiming || !dragStart || !dragCur) { aiming=null; return; }
        // EXACTO de Gemini: dirección = posición_inicial - posición_mouse_actual
        const dx = dragStart.x - dragCur.x;
        const dy = dragStart.y - dragCur.y;
        let pot = Math.hypot(dx, dy) * POT_FACTOR;
        if (pot > POT_MAX) pot = POT_MAX;
        if (pot > 0.0001) {
            const mag = Math.hypot(dx, dy);
            Body.applyForce(aiming, aiming.position, { x:(dx/mag)*pot, y:(dy/mag)*pot });
            lastFlicked = aiming;
        }
        aiming=null; dragStart=null; dragCur=null;
        if (e && e.cancelable) e.preventDefault();
    }

    // ── Gol + pase ───────────────────────────────────────────────────
    function showGol(side) {
        if (scored) return; scored=true;
        if (side==='top') scoreYo++; else scoreRival++;
        scoreYoEl.textContent=scoreYo; scoreRivalEl.textContent=scoreRival;
        Body.setVelocity(mBall,{x:0,y:0});
        golMsg.textContent='¡GOL!'; golMsg.style.fontSize='';
        golMsg.classList.add('show');
        setTimeout(()=>{ golMsg.classList.remove('show'); armarEquipos(); },1100);
    }

    function tickLogic() {
        if (!mBall || !formYo || !formRival) return;
        const bp = mBall.position;
        const inX = bp.x > CX-GOAL_W/2 && bp.x < CX+GOAL_W/2;
        if (!scored && inX && bp.y < bounds.top  - GOAL_DEPTH*0.4) showGol('top');
        if (!scored && inX && bp.y > bounds.bottom+ GOAL_DEPTH*0.4) showGol('bottom');

        if (pendingReceiver) {
            const allStop = Math.hypot(mBall.velocity.x,mBall.velocity.y)<REST_V*1.5 &&
                            pieces.every(p=>Math.hypot(p.velocity.x,p.velocity.y)<REST_V*1.5);
            if (allStop) {
                const bx=mBall.position.x, by=mBall.position.y;
                let dx=bx-CX, dy=by-bounds.top, d=Math.hypot(dx,dy)||1;
                const off=PIECE_R+BALL_R+3;
                let px=Math.max(bounds.left+PIECE_R,Math.min(bounds.right-PIECE_R, bx+(dx/d)*off));
                let py=Math.max(bounds.top +PIECE_R,Math.min(bounds.bottom-PIECE_R, by+(dy/d)*off));
                Body.setPosition(pendingReceiver,{x:px,y:py});
                Body.setVelocity(pendingReceiver,{x:0,y:0});
                Body.setVelocity(mBall,{x:0,y:0});
                lastFlicked=null;
                pendingReceiver=null;
            }
        }
    }

    // ── Dibujo ───────────────────────────────────────────────────────
    function drawStands() {
        const colors=['#3a6ea5','#c94f2e','#f0c040','#4caf82'];
        [{x0:0},{x0:W-STAND_W}].forEach(band=>{
            ctx.fillStyle='#141414'; ctx.fillRect(band.x0,0,STAND_W,H);
            let ci=0;
            for(let y=4;y<H;y+=9) for(let x=band.x0+3;x<band.x0+STAND_W-3;x+=8){
                ctx.fillStyle=colors[ci%4]; ctx.globalAlpha=0.55; ctx.fillRect(x,y,5,5); ci++;
            }
            ctx.globalAlpha=1;
        });
    }

    function drawPitch() {
        const STRIPES=13, pH=bounds.bottom-bounds.top, pW=bounds.right-bounds.left, sH=pH/STRIPES;
        for(let i=0;i<STRIPES;i++){
            ctx.fillStyle=i%2===0?'#3a8c3f':'#347a38';
            ctx.fillRect(bounds.left,bounds.top+i*sH,pW,sH+1);
        }
        ctx.strokeStyle='rgba(255,255,255,0.9)'; ctx.lineWidth=2.5;
        ctx.strokeRect(bounds.left,bounds.top,pW,pH);
        const midY=bounds.top+6*sH;
        ctx.beginPath(); ctx.moveTo(bounds.left,midY); ctx.lineTo(bounds.right,midY); ctx.stroke();
        ctx.beginPath(); ctx.arc(CX,bounds.top+6.5*sH,42,0,Math.PI*2); ctx.stroke();
        ctx.beginPath(); ctx.arc(CX,bounds.top+6.5*sH,3,0,Math.PI*2); ctx.fillStyle='rgba(255,255,255,0.9)'; ctx.fill();

        [goalTop,goalBottom].forEach((g,idx)=>{
            const isTop=idx===0, yOuter=isTop?g.y-g.depth:g.y+g.depth;
            ctx.fillStyle='rgba(255,255,255,0.07)';
            ctx.fillRect(g.xMin,Math.min(g.y,yOuter),GOAL_W,g.depth);
            ctx.strokeStyle='#dce0e5'; ctx.lineWidth=3.5;
            ctx.beginPath(); ctx.moveTo(g.xMin,g.y); ctx.lineTo(g.xMin,yOuter); ctx.lineTo(g.xMax,yOuter); ctx.lineTo(g.xMax,g.y); ctx.stroke();
            ctx.strokeStyle='rgba(255,255,255,0.9)'; ctx.lineWidth=2.5;
            ctx.beginPath(); ctx.moveTo(bounds.left,g.y); ctx.lineTo(bounds.right,g.y); ctx.stroke();
            const aW=GOAL_W+52, aH=sH*1.1;
            ctx.strokeStyle='rgba(255,255,255,0.75)'; ctx.lineWidth=2;
            ctx.strokeRect(CX-aW/2, isTop?g.y:g.y-aH, aW, aH);
        });
        ctx.fillStyle='#e05555';
        [[bounds.left,bounds.top],[bounds.right,bounds.top],[bounds.left,bounds.bottom],[bounds.right,bounds.bottom]].forEach(c=>{
            ctx.beginPath(); ctx.moveTo(c[0],c[1]-10); ctx.lineTo(c[0]+6,c[1]-6); ctx.lineTo(c[0],c[1]-2); ctx.fill();
        });
    }

    function drawPiece(p) {
        const img=p.team===0?flagYo:flagRival, px=p.position.x, py=p.position.y;
        ctx.beginPath(); ctx.arc(px,py+2,PIECE_R+2,0,Math.PI*2);
        ctx.fillStyle='rgba(0,0,0,0.35)'; ctx.fill();
        if (aiming===p) {
            ctx.beginPath(); ctx.arc(px,py,PIECE_R+6,0,Math.PI*2);
            ctx.strokeStyle='rgba(240,192,64,0.85)'; ctx.lineWidth=3; ctx.stroke();
        }
        if (img.complete&&img.naturalWidth>0) {
            ctx.save(); ctx.beginPath(); ctx.arc(px,py,PIECE_R-1.5,0,Math.PI*2); ctx.clip();
            const sc=(PIECE_R*2)/48*1.15;
            ctx.drawImage(img,px-32*sc,py-24*sc,64*sc,48*sc); ctx.restore();
        } else {
            ctx.beginPath(); ctx.arc(px,py,PIECE_R-1.5,0,Math.PI*2);
            ctx.fillStyle=p.team===0?'#74acdf':'#333'; ctx.fill();
        }
        ctx.beginPath(); ctx.arc(px,py,PIECE_R,0,Math.PI*2);
        ctx.strokeStyle='#f2f2f2'; ctx.lineWidth=3; ctx.stroke();
        ctx.beginPath(); ctx.arc(px,py,PIECE_R+1.4,0,Math.PI*2);
        ctx.strokeStyle='rgba(0,0,0,0.4)'; ctx.lineWidth=1; ctx.stroke();
    }

    function drawBall() {
        if (!mBall) return;
        const bx=mBall.position.x, by=mBall.position.y;
        ctx.beginPath(); ctx.arc(bx,by+2,BALL_R+2,0,Math.PI*2); ctx.fillStyle='rgba(0,0,0,0.3)'; ctx.fill();
        ctx.beginPath(); ctx.arc(bx,by,BALL_R,0,Math.PI*2); ctx.fillStyle='#f5f5f0'; ctx.fill();
        ctx.lineWidth=1; ctx.strokeStyle='#222'; ctx.stroke();
        ctx.beginPath(); ctx.arc(bx,by,BALL_R*0.4,0,Math.PI*2); ctx.fillStyle='#222'; ctx.fill();
    }

    // ── Simulación de trayectoria ────────────────────────────────────
    // velEst: velocidad en px/frame que resulta de la potencia Matter
    // Matter: applyForce(F) → dv = F/mass por step (step ≈ 16.67ms)
    // En nuestro espacio lógico W=390, el runner corre a 60fps con delta 16.67ms
    // Empíricamente: vel_logica ≈ pot * 3200 (calibrado contra movimiento real)
    // ── Predicción de trayectoria con MUNDO FANTASMA (Matter real) ────
    // Se clona el estado actual en un motor Matter invisible, se aplica el
    // mismo disparo y se corre acelerado. Como usa el mismo motor que el juego,
    // la trayectoria predicha es IDÉNTICA a lo que va a pasar realmente.
    function predecirTrayectoria(aimingPiece, forceVec) {
        // Motor fantasma independiente (mismas iteraciones que el real para coincidir)
        const ghostEngine = Engine.create({
            gravity: { x:0, y:0 },
            positionIterations: 12,
            velocityIterations: 10,
            constraintIterations: 4
        });
        const ghostWorld  = ghostEngine.world;

        // Clonar paredes
        Composite.add(ghostWorld, makeWalls());

        // Clonar fichas (mismas posiciones, masa y props físicas)
        let ghostAiming = null, ghostBall = null;
        pieces.forEach(p => {
            const g = Bodies.circle(p.position.x, p.position.y, PIECE_R, PIECE_OPT);
            Body.setMass(g, MASA_PIEZA);
            g.team = p.team;
            Composite.add(ghostWorld, g);
            if (p === aimingPiece) ghostAiming = g;
        });
        // Clonar pelota
        ghostBall = Bodies.circle(mBall.position.x, mBall.position.y, BALL_R, BALL_OPT);
        Body.setMass(ghostBall, MASA_BOLA);
        Composite.add(ghostWorld, ghostBall);

        // Aplicar el mismo disparo
        Body.applyForce(ghostAiming, ghostAiming.position, forceVec);

        // Correr la simulación registrando posiciones
        const piecePts = [{ x: ghostAiming.position.x, y: ghostAiming.position.y }];
        const ballPts  = [{ x: ghostBall.position.x,  y: ghostBall.position.y  }];
        const STEP_MS = 1000 / 60;
        const MAX_STEPS = 260;
        let ballStartedMoving = false;

        for (let i = 0; i < MAX_STEPS; i++) {
            Engine.update(ghostEngine, STEP_MS);

            if (i % 3 === 0) piecePts.push({ x: ghostAiming.position.x, y: ghostAiming.position.y });

            const bv = Math.hypot(ghostBall.velocity.x, ghostBall.velocity.y);
            if (bv > 0.3) ballStartedMoving = true;
            if (ballStartedMoving && i % 3 === 0) {
                ballPts.push({ x: ghostBall.position.x, y: ghostBall.position.y });
            }

            // cortar si todo está casi quieto
            const pv = Math.hypot(ghostAiming.velocity.x, ghostAiming.velocity.y);
            if (i > 10 && pv < 0.4 && bv < 0.4) break;
        }
        piecePts.push({ x: ghostAiming.position.x, y: ghostAiming.position.y });
        if (ballStartedMoving) ballPts.push({ x: ghostBall.position.x, y: ghostBall.position.y });

        return { piecePts, ballPts: ballStartedMoving ? ballPts : [] };
    }

    function drawArrow() {
        if (!aiming || !dragStart || !dragCur || !mBall) return;
        const dx=dragStart.x-dragCur.x, dy=dragStart.y-dragCur.y;
        const dist=Math.hypot(dx,dy); if(dist<8) return;
        let pot=dist*POT_FACTOR; if(pot>POT_MAX) pot=POT_MAX;
        const pct=pot/POT_MAX;
        const ndx=dx/dist, ndy=dy/dist;

        // Vector de fuerza IDÉNTICO al que se aplica en pointerUp
        const forceVec = { x: ndx*pot, y: ndy*pot };
        const { piecePts, ballPts } = predecirTrayectoria(aiming, forceVec);

        // ── Trayectoria chapita (blanco punteado) ──
        if(piecePts.length>1){
            ctx.save(); ctx.setLineDash([5,6]);
            ctx.strokeStyle='rgba(255,255,255,0.35)'; ctx.lineWidth=1.8;
            ctx.beginPath(); piecePts.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y));
            ctx.stroke(); ctx.setLineDash([]); ctx.restore();
        }

        // ── Trayectoria pelota (amarillo) ──
        if(ballPts.length>1){
            ctx.save(); ctx.setLineDash([5,7]);
            ctx.strokeStyle='rgba(240,192,64,0.75)'; ctx.lineWidth=2;
            ctx.beginPath(); ballPts.forEach((p,i)=>i===0?ctx.moveTo(p.x,p.y):ctx.lineTo(p.x,p.y));
            ctx.stroke(); ctx.setLineDash([]);
            const fin=ballPts[ballPts.length-1];
            ctx.beginPath(); ctx.arc(fin.x,fin.y,BALL_R+3,0,Math.PI*2);
            ctx.strokeStyle='rgba(240,192,64,0.9)'; ctx.lineWidth=2.5; ctx.stroke();
            ctx.beginPath(); ctx.arc(fin.x,fin.y,2.5,0,Math.PI*2);
            ctx.fillStyle='rgba(240,192,64,0.9)'; ctx.fill(); ctx.restore();
        }

        // ── Flecha blanca ──
        const startOff=PIECE_R+4, len=startOff+18+pct*80;
        const hLen=16,hW=15,tW=3.5,nW=7, px2=-ndy, py2=ndx;
        const ox=dragStart.x, oy=dragStart.y;
        const sx2=ox+ndx*startOff, sy2=oy+ndy*startOff;
        const nx2=ox+ndx*(len-hLen), ny2=oy+ndy*(len-hLen);
        const tx2=ox+ndx*len, ty2=oy+ndy*len;
        ctx.save(); ctx.shadowColor='rgba(0,0,0,0.4)'; ctx.shadowBlur=4;
        ctx.fillStyle='rgba(255,255,255,0.95)';
        ctx.beginPath();
        ctx.moveTo(sx2+px2*tW,sy2+py2*tW); ctx.lineTo(nx2+px2*nW,ny2+py2*nW);
        ctx.lineTo(nx2+px2*hW,ny2+py2*hW); ctx.lineTo(tx2,ty2);
        ctx.lineTo(nx2-px2*hW,ny2-py2*hW); ctx.lineTo(nx2-px2*nW,ny2-py2*nW);
        ctx.lineTo(sx2-px2*tW,sy2-py2*tW); ctx.closePath(); ctx.fill(); ctx.restore();
    }

    // ── Loop principal ───────────────────────────────────────────────
    function frame() {
        tickLogic();
        ctx.clearRect(0,0,W,H);
        drawStands();
        drawPitch();
        pieces.forEach(drawPiece);
        drawBall();
        drawArrow();
        requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
})();
</script>
}
