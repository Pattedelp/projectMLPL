            </div>
        </div>

        <div>
            <h3 style="font-family:var(--font-heading);font-size:13px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:12px;">Resultados</h3>
            @if (!partidosNacional.Any())
            {
                <p style="color:var(--color-muted);font-size:13px;">No hay resultados registrados.</p>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:6px;">
                    @foreach (var p in partidosNacional)
                    {
                        bool localGanaN = p.GolesLocal > p.GolesVisitante;
                        <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:8px 12px;display:flex;align-items:center;gap:8px;font-size:12px;">
                            <div style="flex:1;text-align:right;display:flex;align-items:center;justify-content:flex-end;gap:4px;">
                                @if (!string.IsNullOrEmpty(p.FlagLocal) && banderas.ContainsKey(p.FlagLocal))
                                { <span>@banderas[p.FlagLocal]</span> }
                                <a href="/Equipos/Detalle/@p.EquipoLocalId" style="color:var(--color-text);text-decoration:none;font-weight:@(localGanaN?"700":"400");">@p.NombreLocal</a>
                            </div>
                            <div style="font-family:var(--font-heading);font-size:15px;font-weight:700;background:var(--color-bg3);border-radius:6px;padding:2px 10px;min-width:50px;text-align:center;">
                                @p.GolesLocal - @p.GolesVisitante
                            </div>
                            <div style="flex:1;display:flex;align-items:center;gap:4px;">
                                <a href="/Equipos/Detalle/@p.EquipoVisitanteId" style="color:var(--color-text);text-decoration:none;font-weight:@(!localGanaN?"700":"400");">@p.NombreVisitante</a>
                                @if (!string.IsNullOrEmpty(p.FlagVisitante) && banderas.ContainsKey(p.FlagVisitante))
                                { <span>@banderas[p.FlagVisitante]</span> }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
.tab-btn { padding:8px 16px;border-radius:8px;background:var(--color-bg2);border:1px solid var(--color-border);color:var(--color-muted);font-size:13px;font-weight:500;cursor:pointer; }
.tab-btn.active { background:var(--color-gold);color:var(--color-bg);border-color:var(--color-gold); }
@@media (max-width:700px) {
    .det-grid { grid-template-columns: 1fr !important; }
}
</style>

@section Scripts {
<script>
function showTab(tab) {
    document.getElementById('tab-primera-content').style.display  = tab === 'primera'  ? 'block' : 'none';
    document.getElementById('tab-nacional-content').style.display = tab === 'nacional' ? 'block' : 'none';
    document.getElementById('tab-primera').classList.toggle('active',  tab === 'primera');
    document.getElementById('tab-nacional').classList.toggle('active', tab === 'nacional');
}
</script>
}
