                    <div style="font-family:var(--font-heading);font-size:28px;font-weight:700;color:var(--color-gold);">T@(t.Numero)</div>
                    <div style="font-size:14px;font-weight:500;color:var(--color-text);margin:4px 0;">@t.Nombre</div>
