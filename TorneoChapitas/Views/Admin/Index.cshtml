<!-- ENCUESTAS -->
<div class="admin-section">
    <h2 class="admin-section-title">🗳️ Encuestas</h2>
    @{
        var todasEncuestas = ViewBag.TodasEncuestas as List<Encuesta> ?? new();
    }

    <!-- Crear encuesta -->
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:16px 24px;margin-bottom:12px;">
        <div style="font-size:13px;font-weight:500;margin-bottom:12px;">Nueva encuesta</div>
        <input type="text" id="enc-pregunta" placeholder="¿Pregunta para los participantes?" class="form-control" style="margin-bottom:10px;font-size:13px;" />

        <div style="font-size:11px;color:var(--color-muted);margin-bottom:6px;">Opciones:</div>
        <div id="enc-opciones-list" style="display:flex;flex-direction:column;gap:6px;margin-bottom:10px;">
            <input type="text" class="enc-opcion form-control" placeholder="Opción 1" style="font-size:13px;" />
            <input type="text" class="enc-opcion form-control" placeholder="Opción 2" style="font-size:13px;" />
        </div>

        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
            <button onclick="agregarOpcion()" class="btn-outline" style="font-size:12px;">+ Opción</button>
            <label style="font-size:12px;color:var(--color-muted);display:flex;align-items:center;gap:6px;">
                Máx votos por usuario:
                <input type="number" id="enc-maxvotos" value="1" min="1" max="10" class="form-control" style="width:50px;font-size:12px;" />
            </label>
            <button onclick="crearEncuestaManual()" class="btn-primary" style="font-size:12px;padding:8px 16px;">Crear encuesta</button>
        </div>
        <p id="msg-enc-crear" style="font-size:11px;margin-top:6px;display:none;"></p>
    </div>

    <!-- Lista de encuestas -->
    @if (todasEncuestas.Any())
    {
        <div style="display:flex;flex-direction:column;gap:8px;">
            @foreach (var enc in todasEncuestas)
            {
                <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                    <span style="@(enc.Activa ? "color:var(--color-green)" : "color:var(--color-muted)");font-size:12px;">●</span>
                    <span style="font-size:13px;flex:1;">@enc.Pregunta</span>
                    <span style="font-size:11px;color:var(--color-muted);">@enc.TotalVotos votos</span>
                    <button onclick="toggleEncuesta(@enc.Id, @(!enc.Activa).ToString().ToLower())"
                            class="btn-outline" style="font-size:11px;padding:4px 10px;">
                        @(enc.Activa ? "Desactivar" : "Activar")
                    </button>
                    <button onclick="eliminarEncuesta(@enc.Id)"
                            style="background:transparent;border:1px solid var(--color-red);color:var(--color-red);border-radius:6px;padding:4px 10px;font-size:11px;cursor:pointer;">
                        Eliminar
                    </button>
                </div>
            }
        </div>
    }
    else
    {
        <p style="font-size:13px;color:var(--color-muted);">No hay encuestas creadas todavía.</p>
    }
</div>

