@model Noticia
@{
    ViewBag.Title = Model.Titulo;
    ViewBag.ActivePage = "noticias";
}

<div style="max-width:760px;margin:0 auto;">
    <a asp-action="Index" style="display:inline-flex;align-items:center;gap:6px;color:var(--color-muted);font-size:13px;margin:24px 0 20px;display:block;">
        ← Volver a noticias
    </a>

    <span class="noticia-badge @(Model.Tipo == "automatica" ? "badge-auto" : "badge-manual")" style="margin-bottom:16px;display:inline-block;">
        @(Model.Tipo == "automatica" ? "⚡ Generada automáticamente" : "✍️ Redacción")
    </span>

    <h1 style="font-family:var(--font-heading);font-size:28px;font-weight:700;color:var(--color-text);letter-spacing:1px;margin-bottom:12px;line-height:1.3;">
        @Model.Titulo
    </h1>

    <div style="font-size:13px;color:var(--color-muted);margin-bottom:24px;">
        📅 @Model.CreatedAt.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-AR"))
        · ✍️ @Model.Autor
    </div>

    @if (!string.IsNullOrEmpty(Model.ImagenUrl))
    {
        <div style="margin-bottom:28px;border-radius:12px;overflow:hidden;max-height:420px;">
            <img src="@Model.ImagenUrl" alt="@Model.Titulo"
                 style="width:100%;height:420px;object-fit:cover;"
                 onerror="this.parentElement.style.display='none'" />
        </div>
    }

    <div style="font-size:16px;line-height:1.9;color:var(--color-text);white-space:pre-line;">
        @Model.Contenido
    </div>
</div>
