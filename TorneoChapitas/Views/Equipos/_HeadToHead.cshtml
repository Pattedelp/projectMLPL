@model HeadToHeadViewModel

<div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px;margin-top:16px;">
    <h3 style="font-family:var(--font-heading);font-size:14px;letter-spacing:2px;color:var(--color-gold);margin-bottom:16px;text-transform:uppercase;">
        ⚔️ Mano a Mano
    </h3>

    <!-- Encabezado con nombres y banderas -->
    <div style="display:flex;align-items:center;justify-content:center;gap:20px;margin-bottom:20px;">
        <div style="text-align:center;">
            @if (Model.EquipoA.FlagCode == "retired")
            {
                <div style="font-size:28px;color:var(--color-muted);">✝</div>
            }
            else if (!string.IsNullOrEmpty(Model.EquipoA.FlagCode))
            {
                <img src="https://flagcdn.com/40x30/@(Model.EquipoA.FlagCode).png" style="border-radius:4px;" alt="" onerror="this.style.display='none'" />
            }
            <div style="font-weight:600;margin-top:4px;">@Model.EquipoA.Nombre</div>
        </div>
        <div style="font-family:var(--font-heading);font-size:24px;color:var(--color-muted);">VS</div>
        <div style="text-align:center;">
            @if (Model.EquipoB.FlagCode == "retired")
            {
                <div style="font-size:28px;color:var(--color-muted);">✝</div>
            }
            else if (!string.IsNullOrEmpty(Model.EquipoB.FlagCode))
            {
                <img src="https://flagcdn.com/40x30/@(Model.EquipoB.FlagCode).png" style="border-radius:4px;" alt="" onerror="this.style.display='none'" />
            }
            <div style="font-weight:600;margin-top:4px;">@Model.EquipoB.Nombre</div>
        </div>
    </div>

    @if (!Model.Enfrentamientos.Any())
    {
        <p style="text-align:center;font-size:13px;color:var(--color-muted);margin-bottom:20px;">
            Sin enfrentamientos directos registrados todavía.
        </p>
    }
    else
    {
        <!-- Resumen de victorias -->
        <div style="display:flex;justify-content:center;gap:40px;margin-bottom:20px;text-align:center;">
            <div>
                <div style="font-family:var(--font-heading);font-size:28px;color:var(--color-green);">@Model.VictoriasA</div>
                <div style="font-size:11px;color:var(--color-muted);">Victorias @Model.EquipoA.Nombre</div>
            </div>
            <div>
                <div style="font-family:var(--font-heading);font-size:28px;color:var(--color-red);">@Model.VictoriasB</div>
                <div style="font-size:11px;color:var(--color-muted);">Victorias @Model.EquipoB.Nombre</div>
            </div>
        </div>

        <!-- Últimos enfrentamientos -->
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:20px;">
            @foreach (var e in Model.Enfrentamientos.Take(5))
            {
                <div style="background:var(--color-bg3);border-radius:6px;padding:8px 14px;display:flex;align-items:center;justify-content:center;gap:12px;font-size:14px;">
                    <span style="@(e.GolesA > e.GolesB ? "color:var(--color-green);font-weight:700;" : "")">@e.GolesA</span>
                    <span style="color:var(--color-muted);">-</span>
                    <span style="@(e.GolesB > e.GolesA ? "color:var(--color-green);font-weight:700;" : "")">@e.GolesB</span>
                    <span style="font-size:11px;color:var(--color-muted);margin-left:8px;">
                        (@(e.ALocal ? Model.EquipoA.Nombre + " local" : Model.EquipoB.Nombre + " local"))
                    </span>
                </div>
            }
        </div>
    }

    <!-- Comparación de stats generales -->
    @if (Model.StatsA != null && Model.StatsB != null)
    {
        <h4 style="font-size:12px;letter-spacing:1px;color:var(--color-muted);text-transform:uppercase;margin-bottom:10px;text-align:center;">
            Comparación esta temporada
        </h4>
        <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:8px;align-items:center;font-size:13px;">
            <div style="text-align:right;color:var(--color-text);">@Model.StatsA.Puntos pts</div>
            <div style="text-align:center;font-size:11px;color:var(--color-muted);">PUNTOS</div>
            <div style="text-align:left;color:var(--color-text);">@Model.StatsB.Puntos pts</div>

            <div style="text-align:right;">@Model.StatsA.PartidosJugados</div>
            <div style="text-align:center;font-size:11px;color:var(--color-muted);">PJ</div>
            <div style="text-align:left;">@Model.StatsB.PartidosJugados</div>

            <div style="text-align:right;">@Model.StatsA.GolesAFavor</div>
            <div style="text-align:center;font-size:11px;color:var(--color-muted);">GOLES A FAVOR</div>
            <div style="text-align:left;">@Model.StatsB.GolesAFavor</div>

            <div style="text-align:right;">@Model.StatsA.GolesEnContra</div>
            <div style="text-align:center;font-size:11px;color:var(--color-muted);">GOLES EN CONTRA</div>
            <div style="text-align:left;">@Model.StatsB.GolesEnContra</div>
        </div>
    }
    else
    {
        <p style="text-align:center;font-size:12px;color:var(--color-muted);">
            Stats no disponibles (alguno de los equipos no tiene partidos en el fixture actual).
        </p>
    }

    <!-- PALMARÉS DE AMBOS -->
    <div style="margin-top:24px;display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div>
            <h4 style="font-size:12px;letter-spacing:1px;color:var(--color-muted);text-transform:uppercase;margin-bottom:10px;text-align:center;">
                🏆 @Model.EquipoA.Nombre (@Model.TitulosA.Count)
            </h4>
            @if (!Model.TitulosA.Any())
            {
                <p style="text-align:center;font-size:12px;color:var(--color-muted);">Sin títulos</p>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:6px;max-height:220px;overflow-y:auto;">
                    @foreach (var t in Model.TitulosA.OrderBy(x => x.TemporadaNombre))
                    {
                        var icono = t.TipoTitulo switch {
                            "campeon_torneo"     => "🏆",
                            "campeon_copa"       => "🥇",
                            "campeon_supercopa"  => "⭐",
                            "campeon_primera_b"  => "🥈",
                            "campeon_primera_c"  => "🎖",
                            "campeon_especial"   => "🎪",
                            _                    => "🏅"
                        };
                        <div style="background:var(--color-bg3);border-radius:6px;padding:6px 12px;font-size:12px;">
                            <span>@icono</span> @t.NombreTitulo
                            <div style="font-size:10px;color:var(--color-muted);">@t.TemporadaNombre</div>
                        </div>
                    }
                </div>
            }
        </div>
        <div>
            <h4 style="font-size:12px;letter-spacing:1px;color:var(--color-muted);text-transform:uppercase;margin-bottom:10px;text-align:center;">
                🏆 @Model.EquipoB.Nombre (@Model.TitulosB.Count)
            </h4>
            @if (!Model.TitulosB.Any())
            {
                <p style="text-align:center;font-size:12px;color:var(--color-muted);">Sin títulos</p>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:6px;max-height:220px;overflow-y:auto;">
                    @foreach (var t in Model.TitulosB.OrderBy(x => x.TemporadaNombre))
                    {
                        var icono = t.TipoTitulo switch {
                            "campeon_torneo"     => "🏆",
                            "campeon_copa"       => "🥇",
                            "campeon_supercopa"  => "⭐",
                            "campeon_primera_b"  => "🥈",
                            "campeon_primera_c"  => "🎖",
                            "campeon_especial"   => "🎪",
                            _                    => "🏅"
                        };
                        <div style="background:var(--color-bg3);border-radius:6px;padding:6px 12px;font-size:12px;">
                            <span>@icono</span> @t.NombreTitulo
                            <div style="font-size:10px;color:var(--color-muted);">@t.TemporadaNombre</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
