@model PrediccionesViewModel
@{
    ViewBag.Title = "Predicciones";
    var banderas = new Dictionary<string,string> {
        {"nl","🇳🇱"},{"dk","🇩🇰"},{"cr","🇨🇷"},{"it","🇮🇹"},{"us","🇺🇲"},
        {"ir","🇮🇷"},{"gb-wls","🏴"},{"be","🇧🇪"},{"ua","🇺🇦"},{"de","🇩🇪"},
        {"kr","🇰🇷"},{"ec","🇪🇨"},{"br","🇧🇷"},{"es","🇪🇸"},{"vn","🇻🇳"},
        {"co","🇨🇴"},{"ar","🇦🇷"},{"uy","🇺🇾"},{"ph","🇵🇭"},
        {"pl","🇵🇱"},{"se","🇸🇪"},{"sa","🇸🇦"},{"ma","🇲🇦"},{"jp","🇯🇵"},{"gb-eng","🏴"}
    };
    // Nombres en texto para el <option> (los emoji de bandera no renderizan bien en <select> de Windows)
    var nombresPaises = new Dictionary<string,string> {
        {"nl","Países Bajos"},{"dk","Dinamarca"},{"cr","Costa Rica"},{"it","Italia"},{"us","EE.UU."},
        {"ir","Irán"},{"gb-wls","Gales"},{"be","Bélgica"},{"ua","Ucrania"},{"de","Alemania"},
        {"kr","Corea del Sur"},{"ec","Ecuador"},{"br","Brasil"},{"es","España"},{"vn","Vietnam"},
        {"co","Colombia"},{"ar","Argentina"},{"uy","Uruguay"},{"ph","Filipinas"},
        {"pl","Polonia"},{"se","Suecia"},{"sa","Arabia Saudita"},{"ma","Marruecos"},{"jp","Japón"},{"gb-eng","Inglaterra"}
    };
}

<div class="page-hero">
    <div class="page-hero-icon">🔮</div>
    <div class="page-hero-text">
        <h1>Predicciones</h1>
        <p>Adiviná los resultados y subí en el ranking de pronosticadores</p>
    </div>
</div>

<!-- TABS DIVISIÓN -->
<div style="display:flex;gap:8px;margin-bottom:24px;flex-wrap:wrap;">
    <a href="/Predicciones?division=1" class="tab-btn @(Model.DivisionId==1?"active":"")">🏆 Primera División</a>
    <a href="/Predicciones?division=2" class="tab-btn @(Model.DivisionId==2?"active":"")">🥈 Primera Nacional</a>
    <a href="/Predicciones?division=100" class="tab-btn @(Model.DivisionId==100?"active":"")">🏆 Copa Argentina</a>
    <a href="/Predicciones?division=101" class="tab-btn @(Model.DivisionId==101?"active":"")">⭐ Supercopa</a>
</div>

<!-- IDENTIDAD DEL PRONOSTICADOR -->
<div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:10px;padding:12px 16px;margin-bottom:20px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
    <span style="font-size:13px;color:var(--color-muted);">Tu identidad:</span>
    <input type="text" id="pred-autor" placeholder="Tu nombre" maxlength="50"
           class="form-control" style="width:140px;font-size:13px;" oninput="guardarIdentidad()" />
    <select id="pred-flag" class="form-control" style="width:150px;font-size:13px;" onchange="guardarIdentidad()">
        <option value="">Sin bandera</option>
        @foreach (var b in nombresPaises)
        {
            <option value="@b.Key">@b.Value</option>
        }
    </select>
    <span style="font-size:11px;color:var(--color-green);" id="pred-saved-msg">✓ guardado</span>
</div>

<!-- PRÓXIMOS PARTIDOS -->
<h2 style="font-family:var(--font-heading);font-size:14px;letter-spacing:2px;color:var(--color-gold);margin-bottom:16px;text-transform:uppercase;">
    📅 Próximos Partidos
</h2>

@if (!Model.ProximosPartidos.Any())
{
    var msg = Model.DivisionId >= 100
        ? "No hay cruces definidos todavía para predecir, o la copa ya finalizó."
        : "No hay partidos pendientes en el fixture.";
    <p style="font-size:13px;color:var(--color-muted);margin-bottom:32px;">@msg</p>
}
else
{
    <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:40px;">
        @foreach (var pc in Model.ProximosPartidos)
        {
            var p = pc.Partido;
            var totalPreds = pc.Predicciones.Count;
            var pctL = totalPreds > 0 ? (int)(100.0 * pc.Predicciones.Count(x => x.Prediccion1X2=="L") / totalPreds) : 0;
            var pctV = totalPreds > 0 ? (100 - pctL) : 0;

            <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:18px 20px;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:14px;flex-wrap:wrap;">
                    <div style="display:flex;align-items:center;gap:10px;font-size:15px;font-weight:600;">
                        @if (!string.IsNullOrEmpty(p.EquipoLocal?.FlagCode))
                        {
                            <img src="https://flagcdn.com/20x15/@(p.EquipoLocal.FlagCode).png" class="flag-img" alt="" onerror="this.style.display='none'" />
                        }
                        <span>@p.EquipoLocal?.Nombre</span>
                        <span style="color:var(--color-muted);font-weight:400;">vs</span>
                        <span>@p.EquipoVisitante?.Nombre</span>
                        @if (!string.IsNullOrEmpty(p.EquipoVisitante?.FlagCode))
                        {
                            <img src="https://flagcdn.com/20x15/@(p.EquipoVisitante.FlagCode).png" class="flag-img" alt="" onerror="this.style.display='none'" />
                        }
                    </div>
                    <span style="font-size:11px;color:var(--color-muted);">@totalPreds predicciones</span>
                </div>

                @if (totalPreds > 0)
                {
                    <!-- Barra de tendencia -->
                    <div style="display:flex;height:8px;border-radius:4px;overflow:hidden;margin-bottom:12px;">
                        <div style="width:@(pctL)%;background:#3a82c8;" title="Local @pctL%"></div>

                        <div style="width:@(pctV)%;background:#e05555;" title="Visitante @pctV%"></div>
                    </div>
                    <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--color-muted);margin-bottom:14px;">
                        <span>🔵 Local @pctL%</span>
                        <span>🔴 Visitante @pctV%</span>
                    </div>
                }

                <!-- FORMULARIO DE PREDICCIÓN -->
                <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
                    <select id="pred-@p.Id-1x2" class="form-control" style="width:130px;font-size:13px;">
                        <option value="">¿Quién gana?</option>
                        <option value="L">🏠 Gana @pc.Partido.EquipoLocal.Nombre</option>
                        <option value="V">✈️ Gana @pc.Partido.EquipoVisitante.Nombre</option>
                    </select>
                    <input type="number" id="pred-@p.Id-gl" min="0" max="20" placeholder="GL"
                           class="form-control" style="width:55px;font-size:13px;text-align:center;" />
                    <span style="color:var(--color-muted);">-</span>
                    <input type="number" id="pred-@p.Id-gv" min="0" max="20" placeholder="GV"
                           class="form-control" style="width:55px;font-size:13px;text-align:center;" />
                    <button onclick="predecir(@p.Id, @Model.DivisionId)" class="btn-primary" style="font-size:12px;padding:8px 14px;">
                        🔮 Predecir
                    </button>
                    <span id="pred-@p.Id-msg" style="font-size:12px;display:none;"></span>
                </div>
                <p style="font-size:11px;color:var(--color-muted);margin-top:6px;">
                    💡 1X2 correcto = 1 pto · Resultado exacto = 3 ptos
                </p>
            </div>
        }
    </div>
}

<!-- RANKING -->
<h2 style="font-family:var(--font-heading);font-size:14px;letter-spacing:2px;color:var(--color-gold);margin-bottom:16px;text-transform:uppercase;">
<!-- MIS PREDICCIONES -->
<h2 style="font-family:var(--font-heading);font-size:14px;letter-spacing:2px;color:var(--color-gold);margin-bottom:12px;text-transform:uppercase;">
    🔍 Mis Predicciones
</h2>
<div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:10px;padding:14px 16px;margin-bottom:28px;">
    <div style="display:flex;gap:8px;align-items:center;margin-bottom:12px;">
        <input type="text" id="mis-pred-autor" placeholder="Tu nombre" maxlength="50"
               class="form-control" style="width:160px;font-size:13px;" />
        <button onclick="cargarMisPredicciones()" class="btn-primary" style="font-size:12px;padding:8px 14px;">
            Ver mis predicciones
        </button>
    </div>
    <div id="mis-pred-resultado"></div>
</div>

    🏅 Ranking de Pronosticadores
</h2>

@{
    var rankingTemp = ViewBag.RankingTemporada as List<RankingPronosticador> ?? new();
    var tempNombre  = ViewBag.TemporadaNombre as string ?? "";
}

<!-- Tabs ranking -->
<div style="display:flex;gap:8px;margin-bottom:16px;">
    <button onclick="showRanking('temp')" id="tab-rank-temp" class="tab-btn active" style="font-size:12px;padding:6px 14px;">
        📅 @tempNombre
    </button>
    <button onclick="showRanking('all')" id="tab-rank-all" class="tab-btn" style="font-size:12px;padding:6px 14px;">
        🌍 Histórico
    </button>
</div>

<!-- Ranking temporada actual -->
<div id="rank-temp">
@if (!rankingTemp.Any())
{
    <p style="font-size:13px;color:var(--color-muted);">Aún no hay predicciones con resultados confirmados esta temporada.</p>
}
else
{
    <div class="tabla-wrapper">
        <table class="tabla-posiciones">
            <thead><tr><th>#</th><th>Pronosticador</th><th>Puntos</th><th>1X2 ✓</th><th>Exactos ✓</th></tr></thead>
            <tbody>
                @{ int posT = 1; }
                @foreach (var r in rankingTemp)
                {
                    <tr>
                        <td class="col-pos">@posT</td>
                        <td class="col-equipo"><strong>@r.Autor</strong></td>
                        <td class="col-pts"><strong style="color:var(--color-gold);">@r.TotalPuntos</strong></td>
                        <td class="col-num">@r.Aciertos1X2</td>
                        <td class="col-num">@r.AciertosExactos</td>
                    </tr>
                    posT++;
                }
            </tbody>
        </table>
    </div>
}
</div>

<div id="rank-primera">
@if (!rankingPrimera.Any())
{
    <p style="font-size:13px;color:var(--color-muted);">Sin predicciones confirmadas.</p>
}
else
{
    <div class="tabla-wrapper">
        <table class="tabla-posiciones">
            <thead><tr><th>#</th><th>Pronosticador</th><th>PTS</th><th>1X2 ✓</th><th>Exactos ✓</th></tr></thead>
            <tbody>
                @{ int pos_rank-primera = 1; }
                @foreach (var rk_rank-primera in rankingPrimera)
                {
                    <tr>
                        <td class="col-pos">@(pos_rank-primera)</td>
                        <td class="col-equipo">
                            @if (!string.IsNullOrEmpty(rk_rank-primera.PaisFlag) && banderas.ContainsKey(rk_rank-primera.PaisFlag))
                            {
                                <span style="margin-right:4px;">@banderas[rk_rank-primera.PaisFlag]</span>
                            }
                            <strong>@rk_rank-primera.Autor</strong>
                        </td>
                        <td class="col-pts"><strong style="color:var(--color-gold);">@rk_rank-primera.TotalPuntos</strong></td>
                        <td class="col-num">@rk_rank-primera.Aciertos1X2</td>
                        <td class="col-num">@rk_rank-primera.AciertosExactos</td>
                    </tr>
                    @{ pos_rank-primera++; }
                }
            </tbody>
        </table>
    </div>
}
</div>
<div id="rank-nacional" style="display:none;">
@if (!rankingNacional.Any())
{
    <p style="font-size:13px;color:var(--color-muted);">Sin predicciones confirmadas.</p>
}
else
{
    <div class="tabla-wrapper">
        <table class="tabla-posiciones">
            <thead><tr><th>#</th><th>Pronosticador</th><th>PTS</th><th>1X2 ✓</th><th>Exactos ✓</th></tr></thead>
            <tbody>
                @{ int pos_rank-nacional = 1; }
                @foreach (var rk_rank-nacional in rankingNacional)
                {
                    <tr>
                        <td class="col-pos">@(pos_rank-nacional)</td>
                        <td class="col-equipo">
                            @if (!string.IsNullOrEmpty(rk_rank-nacional.PaisFlag) && banderas.ContainsKey(rk_rank-nacional.PaisFlag))
                            {
                                <span style="margin-right:4px;">@banderas[rk_rank-nacional.PaisFlag]</span>
                            }
                            <strong>@rk_rank-nacional.Autor</strong>
                        </td>
                        <td class="col-pts"><strong style="color:var(--color-gold);">@rk_rank-nacional.TotalPuntos</strong></td>
                        <td class="col-num">@rk_rank-nacional.Aciertos1X2</td>
                        <td class="col-num">@rk_rank-nacional.AciertosExactos</td>
                    </tr>
                    @{ pos_rank-nacional++; }
                }
            </tbody>
        </table>
    </div>
}
</div>
<div id="rank-copa" style="display:none;">
@if (!rankingCopa.Any())
{
    <p style="font-size:13px;color:var(--color-muted);">Sin predicciones confirmadas.</p>
}
else
{
    <div class="tabla-wrapper">
        <table class="tabla-posiciones">
            <thead><tr><th>#</th><th>Pronosticador</th><th>PTS</th><th>1X2 ✓</th><th>Exactos ✓</th></tr></thead>
            <tbody>
                @{ int pos_rank-copa = 1; }
                @foreach (var rk_rank-copa in rankingCopa)
                {
                    <tr>
                        <td class="col-pos">@(pos_rank-copa)</td>
                        <td class="col-equipo">
                            @if (!string.IsNullOrEmpty(rk_rank-copa.PaisFlag) && banderas.ContainsKey(rk_rank-copa.PaisFlag))
                            {
                                <span style="margin-right:4px;">@banderas[rk_rank-copa.PaisFlag]</span>
                            }
                            <strong>@rk_rank-copa.Autor</strong>
                        </td>
                        <td class="col-pts"><strong style="color:var(--color-gold);">@rk_rank-copa.TotalPuntos</strong></td>
                        <td class="col-num">@rk_rank-copa.Aciertos1X2</td>
                        <td class="col-num">@rk_rank-copa.AciertosExactos</td>
                    </tr>
                    @{ pos_rank-copa++; }
                }
            </tbody>
        </table>
    </div>
}
</div>
</div>
<div id="rank-all" style="display:none;">
@if (!Model.Ranking.Any())
{
    <p style="font-size:13px;color:var(--color-muted);">Aún no hay predicciones con resultados confirmados.</p>
}
else
{
    <div class="tabla-wrapper">
        <table class="tabla-posiciones">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Pronosticador</th>
                    <th>Puntos</th>
                    <th>Predicciones</th>
                    <th>Aciertos 1X2</th>
                    <th>Exactos</th>
                </tr>
            </thead>
            <tbody>
                @{ int pos = 1; }
                @foreach (var r in Model.Ranking)
                {
                    <tr>
                        <td class="col-pos">@pos</td>
                        <td class="col-equipo">
                            @if (!string.IsNullOrEmpty(r.PaisFlag) && banderas.ContainsKey(r.PaisFlag))
                            {
                                <span style="margin-right:6px;">@banderas[r.PaisFlag]</span>
                            }
                            <strong>@r.Autor</strong>
                        </td>
                        <td class="col-pts"><strong style="color:var(--color-gold);">@r.TotalPuntos</strong></td>
                        <td class="col-num">@r.Predicciones</td>
                        <td class="col-num">@r.Aciertos1X2</td>
                        <td class="col-num">@r.AciertosExactos</td>
                    </tr>
                    pos++;
                }
            </tbody>
        </table>
    </div>
}

<style>
.tab-btn {
    padding: 10px 18px;
    border-radius: 8px;
    background: var(--color-bg2);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
}
.tab-btn.active {
    background: var(--color-gold);
    color: var(--color-bg);
    border-color: var(--color-gold);
}
</style>
</div>

@section Scripts {
<script>
// Cargar identidad guardada
(function() {
    const autor = localStorage.getItem('pred_autor') || '';
    const flag  = localStorage.getItem('pred_flag')  || '';
    const el = document.getElementById('pred-autor');
    const fl = document.getElementById('pred-flag');
    if (el) el.value = autor;
    if (fl) fl.value = flag;
    document.getElementById('pred-saved-msg').style.display = autor ? 'inline' : 'none';
})();

function guardarIdentidad() {
    const autor = document.getElementById('pred-autor').value.trim();
    const flag  = document.getElementById('pred-flag').value;
    localStorage.setItem('pred_autor', autor);
    localStorage.setItem('pred_flag',  flag);
    document.getElementById('pred-saved-msg').style.display = autor ? 'inline' : 'none';
}

async function cargarMisPredicciones() {
    const autor = document.getElementById('mis-pred-autor').value.trim()
                || document.getElementById('pred-autor')?.value?.trim();
    const cont = document.getElementById('mis-pred-resultado');
    if (!autor) { cont.innerHTML = '<p style="color:var(--color-red);font-size:12px;">Ingresá tu nombre.</p>'; return; }

    cont.innerHTML = '<p style="color:var(--color-muted);font-size:12px;">Cargando...</p>';
    const r = await fetch('/Predicciones/MisPredicciones?autor=' + encodeURIComponent(autor));
    const d = await r.json();
    if (!d.ok || !d.data.length) { cont.innerHTML = '<p style="color:var(--color-muted);font-size:12px;">No encontramos predicciones para ese nombre.</p>'; return; }

    let html = '<div style="display:flex;flex-direction:column;gap:6px;">';
    let tempActual = '';
    d.data.forEach(p => {
        if (p.temporadaNombre !== tempActual) {
            tempActual = p.temporadaNombre;
            html += `<div style="font-size:11px;letter-spacing:1px;color:var(--color-gold);text-transform:uppercase;margin-top:8px;">${tempActual || 'Sin temporada'}</div>`;
        }
        const pred1x2 = p.prediccion1x2 === 'L' ? p.nombreLocal : p.nombreVisitante;
        const predScore = (p.golesLocalPred !== null && p.golesVisitantePred !== null)
            ? `${p.golesLocalPred}-${p.golesVisitantePred}` : '';
        const realScore = p.jugado && p.golesLocalReal !== null
            ? `${p.golesLocalReal}-${p.golesVisitanteReal}` : 'Pendiente';

        let badge = '';
        if (p.jugado) {
            if (p.acertoExacto) badge = '<span style="background:var(--color-gold);color:var(--color-bg);border-radius:4px;padding:1px 6px;font-size:10px;font-weight:700;">+3</span>';
            else if (p.acerto1x2) badge = '<span style="background:var(--color-green);color:#fff;border-radius:4px;padding:1px 6px;font-size:10px;font-weight:700;">+1</span>';
            else badge = '<span style="background:var(--color-red);color:#fff;border-radius:4px;padding:1px 6px;font-size:10px;font-weight:700;">✗</span>';
        }

        html += `<div style="background:var(--color-bg3);border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;font-size:12px;">
            <span style="flex:1;min-width:120px;">${p.nombreLocal} vs ${p.nombreVisitante}</span>
            <span style="color:var(--color-muted);">F${p.fechaNumero}</span>
            <span>🔮 <strong>${pred1x2}</strong> ${predScore ? `(${predScore})` : ''}</span>
            <span style="color:var(--color-muted);">→ ${realScore}</span>
            ${badge}
        </div>`;
    });
    html += '</div>';

    const total = d.data.reduce((s, p) => s + (p.puntos || 0), 0);
    cont.innerHTML = `<p style="font-size:12px;color:var(--color-muted);margin-bottom:8px;">${d.data.length} predicciones · <strong style="color:var(--color-gold);">${total} pts totales</strong></p>` + html;

    // También prellenar el nombre en la identidad
    const autorInput = document.getElementById('pred-autor');
    if (autorInput && !autorInput.value) autorInput.value = autor;
}

// Auto-cargar si hay nombre en localStorage
document.addEventListener('DOMContentLoaded', () => {
    const autor = localStorage.getItem('pred_autor');
    if (autor) {
        document.getElementById('mis-pred-autor').value = autor;
    }
});

async function predecir(partidoId, divisionId) {
    const autor = document.getElementById('pred-autor').value.trim();
    const flag  = document.getElementById('pred-flag').value;
    const pred  = document.getElementById(`pred-${partidoId}-1x2`).value;
    const gl    = document.getElementById(`pred-${partidoId}-gl`).value;
    const gv    = document.getElementById(`pred-${partidoId}-gv`).value;
    const msg   = document.getElementById(`pred-${partidoId}-msg`);

    if (!autor) { msg.style.display='inline'; msg.style.color='var(--color-red)'; msg.textContent='Ingresá tu nombre arriba.'; return; }
    if (!pred)  { msg.style.display='inline'; msg.style.color='var(--color-red)'; msg.textContent='Elegí quién gana.'; return; }

    guardarIdentidad();

    const r = await fetch('/Predicciones/Predecir', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            partidoId, divisionId, autor, paisFlag: flag || null,
            prediccion1x2: pred,
            golesLocal:      gl !== '' ? parseInt(gl) : null,
            golesVisitante:  gv !== '' ? parseInt(gv) : null
        })
    });
    const d = await r.json();
    msg.style.display = 'inline';
    msg.style.color   = d.ok ? 'var(--color-green)' : 'var(--color-red)';
    msg.textContent   = d.msg;
}

function showRanking(tab) {
    ['primera','nacional','copa','all'].forEach(t => {
        document.getElementById('rank-' + t).style.display = t === tab ? 'block' : 'none';
        document.getElementById('tab-rank-' + t).classList.toggle('active', t === tab);
    });
}
</script>
}
