@model List<TorneoAmigos.Models.PosicionViewModel>
<table class="tabla-posiciones tabla-compacta">
    <thead>
        <tr>
            <th>#</th><th>Equipo</th><th>PJ</th><th>G</th><th>P</th><th>DIF</th><th>PTS</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var f in Model)
        {
            <tr class="zona-@f.Zona">
                <td class="col-pos">@f.Posicion</td>
                <td>
                    <a asp-controller="Equipos" asp-action="Detalle" asp-route-id="@f.EquipoId"
                       style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:6px;">
                    @if (!string.IsNullOrEmpty(f.FlagCode))
                    {
                        <img src="https://flagcdn.com/16x12/@(f.FlagCode).png"
                             class="flag-sm" alt="" onerror="this.style.display='none'" />
                    }
                    @f.NombreEquipo
                    </a>
                </td>
                <td class="col-num">@f.PartidosJugados</td>
                <td class="col-g">@f.Ganados</td>
                <td class="col-p">@f.Perdidos</td>
                <td class="@(f.DiferenciaGoles > 0 ? "col-dif-pos" : f.DiferenciaGoles < 0 ? "col-dif-neg" : "col-dif-neu")">
                    @(f.DiferenciaGoles > 0 ? "+" : "")@f.DiferenciaGoles
                </td>
                <td class="col-pts">@f.Puntos</td>
                <td style="padding:2px 4px;">
                    <div style="display:flex;gap:2px;">
                        @foreach (var r in f.Forma)
                        {
                            <span style="width:14px;height:14px;border-radius:2px;display:inline-flex;align-items:center;justify-content:center;
                                         font-size:8px;font-weight:700;
                                         background:@(r.EndsWith("C") ? "#3a82c8" : r=="V" ? "var(--color-green)" : "var(--color-red)");
                                         color:#fff;">@(r.Substring(0,1))</span>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
