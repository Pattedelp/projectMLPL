@model List<TorneoAmigos.Models.EquipoCheckbox>
@{
    ViewBag.Title = "Sortear Copa Argentina";
    ViewBag.ActivePage = "admin";
    var primera = Model.Where(e => e.DivisionId == 1).ToList();
    var b       = Model.Where(e => e.DivisionId == 2).ToList();
}

<div class="page-hero">
    <div class="page-hero-icon">🏆</div>
    <div class="page-hero-text">
        <h1>Copa Argentina</h1>
        <p>Primera vs B · Confirmá los participantes antes de sortear</p>
    </div>
</div>

<a asp-action="Index" style="display:inline-block;color:var(--color-muted);font-size:13px;margin-bottom:24px;">
    ← Volver al panel
</a>

<div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:28px;margin-bottom:24px;">

    <div style="background:var(--color-bg3);border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:13px;color:var(--color-muted);">
        🏆 Los equipos de <strong style="color:var(--color-text);">Primera División</strong> pasan directo a la ronda principal.<br/>
        🥈 Los de <strong style="color:var(--color-text);">Primera Nacional</strong> que sobren sin rival juegan una <strong style="color:var(--color-gold);">Fase Previa</strong> entre ellos.
    </div>

    <!-- Primera División -->
    <h3 style="font-family:var(--font-heading);font-size:13px;letter-spacing:2px;color:var(--color-gold);margin-bottom:12px;">
        🏆 PRIMERA DIVISIÓN (@primera.Count equipos)
    </h3>
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:24px;">
        @foreach (var e in primera)
        {
            <label style="display:flex;align-items:center;gap:8px;background:var(--color-bg3);border:1px solid var(--color-border);border-radius:8px;padding:10px 14px;cursor:pointer;font-size:13px;">
                <input type="checkbox" class="check-primera" value="@e.Id" checked
                       style="accent-color:var(--color-gold);width:16px;height:16px;" />
                @if (!string.IsNullOrEmpty(e.FlagCode) && e.FlagCode != "retired")
                {
                    <img src="https://flagcdn.com/20x15/@(e.FlagCode).png" class="flag-img" alt="" onerror="this.style.display='none'" />
                }
                @e.Nombre
            </label>
        }
    </div>

    <!-- Primera Nacional -->
    <h3 style="font-family:var(--font-heading);font-size:13px;letter-spacing:2px;color:#8aabcc;margin-bottom:12px;">
        🥈 PRIMERA NACIONAL (@b.Count equipos)
    </h3>
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:24px;">
        @foreach (var e in b)
        {
            <label style="display:flex;align-items:center;gap:8px;background:var(--color-bg3);border:1px solid var(--color-border);border-radius:8px;padding:10px 14px;cursor:pointer;font-size:13px;">
                <input type="checkbox" class="check-b" value="@e.Id" checked
                       style="accent-color:#8aabcc;width:16px;height:16px;" />
                @if (!string.IsNullOrEmpty(e.FlagCode) && e.FlagCode != "retired")
                {
                    <img src="https://flagcdn.com/20x15/@(e.FlagCode).png" class="flag-img" alt="" onerror="this.style.display='none'" />
                }
                @e.Nombre
            </label>
        }
    </div>

    <button class="btn-primary" onclick="confirmarSorteo()">🎲 Sortear Copa Argentina</button>
</div>

@section Scripts {
<script>
document.querySelectorAll('.check-participante').forEach(c => {
    c.addEventListener('change', () => {
        const total = document.querySelectorAll('.check-participante:checked').length;
        document.getElementById('count-sel').textContent = total;
    });
});

async function confirmarSorteo() {
    const primera = [...document.querySelectorAll('.check-primera:checked')].map(c => parseInt(c.value));
    const b       = [...document.querySelectorAll('.check-b:checked')].map(c => parseInt(c.value));
    if (primera.length < 1 || b.length < 1) { alert('Necesitás al menos 1 equipo de cada división.'); return; }
    if (!confirm(`¿Sortear la Copa Argentina con ${primera.length} de Primera y ${b.length} de la B?`)) return;

    const r = await fetch('/Admin/SortearCopaArgentina', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ equiposPrimera: primera, equiposB: b })
    });
    const d = await r.json();
    if (d.ok) { alert('¡Copa Argentina sorteada!'); location.href = '/Copas/CopaArgentina'; }
    else alert('Error: ' + (d.msg || 'Intentá de nuevo'));
}
</script>
}
