<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Torneo Chapitas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;700&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="~/css/torneo.css" />
</head>
<body>

<header class="topbar">
    <div class="topbar-inner">
        <a asp-controller="Home" asp-action="Index" class="logo">
            <span class="logo-icon">🏆</span>
            <span class="logo-text">Torneo Chapitas <em>AAC</em></span>
        </a>
        <nav class="main-nav">
            <a asp-controller="Home" asp-action="Index"
               class="@(ViewBag.ActivePage=="home"?"active":"")">Inicio</a>

            <div class="nav-dropdown">
                <span class="@(ViewBag.ActivePage=="primera"?"active":"")">Primera División ▾</span>
                <div class="dropdown-menu">
                    <a asp-controller="PrimeraDivision" asp-action="Posiciones">Posiciones</a>
                    <a asp-controller="PrimeraDivision" asp-action="Fixture">Fixture</a>
                    <a asp-controller="PrimeraDivision" asp-action="Equipos">Equipos</a>
                </div>
            </div>

            <div class="nav-dropdown">
                <span class="@(ViewBag.ActivePage=="nacb"?"active":"")">Primera Nacional ▾</span>
                <div class="dropdown-menu">
                    <a asp-controller="NacionalB" asp-action="Posiciones">Posiciones</a>
                    <a asp-controller="NacionalB" asp-action="Fixture">Fixture</a>
                    <a asp-controller="NacionalB" asp-action="Equipos">Equipos</a>
                </div>
            </div>

            <a asp-controller="Historial" asp-action="Index"
               class="@(ViewBag.ActivePage=="historial"?"active":"")">Historial</a>
            <a asp-controller="Estadisticas" asp-action="Index"
               class="@(ViewBag.ActivePage=="estadisticas"?"active":"")">Estadísticas</a>

            <div class="nav-dropdown">
                <span class="@(ViewBag.ActivePage=="copas"?"active":"")">Copas ▾</span>
                <div class="dropdown-menu">
                    <a asp-controller="Copas" asp-action="CopaArgentina">Copa Argentina</a>
                    <a asp-controller="Copas" asp-action="SupercopaArgentina">Supercopa Argentina</a>
                </div>
            </div>
        </nav>

        <!-- Admin panel link -->
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Index"
               class="nav-admin-link @(ViewBag.ActivePage == "admin" ? "active" : "")">⚙️ Admin</a>
        }
        <!-- Login/Logout en la derecha -->
        <div class="nav-auth">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index"
                   class="btn-login @(ViewBag.ActivePage == "admin" ? "active" : "")">⚙️ Admin</a>
                <form method="post" asp-controller="Auth" asp-action="Logout" style="display:inline">
                    <button type="submit" class="btn-logout">Salir</button>
                </form>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="btn-login">🔐 Admin</a>
            }
        </div>

        <button class="nav-toggle" id="navToggle">☰</button>
    </div>
</header>

<div class="mobile-nav" id="mobileNav">
    <a asp-controller="Home" asp-action="Index">Inicio</a>
    <p class="mobile-section-label">Primera División</p>
    <a asp-controller="PrimeraDivision" asp-action="Posiciones">→ Posiciones</a>
    <a asp-controller="PrimeraDivision" asp-action="Fixture">→ Fixture</a>
    <a asp-controller="PrimeraDivision" asp-action="Equipos">→ Equipos</a>
    <p class="mobile-section-label">Primera Nacional</p>
    <a asp-controller="NacionalB" asp-action="Posiciones">→ Posiciones</a>
    <a asp-controller="NacionalB" asp-action="Fixture">→ Fixture</a>
    <a asp-controller="NacionalB" asp-action="Equipos">→ Equipos</a>
    <a asp-controller="Historial" asp-action="Index">Historial</a>
    <a asp-controller="Estadisticas" asp-action="Index">Estadísticas</a>
    <p class="mobile-section-label">Copas</p>
    <a asp-controller="Copas" asp-action="CopaArgentina">→ Copa Argentina</a>
    <a asp-controller="Copas" asp-action="SupercopaArgentina">→ Supercopa Argentina</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert-success"><span>✓</span> @TempData["Mensaje"]</div>
}

<main class="site-main">
    @RenderBody()
</main>

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-left">
            <img src="~/img/aac-logo.png" alt="AAC"
                 style="width:36px;height:36px;border-radius:50%;object-fit:cover;flex-shrink:0;" />
            <div class="footer-brand">
                Torneo Chapitas
                <span>Asociación Argentina de Chapitas</span>
            </div>
        </div>
        <div class="footer-copy">© 2025 Torneo Chapitas. Todos los derechos reservados.</div>
        <div class="footer-social">
            <a href="#">📘</a><a href="#">📷</a><a href="#">▶️</a>
        </div>
    </div>
</footer>

<script>
    document.getElementById('navToggle').addEventListener('click', function () {
        document.getElementById('mobileNav').classList.toggle('open');
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
