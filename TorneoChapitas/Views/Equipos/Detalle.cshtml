@model EquipoDetalleViewModel
@{
    ViewBag.Title = Model.Equipo.Nombre;
    var e = Model.Equipo;
    var esAdmin = User.IsInRole("Admin");
    var totalTitulos = Model.Titulos.Count;
}

<div style="max-width:760px;margin:0 auto;">
    <a href="javascript:history.back()" style="display:inline-block;color:var(--color-muted);font-size:13px;margin:24px 0 20px;">
        ← Volver
    </a>

    <!-- HEADER -->
    <div style="display:flex;align-items:center;gap:20px;margin-bottom:32px;flex-wrap:wrap;">
        @if (e.FlagCode == "retired")
        {
            <div style="width:64px;height:48px;display:flex;align-items:center;justify-content:center;font-size:32px;color:var(--color-muted);border-radius:6px;background:var(--color-bg2);">✝</div>
        }
        else if (!string.IsNullOrEmpty(e.FlagCode))
        {
            <img src="https://flagcdn.com/64x48/@(e.FlagCode).png" alt=""
                 style="width:64px;height:48px;object-fit:cover;border-radius:6px;" onerror="this.style.display='none'" />
        }
        <div>
            <h1 style="font-family:var(--font-heading);font-size:28px;font-weight:700;color:var(--color-text);letter-spacing:1px;">
                @e.Nombre
            </h1>
            <p style="font-size:13px;color:var(--color-muted);margin-top:4px;">
                @(e.DivisionId == 1 ? "🏆 Primera División" : "🥈 Primera Nacional")
                @if (e.FlagCode == "retired") { <span> · Jugador retirado</span> }
            </p>
        </div>
    </div>

    <!-- STATS RÁPIDAS -->
    @if (Model.Posicion != null)
    {
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:32px;">
            <div class="stat-box">
                <div class="stat-num">@Model.Posicion.Posicion°</div>
                <div class="stat-label">Posición</div>
            </div>
            <div class="stat-box">
                <div class="stat-num" style="color:var(--color-gold);">@Model.Posicion.Puntos</div>
                <div class="stat-label">Puntos</div>
            </div>
            <div class="stat-box">
                <div class="stat-num">@Model.Posicion.PartidosJugados</div>
                <div class="stat-label">PJ</div>
            </div>
            <div class="stat-box">
                <div class="stat-num" style="color:@(Model.Posicion.GolesAFavor - Model.Posicion.GolesEnContra >= 0 ? "var(--color-green)" : "var(--color-red)")">
                    @((Model.Posicion.GolesAFavor - Model.Posicion.GolesEnContra) >= 0 ? "+" : "")@(Model.Posicion.GolesAFavor - Model.Posicion.GolesEnContra)
                </div>
                <div class="stat-label">Dif. Gol</div>
            </div>
        </div>
    }

    <!-- DESCRIPCIÓN -->
    <div style="margin-bottom:32px;">
        <h3 style="font-family:var(--font-heading);font-size:13px;letter-spacing:2px;color:var(--color-gold);margin-bottom:12px;text-transform:uppercase;">
            📋 Descripción
        </h3>

        @if (esAdmin)
        {
            <div id="desc-view" style="@(string.IsNullOrEmpty(e.Descripcion) ? "display:none;" : "")">
                <p id="desc-texto" style="font-size:14px;line-height:1.8;color:var(--color-text);white-space:pre-line;background:var(--color-bg2);border:1px solid var(--color-border);border-radius:10px;padding:16px 20px;">@e.Descripcion</p>
                <button onclick="editarDescripcion()" class="btn-outline" style="margin-top:8px;font-size:12px;">✏️ Editar</button>
            </div>
            <div id="desc-empty" style="@(string.IsNullOrEmpty(e.Descripcion) ? "" : "display:none;")">
                <p style="font-size:13px;color:var(--color-muted);margin-bottom:8px;">Sin descripción todavía.</p>
                <button onclick="editarDescripcion()" class="btn-outline" style="font-size:12px;">✏️ Agregar descripción</button>
            </div>
            <div id="desc-edit" style="display:none;">
                <textarea id="desc-input" rows="5" class="form-control" placeholder="Escribí algo sobre este equipo/jugador...">@e.Descripcion</textarea>
                <div style="display:flex;gap:8px;margin-top:8px;">
                    <button onclick="guardarDescripcion(@e.Id)" class="btn-primary" style="font-size:12px;padding:8px 16px;">Guardar</button>
                    <button onclick="cancelarEdicion()" class="btn-cancelar" style="font-size:12px;padding:8px 16px;">Cancelar</button>
                </div>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(e.Descripcion))
            {
                <p style="font-size:14px;line-height:1.8;color:var(--color-text);white-space:pre-line;background:var(--color-bg2);border:1px solid var(--color-border);border-radius:10px;padding:16px 20px;">@e.Descripcion</p>
            }
            else
            {
                <p style="font-size:13px;color:var(--color-muted);">Sin descripción todavía.</p>
            }
        }
    </div>

    <!-- HEAD TO HEAD -->
    <div style="margin-bottom:32px;">
        <h3 style="font-family:var(--font-heading);font-size:13px;letter-spacing:2px;color:var(--color-gold);margin-bottom:12px;text-transform:uppercase;">
            ⚔️ Mano a Mano
        </h3>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
            <select id="h2h-rival" class="form-control" style="flex:1;min-width:160px;">
                <option value="">Elegí un rival...</option>
                @foreach (var r in (List<Equipo>)ViewBag.TodosLosEquipos)
                {
                    <option value="@r.Id">@r.Nombre</option>
                }
            </select>
            <button onclick="compararH2H(@e.Id)" class="btn-primary" style="font-size:12px;padding:8px 16px;">
                Comparar
            </button>
        </div>
        <div id="h2h-resultado"></div>
    </div>

    <!-- PALMARÉS -->
    <div>
        <h3 style="font-family:var(--font-heading);font-size:13px;letter-spacing:2px;color:var(--color-gold);margin-bottom:12px;text-transform:uppercase;">
            🏆 Palmarés (@totalTitulos)
        </h3>

        @if (totalTitulos == 0)
        {
            <p style="font-size:13px;color:var(--color-muted);">Sin títulos registrados.</p>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:8px;">
                @foreach (var t in Model.Titulos.OrderBy(x => x.TemporadaNombre))
                {
                    var (icono, color) = t.TipoTitulo switch {
                        "campeon_torneo"     => ("🏆", "#f0c040"),
                        "campeon_copa"       => ("🥇", "#c0c0c0"),
                        "campeon_supercopa"  => ("⭐", "#3a82c8"),
                        "campeon_primera_b"  => ("🥈", "#8aabcc"),
                        "campeon_primera_c"  => ("🎖", "#8aabcc"),
                        "campeon_especial"   => ("🎪", "#9b59b6"),
                        _                    => ("🏅", "#8aabcc")
                    };
                    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:10px 16px;display:flex;align-items:center;gap:10px;">
                        <span style="font-size:18px;">@icono</span>
                        <div>
                            <div style="font-size:13px;color:var(--color-text);font-weight:500;">@t.NombreTitulo</div>
                            <div style="font-size:11px;color:var(--color-muted);">@t.TemporadaNombre</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
.stat-box {
    background: var(--color-bg2);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 14px;
    text-align: center;
}
.stat-num {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
}
.stat-label {
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-top: 4px;
}
</style>

@section Scripts {
<script>
function editarDescripcion() {
    document.getElementById('desc-view').style.display  = 'none';
    document.getElementById('desc-empty').style.display = 'none';
    document.getElementById('desc-edit').style.display  = 'block';
}
async function cancelarEdicion() {
    document.getElementById('desc-edit').style.display = 'none';
    const tieneTexto = document.getElementById('desc-texto')?.textContent.trim().length > 0;
    document.getElementById(tieneTexto ? 'desc-view' : 'desc-empty').style.display = 'block';
}

async function compararH2H(equipoAId) {
    const rivalId = document.getElementById('h2h-rival').value;
    const cont = document.getElementById('h2h-resultado');
    if (!rivalId) { cont.innerHTML = ''; return; }

    cont.innerHTML = '<p style="text-align:center;font-size:12px;color:var(--color-muted);margin-top:12px;">Cargando...</p>';
    try {
        const r = await fetch(`/Equipos/HeadToHead?equipoAId=${equipoAId}&equipoBId=${rivalId}`);
        const html = await r.text();
        cont.innerHTML = html;
    } catch {
        cont.innerHTML = '<p style="text-align:center;font-size:12px;color:var(--color-muted);margin-top:12px;">Error al cargar comparación.</p>';
    }
}
async function guardarDescripcion(equipoId) {
    const texto = document.getElementById('desc-input').value;
    const r = await fetch('/Equipos/ActualizarDescripcion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ equipoId, descripcion: texto })
    });
    const d = await r.json();
    if (d.ok) location.reload();
    else alert('Error al guardar.');
}
</script>
}
