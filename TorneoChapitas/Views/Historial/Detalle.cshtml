@model TemporadaDetalleViewModel
@{
    ViewBag.Title = Model.Temporada.Nombre;
    var partidosPrimera  = ViewBag.PartidosPrimera  as List<HistoricoPartido> ?? new();
    var partidosNacional = ViewBag.PartidosNacional as List<HistoricoPartido> ?? new();
    var banderas = new Dictionary<string,string> {
        {"nl","🇳🇱"},{"dk","🇩🇰"},{"cr","🇨🇷"},{"it","🇮🇹"},{"us","🇺🇲"},
        {"ir","🇮🇷"},{"gb-wls","🏴"},{"be","🇧🇪"},{"ua","🇺🇦"},{"de","🇩🇪"},
        {"kr","🇰🇷"},{"ec","🇪🇨"},{"br","🇧🇷"},{"es","🇪🇸"},{"vn","🇻🇳"},
        {"co","🇨🇴"},{"ar","🇦🇷"},{"uy","🇺🇾"},{"ph","🇵🇭"},{"pl","🇵🇱"},
        {"se","🇸🇪"},{"sa","🇸🇦"},{"ma","🇲🇦"},{"jp","🇯🇵"},{"gb-eng","🏴"},
        {"pt","🇵🇹"},{"tr","🇹🇷"},{"ng","🇳🇬"}
    };
}

<div class="page-hero">
    <div class="page-hero-icon">📅</div>
    <div class="page-hero-text">
        <h1>@Model.Temporada.Nombre</h1>
        <p>@Model.Temporada.FechaInicio?.ToString("MMM yyyy") — @Model.Temporada.FechaFin?.ToString("MMM yyyy")</p>
    </div>
</div>

<a asp-action="Index" style="display:inline-block;color:var(--color-muted);font-size:13px;margin-bottom:24px;">
    ← Volver al historial
</a>

<!-- TABS -->
<div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;">
    <button onclick="showTab('primera')"  id="tab-primera"  class="tab-btn active">🏆 Primera División</button>
    <button onclick="showTab('nacional')" id="tab-nacional" class="tab-btn">🥈 Primera Nacional</button>
</div>

<!-- PRIMERA DIVISIÓN -->
<div id="tab-primera-content">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;">

        <!-- Tabla de posiciones -->
        <div>
            <h3 style="font-family:var(--font-heading);font-size:13px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:12px;">Posiciones</h3>
            <div class="tabla-wrapper">
                <table class="tabla-posiciones">
                    <thead>
                        <tr><th>#</th><th>Equipo</th><th>PJ</th><th>V</th><th>D</th><th>DG</th><th>PTS</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.ResultadosPrimera)
                        {
                            <tr class="@(r.Campeon ? "zona-campeon" : r.Descendio ? "zona-descenso" : r.Ascendio ? "zona-ascenso" : "")"
                                style="cursor:pointer;" onclick="window.location='/Equipos/Detalle/@r.EquipoId'">
                                <td class="col-pos">@r.Posicion</td>
                                <td class="col-equipo">
                                    @if (!string.IsNullOrEmpty(r.FlagCode))
                                    { <img src="https://flagcdn.com/20x15/@(r.FlagCode).png" class="flag-img" alt="" onerror="this.style.display='none'" /> }
                                    @r.NombreEquipo
                                    @if (r.Campeon)    { <span style="margin-left:4px;font-size:11px;">🏆</span> }
                                    @if (r.Descendio)  { <span style="margin-left:4px;font-size:11px;color:var(--color-red);">⬇</span> }
                                    @if (r.Ascendio)   { <span style="margin-left:4px;font-size:11px;color:var(--color-green);">⬆</span> }
                                </td>
                                <td class="col-num">@r.PartidosJugados</td>
                                <td class="col-num" style="color:var(--color-green);">@r.Ganados</td>
                                <td class="col-num" style="color:var(--color-red);">@r.Perdidos</td>
                                <td class="col-num">@(r.GolesFavor - r.GolesContra > 0 ? "+" : "")@(r.GolesFavor - r.GolesContra)</td>
                                <td class="col-pts" style="color:var(--color-gold);font-weight:700;">@r.Puntos</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Resultados -->
        <div>
            <h3 style="font-family:var(--font-heading);font-size:13px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:12px;">Resultados</h3>
            @if (!partidosPrimera.Any())
            {
                <p style="color:var(--color-muted);font-size:13px;">No hay resultados registrados.</p>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:6px;">
                    @foreach (var p in partidosPrimera)
                    {
                        bool localGana = p.GolesLocal > p.GolesVisitante;
                        <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:8px 12px;display:flex;align-items:center;gap:8px;font-size:12px;">
                            <div style="flex:1;text-align:right;display:flex;align-items:center;justify-content:flex-end;gap:4px;">
                                @if (!string.IsNullOrEmpty(p.FlagLocal) && banderas.ContainsKey(p.FlagLocal))
                                { <span>@banderas[p.FlagLocal]</span> }
                                <a href="/Equipos/Detalle/@p.EquipoLocalId" style="color:var(--color-text);text-decoration:none;font-weight:@(localGana?"700":"400");">@p.NombreLocal</a>
                            </div>
                            <div style="font-family:var(--font-heading);font-size:15px;font-weight:700;background:var(--color-bg3);border-radius:6px;padding:2px 10px;min-width:50px;text-align:center;">
                                @p.GolesLocal - @p.GolesVisitante
                            </div>
                            <div style="flex:1;display:flex;align-items:center;gap:4px;">
                                <a href="/Equipos/Detalle/@p.EquipoVisitanteId" style="color:var(--color-text);text-decoration:none;font-weight:@(!localGana?"700":"400");">@p.NombreVisitante</a>
                                @if (!string.IsNullOrEmpty(p.FlagVisitante) && banderas.ContainsKey(p.FlagVisitante))
                                { <span>@banderas[p.FlagVisitante]</span> }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- PRIMERA NACIONAL -->
