@model HistorialViewModel
@{
    ViewBag.Title = "Panel Admin";
    ViewBag.ActivePage = "admin";
}

<div class="page-hero">
    <div class="page-hero-icon">⚙️</div>
    <div class="page-hero-text">
        <h1>Panel de Administración</h1>
        <p>Torneo Chapitas · AAC</p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div style="background:rgba(224,85,85,.15);border-left:3px solid var(--color-red);color:var(--color-red);padding:12px 20px;border-radius:6px;margin-bottom:20px;">
        ⚠️ @TempData["Error"]
    </div>
}

@if (Model.TemporadaActiva != null)
{
    <div class="admin-section">
        <h2 class="admin-section-title">📅 Temporada Activa: @Model.TemporadaActiva.Nombre</h2>

        <div style="display:flex;flex-direction:column;gap:12px;">

<!-- AGREGAR JUGADORES -->
<div class="admin-section">
    <h2 class="admin-section-title">👤 Jugadores</h2>
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px 24px;display:flex;align-items:center;gap:16px;">
        <div style="width:44px;height:44px;border-radius:50%;background:rgba(240,192,64,.2);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">👤</div>
        <div style="flex:1;">
            <div style="font-family:var(--font-heading);font-size:14px;letter-spacing:1px;color:var(--color-text);">Agregar Jugador Nuevo</div>
            <div style="font-size:12px;color:var(--color-muted);margin-top:2px;">Ingresá nombre y país — se inserta directo en la BD</div>
        </div>
        <a asp-action="AgregarJugador" style="background:var(--color-gold);color:var(--color-bg);border:none;border-radius:8px;padding:10px 20px;font-family:var(--font-heading);font-size:13px;letter-spacing:1px;cursor:pointer;text-decoration:none;flex-shrink:0;">
            Agregar
        </a>
    </div>

    <!-- Retirar jugador -->
    @{
        var activos   = ViewBag.EquiposTodos as List<Equipo> ?? new();
        var retirados = (ViewBag.EquiposRetirados as List<Equipo>) ?? new();
    }
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:16px 24px;margin-top:10px;">
        <div style="font-size:13px;font-weight:500;margin-bottom:10px;">⚰️ Retirar jugador</div>
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
            <select id="sel-retirar" class="form-control" style="flex:1;font-size:13px;">
                <option value="">-- Elegí un jugador --</option>
                @foreach (var e in activos.OrderBy(e => e.Nombre))
                {
                    <option value="@e.Id">@e.Nombre</option>
                }
            </select>
            <button onclick="retirarJugador()" style="background:var(--color-red);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-size:12px;cursor:pointer;">
                Retirar
            </button>
        </div>
        <p id="msg-retirar" style="font-size:11px;margin-top:6px;display:none;"></p>
    </div>

    <!-- Reactivar jugador -->
    @if (retirados.Any())
    {
        <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:16px 24px;margin-top:10px;">
            <div style="font-size:13px;font-weight:500;margin-bottom:10px;">♻️ Reactivar jugador retirado</div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <select id="sel-reactivar" class="form-control" style="flex:1;font-size:13px;">
                    <option value="">-- Elegí un jugador --</option>
                    @foreach (var e in retirados.OrderBy(e => e.Nombre))
                    {
                        <option value="@e.Id">@e.Nombre</option>
                    }
                </select>
                <button onclick="reactivarJugador()" style="background:var(--color-green);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-size:12px;cursor:pointer;">
                    Reactivar
                </button>
            </div>
            <p id="msg-reactivar" style="font-size:11px;margin-top:6px;display:none;"></p>
        </div>
    }
</div>

<!-- NUEVA TEMPORADA -->
<div class="admin-section">
    <h2 class="admin-section-title">🔄 Nueva Temporada</h2>
    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:24px;">
        <p style="color:var(--color-muted);font-size:14px;margin-bottom:16px;">
            Disponible una vez finalizada la temporada actual.
        </p>
        <a asp-action="NuevaTemporada"
           style="@(Model.TemporadaActiva != null ? "opacity:0.4;pointer-events:none;" : "")"
           class="btn-primary">
            Iniciar Nueva Temporada
        </a>
    </div>
</div>

            <!-- BORRAR FIXTURE -->
            <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:16px 24px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
                <div>
                    <div style="font-size:13px;font-weight:500;color:var(--color-text);">🗑️ Borrar Fixture</div>
                    <div style="font-size:11px;color:var(--color-muted);margin-top:2px;">Solo funciona si no hay resultados cargados. Permite agregar jugadores y regenerar.</div>
                </div>
                <div style="display:flex;gap:8px;flex-wrap:wrap;">
                    <button onclick="regenerarFixture()" style="background:var(--color-gold);color:var(--color-bg);border:none;border-radius:8px;padding:8px 16px;font-size:12px;cursor:pointer;">
                        🎲 Regenerar Fixture
                    </button>
                    <button onclick="borrarFixture()" style="background:transparent;border:1px solid var(--color-red);color:var(--color-red);border-radius:8px;padding:8px 16px;font-size:12px;cursor:pointer;">
                        🗑️ Borrar Fixture
                    </button>
                </div>
                <p id="msg-borrar-fixture" style="font-size:12px;display:none;width:100%;margin-top:6px;"></p>
            </div>

            <!-- FINALIZAR TEMPORADA -->
            <!-- REDUCIDO -->
            @{
                var tablaB = ViewBag.TablaBReducido as List<PosicionViewModel> ?? new List<PosicionViewModel>();
                var todosjugados = ViewBag.TodosJugadosB == true;
            }
            @if (tablaB.Count >= 6)
            {
                <div style="background:var(--color-bg2);border:1px solid rgba(58,130,200,0.4);border-radius:12px;padding:16px 24px;margin-bottom:16px;">
                    <div style="font-family:var(--font-heading);font-size:13px;letter-spacing:1px;color:#3a82c8;margin-bottom:12px;">
                        🔁 Reducido y Promoción
                    </div>
                    <p style="font-size:12px;color:var(--color-muted);margin-bottom:12px;">
                        3° vs 6° y 4° vs 5°. Se generan automáticamente al completar el fixture regular.
                        <br/>Posiciones actuales: <strong>3°: @tablaB[2].NombreEquipo</strong> vs <strong>6°: @tablaB[5].NombreEquipo</strong>
                        · <strong>4°: @tablaB[3].NombreEquipo</strong> vs <strong>5°: @tablaB[4].NombreEquipo</strong>
                    </p>
                    <div style="display:flex;gap:8px;flex-wrap:wrap;">
                        <button onclick="generarReducido()" style="background:#3a82c8;color:#fff;border:none;border-radius:8px;padding:8px 16px;font-size:12px;cursor:pointer;">
                            🔁 Generar Semifinales del Reducido
                        </button>
                    </div>

                    <!-- Final reducido -->
                    <div style="margin-top:12px;border-top:1px solid var(--color-border);padding-top:12px;">
                        <div style="font-size:12px;color:var(--color-muted);margin-bottom:8px;">Final del Reducido (elegir ganadores de semis):</div>
                        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                            <select id="sel-final-local" class="form-control" style="font-size:12px;flex:1;min-width:120px;">
                                <option value="0">Local...</option>
                                @foreach (var e in tablaB.Skip(2).Take(4))
                                {
                                    <option value="@e.EquipoId">@e.NombreEquipo</option>
                                }
                            </select>
                            <span style="color:var(--color-muted);">vs</span>
                            <select id="sel-final-visit" class="form-control" style="font-size:12px;flex:1;min-width:120px;">
                                <option value="0">Visitante...</option>
                                @foreach (var e in tablaB.Skip(2).Take(4))
                                {
                                    <option value="@e.EquipoId">@e.NombreEquipo</option>
                                }
                            </select>
                            <button onclick="generarFinalReducido()" style="background:#7c3aed;color:#fff;border:none;border-radius:8px;padding:8px 14px;font-size:12px;cursor:pointer;">
                                Generar Final
                            </button>
                        </div>
                    </div>

                    <!-- Promoción -->
                    @{
                        var tablaPrimera = ViewBag.TablaPrimeraReducido as List<PosicionViewModel> ?? new List<PosicionViewModel>();
                        var posPromPrimera = Model.TemporadaActiva?.PosPromocionPrimera ?? 8;
                        var equipoPromPrimera = tablaPrimera.Count >= posPromPrimera ? tablaPrimera[posPromPrimera - 1] : null;
                    }
                    <div style="margin-top:12px;border-top:1px solid var(--color-border);padding-top:12px;">
                        <div style="font-size:12px;color:var(--color-muted);margin-bottom:8px;">
                            Partido de Promoción (ganador del reducido vs @(equipoPromPrimera?.NombreEquipo ?? $"{posPromPrimera}° de Primera")):
                        </div>
                        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                            <select id="sel-prom-local" class="form-control" style="font-size:12px;flex:1;min-width:120px;">
                                <option value="0">Ganador del reducido (B)...</option>
                                @foreach (var e in tablaB)
                                {
                                    <option value="@e.EquipoId">@e.NombreEquipo</option>
                                }
                                @if (equipoPromPrimera != null)
                                {
                                    <option value="@equipoPromPrimera.EquipoId">@equipoPromPrimera.NombreEquipo (1ra)</option>
                                }
                            </select>
                            <span style="color:var(--color-muted);">vs</span>
                            <select id="sel-prom-visit" class="form-control" style="font-size:12px;flex:1;min-width:120px;">
                                <option value="0">@(equipoPromPrimera?.NombreEquipo ?? $"{posPromPrimera}° de Primera")...</option>
                                @if (equipoPromPrimera != null)
                                {
                                    <option value="@equipoPromPrimera.EquipoId" selected>@equipoPromPrimera.NombreEquipo (1ra)</option>
                                }
                                @foreach (var e in tablaB)
                                {
                                    <option value="@e.EquipoId">@e.NombreEquipo (B)</option>
                                }
                            </select>
                            <button onclick="generarPromocion()" style="background:#e05555;color:#fff;border:none;border-radius:8px;padding:8px 14px;font-size:12px;cursor:pointer;">
                                ⚔️ Generar Promoción
                            </button>
                        </div>
                    </div>
                    <p id="msg-reducido" style="font-size:12px;margin-top:8px;display:none;"></p>
                </div>
            }



            <!-- CONFIG DESCENSOS/ASCENSOS/PROMOCIÓN -->
            @{
                var tempActiva = Model.TemporadaActiva;
            }
            @if (tempActiva != null)
            {
                <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px 24px;margin-bottom:16px;">
                    <div style="font-family:var(--font-heading);font-size:13px;letter-spacing:1px;color:var(--color-text);margin-bottom:14px;">
                        ⚙️ Configuración de movimientos
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
                        <div>
                            <label style="font-size:11px;color:var(--color-muted);display:block;margin-bottom:4px;">Descensos directos</label>
                            <select id="cfg-descensos" class="form-control" style="font-size:13px;">
                                <option value="0" selected="@(tempActiva.CantDescensos==0)">Sin descensos</option>
                                <option value="1" selected="@(tempActiva.CantDescensos==1)">1 descenso</option>
                                <option value="2" selected="@(tempActiva.CantDescensos==2)">2 descensos</option>
                            </select>
                        </div>
                        <div>
                            <label style="font-size:11px;color:var(--color-muted);display:block;margin-bottom:4px;">Ascensos directos</label>
                            <select id="cfg-ascensos" class="form-control" style="font-size:13px;">
                                <option value="1" selected="@(tempActiva.CantAscensos==1)">1 ascenso</option>
                                <option value="2" selected="@(tempActiva.CantAscensos==2)">2 ascensos</option>
                            </select>
                        </div>
                    </div>
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-bottom:8px;">
                        <input type="checkbox" id="cfg-promocion" @(tempActiva.TienePromocion?"checked":"")
                               style="accent-color:var(--color-gold);width:14px;height:14px;"
                               onchange="document.getElementById('cfg-promo-detail').style.display=this.checked?'grid':'none'" />
                        <span style="font-size:13px;">🔁 Partido de promoción</span>
                    </label>
                    <div id="cfg-promo-detail" style="display:@(tempActiva.TienePromocion?"grid":"none");grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
                        <div>
                            <label style="font-size:11px;color:var(--color-muted);display:block;margin-bottom:4px;">Pos. Primera → Promoción</label>
                            <input type="number" id="cfg-pos-primera" value="@(tempActiva.PosPromocionPrimera ?? 8)" min="1" max="20" class="form-control" style="font-size:13px;" />
                        </div>
                        <div>
                            <label style="font-size:11px;color:var(--color-muted);display:block;margin-bottom:4px;">Pos. B → Promoción</label>
                            <input type="number" id="cfg-pos-b" value="@(tempActiva.PosPromocionB ?? 3)" min="1" max="20" class="form-control" style="font-size:13px;" />
                        </div>
                    </div>
                    <button onclick="guardarConfigTemporada()" class="btn-outline" style="font-size:12px;">
                        💾 Guardar configuración
                    </button>
                    <p id="msg-config" style="font-size:11px;margin-top:6px;display:none;"></p>
                </div>
            }

            @{
                var cierre = ViewBag.Cierre as TemporadaCierre;
                var equiposTodos = ViewBag.EquiposTodos as List<Equipo> ?? new();
                var equiposB = ViewBag.EquiposB as List<Equipo> ?? new();
            }
            <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px 24px;">
                <div style="display:flex;align-items:center;gap:16px;margin-bottom:4px;">
                    <div style="width:44px;height:44px;border-radius:50%;background:rgba(224,85,85,.2);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">🏁</div>
                    <div>
                        <div style="font-family:var(--font-heading);font-size:14px;letter-spacing:1px;color:var(--color-text);">Cierre de Temporada</div>
                        <div style="font-size:12px;color:var(--color-muted);margin-top:2px;">Guardá los datos a medida que se definen. Finalizar es solo la confirmación.</div>
                    </div>
                </div>

                @if (cierre != null)
                {
                    <div style="font-size:11px;color:var(--color-green);margin-bottom:12px;margin-left:60px;">
                        ✅ Borrador guardado
                    </div>
                }

                <div style="background:var(--color-bg3);border-radius:8px;padding:16px;margin-bottom:16px;display:flex;flex-direction:column;gap:14px;">

                    <!-- Sin descensos -->
                    <label style="display:flex;align-items:center;gap:10px;cursor:pointer;">
                        <input type="checkbox" id="chk-sin-descensos"
                               @(cierre?.SinDescensos == true ? "checked" : "")
                               style="accent-color:var(--color-gold);width:16px;height:16px;" />
                        <span style="font-size:13px;color:var(--color-text);">
                            ⚠️ <strong>Sin descensos esta temporada</strong>
                            <span style="color:var(--color-muted);font-size:11px;display:block;margin-top:2px;">
                                Los ascensos de la B se aplican normalmente, pero nadie baja de Primera.
                            </span>
                        </span>
                    </label>

                    <!-- Campeón Primera División -->
                    <div>
                        <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:6px;">🏆 Campeón Primera División</label>
                        <select id="sel-campeon-primera" class="form-control" style="font-size:13px;">
                            <option value="0">-- Automático (1° de tabla) --</option>
                            @foreach (var e in equiposTodos.Where(e => e.DivisionId == 1))
                            {
                                <option value="@e.Id" selected="@(cierre != null && cierre.CampeonPrimeraId == e.Id)">@e.Nombre</option>
                            }
                        </select>
                    </div>

                    <!-- Campeón Primera Nacional (B) -->
                    <div>
                        <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:6px;">🥈 Campeón Primera Nacional</label>
                        <select id="sel-campeon-b" class="form-control" style="font-size:13px;">
                            <option value="0">-- Automático (1° de tabla B) --</option>
                            @foreach (var e in equiposB)
                            {
                                <option value="@e.Id" selected="@(cierre != null && cierre.CampeonBId == e.Id)">@e.Nombre</option>
                            }
                        </select>
                    </div>

                    <!-- Copas -->
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                        <div>
                            <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:6px;">🏆 Campeón Copa Argentina</label>
                            <select id="sel-campeon-copa" class="form-control" style="font-size:13px;">
                                <option value="0">-- No se jugó --</option>
                                @foreach (var e in equiposTodos)
                                {
                                    <option value="@e.Id" selected="@(cierre != null && cierre.CampeonCopaId == e.Id)">@e.Nombre</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:6px;">⭐ Campeón Supercopa</label>
                            <select id="sel-campeon-supercopa" class="form-control" style="font-size:13px;">
                                <option value="0">-- No se jugó --</option>
                                @foreach (var e in equiposTodos)
                                {
                                    <option value="@e.Id" selected="@(cierre != null && cierre.CampeonSupercopaId == e.Id)">@e.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Ascensos -->
                    <div>
                        <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:6px;">📈 Ascensos directos (de Primera Nacional → Primera)</label>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                            <select id="sel-ascenso-1" class="form-control" style="font-size:13px;">
                                <option value="0">-- Automático (1° de la B) --</option>
                                @foreach (var e in equiposB)
                                {
                                    <option value="@e.Id" selected="@(cierre != null && cierre.Ascenso1Id == e.Id)">@e.Nombre</option>
                                }
                            </select>
                            <select id="sel-ascenso-2" class="form-control" style="font-size:13px;">
                                <option value="0">-- Automático (2° de la B) --</option>
                                @foreach (var e in equiposB)
                                {
                                    <option value="@e.Id" selected="@(cierre != null && cierre.Ascenso2Id == e.Id)">@e.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Promoción: ascenso 3 y descenso por promoción -->
                    <div>
                        <label style="font-size:11px;color:#3a82c8;letter-spacing:1px;display:block;margin-bottom:6px;">⚔️ Partido de Promoción (solo si ganó el equipo de la B)</label>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                            <div>
                                <label style="font-size:10px;color:var(--color-muted);display:block;margin-bottom:4px;">⬆ Ascenso 3 (ganador de la B)</label>
                                <select id="sel-ascenso-3" class="form-control" style="font-size:13px;">
                                    <option value="0">-- No hubo / Ganó el de Primera --</option>
                                    @foreach (var e in equiposB)
                                    {
                                        <option value="@e.Id" selected="@(cierre != null && cierre.Ascenso3Id == e.Id)">@e.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div>
                                <label style="font-size:10px;color:var(--color-muted);display:block;margin-bottom:4px;">⬇ Descenso por promo (perdedor de Primera)</label>
                                <select id="sel-descenso-promo" class="form-control" style="font-size:13px;">
                                    <option value="0">-- No hubo / Ganó el de Primera --</option>
                                    @foreach (var e in equiposTodos.Where(e => e.DivisionId == 1))
                                    {
                                        <option value="@e.Id" selected="@(cierre != null && cierre.DescensoPromoId == e.Id)">@e.Nombre</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Descensos -->
                    <div id="seccion-descensos" style="@(cierre?.SinDescensos == true ? "display:none;" : "")">
                        <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:6px;">📉 Descensos (de Primera → Primera Nacional)</label>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                            <select id="sel-descenso-1" class="form-control" style="font-size:13px;">
                                <option value="0">-- Automático (penúltimo) --</option>
                                @foreach (var e in equiposTodos.Where(e => e.DivisionId == 1))
                                {
                                    <option value="@e.Id" selected="@(cierre != null && cierre.Descenso1Id == e.Id)">@e.Nombre</option>
                                }
                            </select>
                            <select id="sel-descenso-2" class="form-control" style="font-size:13px;">
                                <option value="0">-- Automático (último) --</option>
                                @foreach (var e in equiposTodos.Where(e => e.DivisionId == 1))
                                {
                                    <option value="@e.Id" selected="@(cierre != null && cierre.Descenso2Id == e.Id)">@e.Nombre</option>
                                }
                            </select>
                        </div>
                    </div>



                    <!-- Descensos B → Primera C (solo si está activa) -->
                    @if (ViewBag.PrimeraCActiva == true)
                    {
                        <div>
                            <label style="font-size:11px;color:#7c3aed;letter-spacing:1px;display:block;margin-bottom:6px;">📉 Descensos (de Primera Nacional → Primera C)</label>
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                                <select id="sel-descenso-b1" class="form-control" style="font-size:13px;">
                                    <option value="0">-- Automático (penúltimo de la B) --</option>
                                    @foreach (var e in equiposB)
