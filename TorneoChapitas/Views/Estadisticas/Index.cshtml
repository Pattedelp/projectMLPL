@model EstadisticasViewModel
@{
    ViewBag.Title = "Estadísticas";
    ViewBag.ActivePage = "estadisticas";
}

<div class="page-hero">
    <div class="page-hero-icon">
        <img src="~/img/aac-logo.png" alt="AAC"
             style="width:56px;height:56px;border-radius:50%;object-fit:cover;" />
    </div>
    <div class="page-hero-text">
        <h1>Estadísticas</h1>
        <p>Historial de campeones y ranking histórico · Torneo Chapitas AAC</p>
    </div>
</div>

<!-- TABS -->
<div style="display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap;">
    <button onclick="showTab('palmares')"    id="tab-palmares"    class="tab-btn active">🏆 Palmarés</button>
    <button onclick="showTab('alltime')"     id="tab-alltime"     class="tab-btn">📊 Tabla Histórica</button>
    <button onclick="showTab('historiales')" id="tab-historiales" class="tab-btn">⚔️ Historiales Completos</button>
</div>

<!-- ============ PALMARÉS ============ -->
<div id="section-palmares">
@if (!Model.Palmares.Equipos.Any())
{
    <div style="text-align:center;padding:60px 24px;">
        <div style="font-size:48px;margin-bottom:16px;">🏆</div>
        <h3 style="font-family:var(--font-heading);color:var(--color-gold);letter-spacing:2px;">AÚN NO HAY TÍTULOS</h3>
        <p style="color:var(--color-muted);font-size:14px;margin-top:8px;">Los títulos se registran al finalizar cada torneo o copa.</p>
    </div>
}
else
{
    <h2 style="font-family:var(--font-heading);font-size:15px;letter-spacing:2px;text-transform:uppercase;color:var(--color-gold);margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--color-border);">
        🏆 Tabla de Títulos
    </h2>
    <div class="tabla-wrapper" style="margin-bottom:40px;">
        <table class="tabla-posiciones">
            <thead>
                <tr>
                    <th>#</th><th>Jugador</th>
                    <th title="Total títulos">Total</th>
                    <th title="Campeonatos de Liga">🏆 Liga</th>
                    <th title="Copa Argentina">🥇 Copa Arg.</th>
                    <th title="Supercopa">⭐ Supercopa</th>
                    <th title="Otros títulos">🎖 Otros</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{ int pos = 1; }
                @foreach (var e in Model.Palmares.Equipos)
                {
                    var otros = e.TotalTitulos - e.CampeonatosLiga - e.CopaArgentina - e.Supercopa;
                    <tr style="cursor:pointer;" onclick="toggleDetalle('@e.NombreEquipo.ToLower().Replace(" ","_")')">
                        <td class="col-pos">@pos</td>
                        <td class="col-equipo">
                            @if (e.FlagCode == "retired") { <span style="font-size:14px;margin-right:6px;color:var(--color-muted);" title="Jugador retirado">✝</span> }
                            else if (!string.IsNullOrEmpty(e.FlagCode)) { <img src="https://flagcdn.com/20x15/@(e.FlagCode).png" class="flag-img" alt="" onerror="this.style.display='none'" /> }
                            <strong>@e.NombreEquipo</strong>
                            @if (e.FlagCode == "retired") { <span style="font-size:11px;color:var(--color-muted);margin-left:6px;">retirado</span> }
                        </td>
                        <td class="col-pts">@e.TotalTitulos</td>
                        <td class="col-num">@(e.CampeonatosLiga > 0 ? e.CampeonatosLiga.ToString() : "-")</td>
                        <td class="col-num">@(e.CopaArgentina  > 0 ? e.CopaArgentina.ToString()  : "-")</td>
                        <td class="col-num">@(e.Supercopa      > 0 ? e.Supercopa.ToString()      : "-")</td>
                        <td class="col-num">@(otros > 0 ? otros.ToString() : "-")</td>
                        <td style="color:var(--color-muted);font-size:12px;">ver ▾</td>
                    </tr>
                    <tr id="detalle-@e.NombreEquipo.ToLower().Replace(" ","_")" style="display:none;">
                        <td colspan="8" style="padding:0;background:var(--color-bg3);">
                            <div style="padding:16px 24px;">
                                <div style="display:flex;flex-wrap:wrap;gap:8px;">
                                    @foreach (var t in e.Titulos.OrderBy(x => x.TemporadaNombre))
                                    {
                                        var (icono, color) = t.TipoTitulo switch {
                                            "campeon_torneo"    => ("🏆","#f0c040"),
                                            "campeon_copa"      => ("🥇","#c0c0c0"),
                                            "campeon_supercopa" => ("⭐","#3a82c8"),
                                            "campeon_primera_b" => ("🥈","#8aabcc"),
                                            "campeon_primera_c" => ("🎖","#8aabcc"),
                                            "campeon_especial"  => ("🎪","#9b59b6"),
                                            _                   => ("🏅","#8aabcc")
                                        };
                                        <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:8px 14px;display:flex;align-items:center;gap:8px;min-width:200px;">
                                            <span style="font-size:18px;">@icono</span>
                                            <div>
                                                <div style="font-size:13px;color:var(--color-text);font-weight:500;">@t.NombreTitulo</div>
                                                <div style="font-size:11px;color:var(--color-muted);">@t.TemporadaNombre</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </td>
                    </tr>
                    pos++;
                }
            </tbody>
        </table>
    </div>

    @if (Model.Palmares.UltimosTitulos.Any())
    {
        <h2 style="font-family:var(--font-heading);font-size:15px;letter-spacing:2px;text-transform:uppercase;color:var(--color-gold);margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--color-border);">
            🕐 Últimos Campeones
        </h2>
        <div style="display:flex;flex-direction:column;gap:8px;">
            @foreach (var t in Model.Palmares.UltimosTitulos.Take(8))
            {
                var icono = t.TipoTitulo switch {
                    "campeon_torneo"    => "🏆",
                    "campeon_copa"      => "🥇",
                    "campeon_supercopa" => "⭐",
                    "campeon_primera_b" => "🥈",
                    _ => "🎖"
                };
                <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:12px 18px;display:flex;align-items:center;gap:14px;">
                    <span style="font-size:22px;flex-shrink:0;">@icono</span>
                    <div>
                        <div style="font-size:14px;font-weight:500;color:var(--color-text);display:flex;align-items:center;gap:8px;">
                            @if (t.FlagCode == "retired") { <span style="font-size:13px;color:var(--color-muted);">✝</span> }
                            else if (!string.IsNullOrEmpty(t.FlagCode)) { <img src="https://flagcdn.com/16x12/@(t.FlagCode).png" style="border-radius:1px;" alt="" onerror="this.style.display='none'" /> }
                            @t.NombreEquipo
                        </div>
                        <div style="font-size:12px;color:var(--color-muted);">@t.NombreTitulo · @t.TemporadaNombre</div>
                    </div>
                </div>
            }
        </div>
    }
}
</div>

<!-- ============ RANKING ALL-TIME ============ -->
<div id="section-alltime" style="display:none;">
    <h2 style="font-family:var(--font-heading);font-size:15px;letter-spacing:2px;text-transform:uppercase;color:var(--color-gold);margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid var(--color-border);">
        📊 Tabla Histórica — Primera División
    </h2>
    <p style="font-size:12px;color:var(--color-muted);margin-bottom:20px;">
        Acumula todos los partidos de liga de Primera División registrados en el sistema. Ordenado por victorias totales.
    </p>
    @if (!Model.RankingAllTime.Any())
    {
        <p style="color:var(--color-muted);font-size:13px;">No hay datos suficientes todavía.</p>
    }
    else
    {
        <div class="tabla-wrapper">
            <table class="tabla-posiciones">
                <thead>
                    <tr>
                        <th>#</th><th>Jugador</th>
                        <th title="Partidos Jugados">PJ</th>
                        <th title="Victorias">V</th>
                        <th title="Derrotas">D</th>
                        <th title="Goles a Favor">GF</th>
                        <th title="Goles en Contra">GC</th>
                        <th title="Diferencia de Goles">DG</th>
                        <th title="Puntos">PTS</th>
                        <th title="% Victorias">%V</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int posAt = 1; }
                    @foreach (var entry in Model.RankingAllTime)
                    {
                        var dg  = entry.GolesAFavor - entry.GolesEnContra;
                        var pct = entry.PartidosJugados > 0 ? (int)(100.0 * entry.Victorias / entry.PartidosJugados) : 0;
                        <tr style="cursor:pointer;" onclick="window.location='/Equipos/Detalle/@entry.EquipoId'">
                            <td class="col-pos">@posAt</td>
                            <td class="col-equipo">
                                @if (entry.FlagCode == "retired") { <span style="font-size:14px;margin-right:6px;color:var(--color-muted);">✝</span> }
                                else if (!string.IsNullOrEmpty(entry.FlagCode)) { <img src="https://flagcdn.com/20x15/@(entry.FlagCode).png" class="flag-img" alt="" onerror="this.style.display='none'" /> }
                                <strong>@entry.NombreEquipo</strong>
                            </td>
                            <td class="col-num">@entry.PartidosJugados</td>
                            <td class="col-num" style="color:var(--color-green);font-weight:600;">@entry.Victorias</td>
                            <td class="col-num" style="color:var(--color-red);">@entry.Derrotas</td>
                            <td class="col-num">@entry.GolesAFavor</td>
                            <td class="col-num">@entry.GolesEnContra</td>
                            <td class="col-num" style="color:@(dg >= 0 ? "var(--color-green)" : "var(--color-red)")">@(dg >= 0 ? "+" : "")@dg</td>
                            <td class="col-pts" style="color:var(--color-gold);font-weight:700;">@entry.PuntosTotal</td>
                            <td class="col-num"><span style="font-size:12px;">@pct%</span></td>
                        </tr>
                        posAt++;
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- ============ HISTORIALES COMPLETOS ============ -->
<div id="section-historiales" style="display:none;">
    <h2 style="font-family:var(--font-heading);font-size:15px;letter-spacing:2px;text-transform:uppercase;color:var(--color-gold);margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid var(--color-border);">
        ⚔️ Historiales Completos
    </h2>
    <p style="font-size:12px;color:var(--color-muted);margin-bottom:20px;">
        Historial de cada jugador contra todos sus rivales. Incluye liga, copas y partidos de la temporada en curso.
    </p>

    @if (!Model.Historiales.Any())
    {
        <p style="color:var(--color-muted);font-size:13px;">No hay datos todavía.</p>
    }
    else
    {
<div style="margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">

    <label style="font-size:13px;color:var(--color-muted);">
        Ver historial de:
    </label>

    <div class="historial-selector">

        <div class="historial-selector-selected" onclick="toggleSelector()">
            <span id="historial-selected-text">-- Elegí un jugador --</span>
            <span>▾</span>
        </div>

        <div id="historial-options" class="historial-selector-options">

            @foreach (var h in Model.Historiales.OrderBy(x => x.NombreEquipo))
            {
                <div class="historial-option"
                     data-id="@h.EquipoId"
                     data-nombre="@h.NombreEquipo"
                     onclick="seleccionarHistorial('@h.EquipoId','@h.NombreEquipo')">

                    @if (h.FlagCode == "retired")
                    {
                        <span style="font-size:14px;color:var(--color-muted);margin-right:6px;">✝</span>
                    }
                    else if (!string.IsNullOrEmpty(h.FlagCode))
                    {
                        <img src="https://flagcdn.com/20x15/@(h.FlagCode).png"
                             class="flag-img"
                             alt=""
                             onerror="this.style.display='none'" />
                    }

                    <span>@h.NombreEquipo</span>

                </div>
            }

        </div>

    </div>

</div>

        @foreach (var h in Model.Historiales)
        {
            <div id="historial-@h.EquipoId" class="historial-panel" style="display:none;">
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
                    @if (!string.IsNullOrEmpty(h.FlagCode) && h.FlagCode != "retired")
                    { <img src="https://flagcdn.com/32x24/@(h.FlagCode).png" style="border-radius:3px;" alt="" onerror="this.style.display='none'" /> }
                    <span style="font-family:var(--font-heading);font-size:17px;color:var(--color-text);">@h.NombreEquipo</span>
                    <span style="font-size:12px;color:var(--color-muted);">— @h.Rivales.Count rivales</span>
                </div>
                <div class="tabla-wrapper">
                    <table class="tabla-posiciones">
                        <thead>
                            <tr>
                                <th style="text-align:left;">Rival</th>
                                <th title="Diferencia victorias-derrotas">DIF</th>
                                <th title="Partidos Jugados">PJ</th>
                                <th title="Partidos Ganados">PG</th>
                                <th title="Partidos Empatados">PE</th>
                                <th title="Partidos Perdidos">PP</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rv in h.Rivales.OrderByDescending(r => r.Dif).ThenByDescending(r => r.PJ))
                            {
                                var difColor = rv.Dif > 0 ? "var(--color-green)" : rv.Dif < 0 ? "var(--color-red)" : "var(--color-muted)";
                                var difStr   = rv.Dif > 0 ? $"+{rv.Dif}" : rv.Dif.ToString();
                                <tr style="cursor:pointer;" onclick="window.location='/Equipos/Detalle/@h.EquipoId?rivalId=@rv.RivalId'">
                                    <td class="col-equipo">
                                        @if (!string.IsNullOrEmpty(rv.FlagRival) && rv.FlagRival != "retired")
                                        { <img src="https://flagcdn.com/20x15/@(rv.FlagRival).png" class="flag-img" alt="" onerror="this.style.display='none'" /> }
                                        <strong>@rv.NombreRival</strong>
                                    </td>
                                    <td class="col-num">
                                        <span style="background:@(rv.Dif > 0 ? "rgba(40,167,69,0.15)" : rv.Dif < 0 ? "rgba(220,53,69,0.15)" : "var(--color-bg3)");color:@difColor;padding:2px 8px;border-radius:4px;font-weight:700;font-family:var(--font-heading);">
                                            @difStr
                                        </span>
                                    </td>
                                    <td class="col-num">@rv.PJ</td>
                                    <td class="col-num" style="color:var(--color-green);font-weight:600;">@rv.PG</td>
                                    <td class="col-num" style="color:var(--color-muted);">@rv.PE</td>
                                    <td class="col-num" style="color:var(--color-red);">@rv.PP</td>
                                    <td style="font-size:11px;color:var(--color-muted);">ver ⚔</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
<script>
function toggleDetalle(id) {
    const row = document.getElementById('detalle-' + id);
    if (!row) return;
    row.style.display = row.style.display !== 'none' ? 'none' : 'table-row';
}
function showTab(tab) {
    ['palmares','alltime','historiales'].forEach(t => {
        document.getElementById('section-' + t).style.display = t === tab ? 'block' : 'none';
        document.getElementById('tab-' + t).classList.toggle('active', t === tab);
    });
}
function mostrarHistorial(eqId) {
    document.querySelectorAll('.historial-panel').forEach(p => p.style.display = 'none');
    if (eqId) {
        const panel = document.getElementById('historial-' + eqId);
        if (panel) panel.style.display = 'block';
    }
}
(function() {
    const params = new URLSearchParams(window.location.search);
    const eqId   = params.get('equipo');
    if (eqId) {
        showTab('historiales');
        const opcion = document.querySelector(".historial-option[data-id='" + eqId + "']");

if (opcion) {
    document.getElementById("historial-selected-text").innerText =
        opcion.dataset.nombre;
}

mostrarHistorial(eqId);
    }
})();

function toggleSelector() {

    const lista = document.getElementById("historial-options");

    lista.style.display =
        lista.style.display === "block"
            ? "none"
            : "block";
}

function seleccionarHistorial(id, nombre) {

    document.getElementById("historial-selected-text").innerText = nombre;

    document.getElementById("historial-options").style.display = "none";

    mostrarHistorial(id);
}

document.addEventListener("click", function(e){

    const selector = document.querySelector(".historial-selector");

    if(selector && !selector.contains(e.target)){
        document.getElementById("historial-options").style.display="none";
    }

});
</script>
<style>
.tab-btn { padding:10px 18px;border-radius:8px;background:var(--color-bg2);border:1px solid var(--color-border);color:var(--color-muted);font-size:13px;font-weight:500;cursor:pointer; }
.tab-btn.active { background:var(--color-gold);color:var(--color-bg);border-color:var(--color-gold); }

.historial-selector{
    position:relative;
    width:260px;
    font-size:13px;
}

.historial-selector-selected{
    background:var(--color-bg2);
    border:1px solid var(--color-border);
    border-radius:8px;
    padding:10px 14px;
    cursor:pointer;
    display:flex;
    align-items:center;
    justify-content:space-between;
    color:var(--color-text);
    transition:.15s;
}

.historial-selector-selected:hover{
    border-color:var(--color-gold);
}

.historial-selector-options{
    display:none;
    position:absolute;
    left:0;
    right:0;
    top:105%;
    background:var(--color-bg2);
    border:1px solid var(--color-border);
    border-radius:8px;
    overflow:hidden;
    max-height:320px;
    overflow-y:auto;
    z-index:999;
    box-shadow:0 10px 25px rgba(0,0,0,.35);
}

.historial-option{
    display:flex;
    align-items:center;
    gap:10px;
    padding:10px 14px;
    cursor:pointer;
    transition:.15s;
}

.historial-option:hover{
    background:var(--color-bg3);
}
</style>
}
