@model HomeViewModel
@{
    ViewBag.Title = "Inicio";
    ViewBag.ActivePage = "home";
}

<!-- HERO -->
<div class="home-hero">
    <div class="home-hero-content">
        <div class="home-hero-badge">
            <img src="~/img/aac-logo.png" alt="AAC"
                 style="width:76px;height:76px;border-radius:50%;object-fit:cover;" />
        </div>
        <div class="home-hero-text">
            <h1>TORNEO <span>CHAPITAS</span></h1>
            <p>Organización: <span>AAC</span> · Asociación Argentina de Chapitas</p>
        </div>
    </div>
    <div class="home-hero-ball"></div>
</div>

<!-- STATS -->
<div class="stats-bar">
    <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-info">
            <div class="stat-label">Partidos jugados</div>
            <div class="stat-value">@Model.TotalPartidosJugados</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">⚽</div>
        <div class="stat-info">
            <div class="stat-label">Goles totales</div>
            <div class="stat-value">@Model.TotalGoles</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-info">
            <div class="stat-label">Equipos</div>
            <div class="stat-value">@(Model.PrimeraDivision.Equipos.Count + Model.NacionalB.Equipos.Count)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">🏆</div>
        <div class="stat-info">
            <div class="stat-label">Divisiones</div>
            <div class="stat-value">2</div>
        </div>
    </div>
</div>

<!-- CARRUSEL DE NOTICIAS -->
@if (Model.UltimasNoticias.Any())
{
    <div class="carrusel-section">
        <div class="carrusel-header">
            <h2 class="carrusel-titulo">📰 Últimas Noticias</h2>
            <a asp-controller="Noticias" asp-action="Index" class="carrusel-ver-mas">Ver todas →</a>
        </div>
        <div class="carrusel-wrapper">
            <button class="carrusel-btn carrusel-prev" onclick="moverCarrusel(-1)">‹</button>
            <div class="carrusel-track-outer">
                <div class="carrusel-track" id="carruselTrack">
                    @foreach (var n in Model.UltimasNoticias)
                    {
                        <div class="carrusel-slide">
                            <a asp-controller="Noticias" asp-action="Detalle" asp-route-id="@n.Id"
                               class="carrusel-slide-inner">
                                <div class="carrusel-img"
                                     style="@(!string.IsNullOrEmpty(n.ImagenUrl) ? $"background-image:url('{n.ImagenUrl}')" : "")">
                                    @if (string.IsNullOrEmpty(n.ImagenUrl))
                                    {
                                        <span style="font-size:32px;">📰</span>
                                    }
                                </div>
                                <div class="carrusel-body">
                                    <span class="noticia-badge @(n.Tipo == "automatica" ? "badge-auto" : "badge-manual")" style="font-size:10px;">
                                        @(n.Tipo == "automatica" ? "⚡ Auto" : "✍️")
                                    </span>
                                    <h3 class="carrusel-noticia-titulo">@n.Titulo</h3>
                                    <p class="carrusel-noticia-fecha">@n.CreatedAt.ToString("dd/MM/yyyy")</p>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
            <button class="carrusel-btn carrusel-next" onclick="moverCarrusel(1)">›</button>
        </div>
        <div class="carrusel-dots" id="carruselDots"></div>
    </div>
}

<!-- MINI TABLAS -->
<div class="home-sections">
    @await Html.PartialAsync("_MiniTabla", Model.PrimeraDivision)
    @await Html.PartialAsync("_MiniTabla", Model.NacionalB)
</div>

@section Scripts {
<script>
let currentSlide = 0;
const track = document.getElementById('carruselTrack');
if (track) {
    const slides        = Array.from(track.querySelectorAll('.carrusel-slide'));
    const dotsContainer = document.getElementById('carruselDots');
    let autoTimer;

    function getSlidesVisible() {
        return window.innerWidth < 600 ? 1 : window.innerWidth < 900 ? 2 : 3;
    }

    function getTotal() {
        return Math.max(1, Math.ceil(slides.length / getSlidesVisible()));
    }

    function buildDots() {
        dotsContainer.innerHTML = '';
        for (let i = 0; i < getTotal(); i++) {
            const d = document.createElement('span');
            d.className = 'carrusel-dot' + (i === 0 ? ' active' : '');
            d.onclick   = () => goTo(i);
            dotsContainer.appendChild(d);
        }
    }

    function goTo(idx) {
        const sv    = getSlidesVisible();
        const total = getTotal();
        currentSlide = ((idx % total) + total) % total;

        // Mover el track: cada slide ocupa 100/sv %
        const slideW = 100 / sv;
        track.style.transform = `translateX(-${currentSlide * slideW}%)`;

        document.querySelectorAll('.carrusel-dot').forEach((d, i) =>
            d.classList.toggle('active', i === currentSlide));
    }

    function resetTimer() {
        clearInterval(autoTimer);
        autoTimer = setInterval(() => goTo(currentSlide + 1), 5000);
    }

    window.moverCarrusel = function(dir) { goTo(currentSlide + dir); resetTimer(); };

    // Touch swipe para mobile
    let touchStartX = 0;
    track.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', e => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) { goTo(currentSlide + (diff > 0 ? 1 : -1)); resetTimer(); }
    });

    window.addEventListener('resize', () => { buildDots(); goTo(0); });
    buildDots();
    resetTimer();
}
</script>
}
