@model List<GrupoFecha>
@{
    ViewBag.Title = "Primera C Nacional - Fixture";
    bool esAdmin = ViewBag.EsAdmin == true;
}

<div class="page-hero">
    <div class="page-hero-icon">🏟️</div>
    <div class="page-hero-text">
        <h1>Primera C Nacional</h1>
        <p>Fixture de la temporada</p>
    </div>
</div>

<nav class="section-nav">
    <a asp-controller="PrimeraC" asp-action="Posiciones">Posiciones</a>
    <a asp-controller="PrimeraC" asp-action="Fixture" class="active">Fixture</a>
    <a asp-controller="PrimeraC" asp-action="Equipos">Equipos</a>
</nav>

@if (!Model.Any())
{
    <div style="text-align:center;padding:60px 20px;color:var(--color-muted);">
        <div style="font-size:48px;margin-bottom:16px;">🏟️</div>
        <p style="font-size:16px;">No hay fixture generado para Primera C todavía.</p>
    </div>
}
@foreach (var grupo in Model)
{
    @await Html.PartialAsync("_TablaViva", grupo)
}
