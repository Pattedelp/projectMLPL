it @model CopaFullViewModel
@{
    ViewBag.Title = Model.Copa.Nombre;
    ViewBag.ActivePage = "copas";
}

<div class="page-hero">
    <div class="page-hero-icon">🏆</div>
    <div class="page-hero-text">
        <h1>@Model.Copa.Nombre</h1>
        <p>Torneo Chapitas · AAC</p>
    </div>
</div>

<nav class="section-nav">
    <a asp-controller="Copas" asp-action="CopaArgentina"
       class="@(Model.Copa.Tipo == "copa_argentina" ? "active" : "")">Copa Argentina</a>
    <a asp-controller="Copas" asp-action="SupercopaArgentina"
       class="@(Model.Copa.Tipo == "supercopa" ? "active" : "")">Supercopa Argentina</a>
</nav>

<div class="bracket-scroll">
<div class="bracket">
    @foreach (var ronda in Model.Rondas)
    {
        <div class="bracket-round">
            <div class="bracket-round-header">
                <span class="bracket-round-title">@ronda.Nombre</span>
                @if (Model.EsAdmin)
                {
                    <label class="toggle-habilitada" style="margin-left:8px" title="Habilitar ronda">
                        <input type="checkbox" class="check-ronda"
                               data-ronda-id="@ronda.Id"
                               @(ronda.Habilitada ? "checked" : "") />
                        <span class="toggle-slider"></span>
                    </label>
                }
            </div>
            <div class="bracket-matches">
                @foreach (var partido in ronda.Partidos)
                {
                    var bloqueado = !ronda.Habilitada && !Model.EsAdmin;
                    var tbd = string.IsNullOrEmpty(partido.NombreLocal) || partido.NombreLocal == "Por definir";
                    <div class="bracket-match @(bloqueado ? "bracket-blur" : "")" id="copa-partido-@partido.Id">
                        <div class="bracket-team @(partido.Jugado && partido.GolesLocal > partido.GolesVisitante ? "winner" : "") @(tbd ? "tbd" : "")">
                            @if (!string.IsNullOrEmpty(partido.FlagLocal))
                            {
                                <img src="https://flagcdn.com/16x12/@(partido.FlagLocal).png" class="flag-sm" alt="" onerror="this.style.display='none'" />
                            }
                            <span>@(string.IsNullOrEmpty(partido.NombreLocal) ? "Por definir" : partido.NombreLocal)</span>
                            @if (partido.Jugado) { <span class="bracket-score">@partido.GolesLocal</span> }
                        </div>
                        <div class="bracket-team @(partido.Jugado && partido.GolesVisitante > partido.GolesLocal ? "winner" : "") @(tbd ? "tbd" : "")">
                            @if (!string.IsNullOrEmpty(partido.FlagVisitante))
                            {
                                <img src="https://flagcdn.com/16x12/@(partido.FlagVisitante).png" class="flag-sm" alt="" onerror="this.style.display='none'" />
                            }
                            <span>@(string.IsNullOrEmpty(partido.NombreVisitante) ? "Por definir" : partido.NombreVisitante)</span>
                            @if (partido.Jugado) { <span class="bracket-score">@partido.GolesVisitante</span> }
                        </div>
                        @if (Model.EsAdmin && ronda.Habilitada)
                        {
                            <div class="bracket-admin-btn" style="display:flex;gap:6px;justify-content:flex-end;">
                                @if (!tbd)
                                {
                                    <a href="#" class="btn-editar"
                                       onclick="abrirModalCopa(@partido.Id, '@partido.NombreLocal', '@partido.FlagLocal', '@partido.NombreVisitante', '@partido.FlagVisitante', @(partido.GolesLocal??0), @(partido.GolesVisitante??0)); return false;">
                                        @(partido.Jugado ? "editar" : "+ resultado")
                                    </a>
                                }
                                <a href="#" class="btn-editar" style="background:rgba(58,130,200,.2);color:#8aabcc;"
                                   onclick="abrirModalEditarBracket(@partido.Id, '@partido.NombreLocal', '@partido.NombreVisitante'); return false;">
                                    ✏️
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        @if (ronda != Model.Rondas.Last())
        {
            <div class="bracket-arrow">›</div>
        }
    }
</div>
</div>

<!-- MODAL -->
<div id="modal-overlay-copa" class="modal-overlay" onclick="cerrarModalCopa()" style="display:none"></div>
<div id="modal-copa" class="modal-resultado" style="display:none">
    <div class="modal-header">
        <h3>Resultado de Copa</h3>
        <button onclick="cerrarModalCopa()" class="modal-close">✕</button>
    </div>
    <div class="modal-body">
        <div class="form-partido-header">
            <div class="form-team-name">
                <img id="copa-flag-local" src="" class="flag-modal" style="display:none" alt="" />
                <div id="copa-local"></div>
            </div>
            <div class="form-vs">vs</div>
            <div class="form-team-name">
                <div id="copa-visitante"></div>
                <img id="copa-flag-visitante" src="" class="flag-modal" style="display:none" alt="" />
            </div>
        </div>
        <div class="score-inputs">
            <input type="number" id="copa-input-local" min="0" max="99" value="0" class="score-input" />
            <div class="score-sep">-</div>
            <input type="number" id="copa-input-visitante" min="0" max="99" value="0" class="score-input" />
        </div>
        <div style="display:flex;gap:12px;justify-content:center;margin-top:16px;">
            <button class="btn-primary" id="copa-btn-guardar" onclick="guardarResultadoCopa()">Guardar</button>
            <button class="btn-cancelar" onclick="cerrarModalCopa()">Cancelar</button>
        </div>
        <p id="copa-error" style="color:var(--color-red);font-size:13px;text-align:center;margin-top:8px;display:none"></p>
    </div>
</div>

<!-- MODAL EDITAR BRACKET -->
<div id="modal-overlay-edit-bracket" class="modal-overlay" onclick="cerrarModalEditarBracket()" style="display:none"></div>
<div id="modal-edit-bracket" class="modal-resultado" style="display:none">
    <div class="modal-header">
        <h3>Editar Participantes</h3>
        <button onclick="cerrarModalEditarBracket()" class="modal-close">✕</button>
    </div>
    <div class="modal-body">
        <input type="hidden" id="edit-bracket-id" />
        <p style="font-size:12px;color:var(--color-muted);margin-bottom:16px;">
            Local actual: <strong id="edit-local-actual"></strong> · 
            Visitante actual: <strong id="edit-visita-actual"></strong>
        </p>
        <div style="display:flex;gap:12px;align-items:center;margin-bottom:16px;flex-wrap:wrap;">
            <div style="flex:1;">
                <label style="font-size:11px;color:var(--color-muted);display:block;margin-bottom:4px;">Local</label>
                <select id="edit-sel-local" class="form-control"></select>
            </div>
            <div style="font-size:18px;color:var(--color-muted);padding-top:16px;">vs</div>
            <div style="flex:1;">
                <label style="font-size:11px;color:var(--color-muted);display:block;margin-bottom:4px;">Visitante</label>
                <select id="edit-sel-visita" class="form-control"></select>
            </div>
        </div>
        <div style="display:flex;gap:12px;justify-content:center;">
            <button class="btn-primary" onclick="guardarEditBracket()">Guardar</button>
            <button class="btn-cancelar" onclick="cerrarModalEditarBracket()">Cancelar</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
let copaPartidoActual = null;

function abrirModalCopa(id, local, flagL, visitante, flagV, gl, gv) {
    copaPartidoActual = id;
    document.getElementById('copa-local').textContent     = local;
    document.getElementById('copa-visitante').textContent = visitante;
    const fl = document.getElementById('copa-flag-local');
    const fv = document.getElementById('copa-flag-visitante');
    if (flagL) { fl.src = `https://flagcdn.com/32x24/${flagL}.png`; fl.style.display='inline'; } else fl.style.display='none';
    if (flagV) { fv.src = `https://flagcdn.com/32x24/${flagV}.png`; fv.style.display='inline'; } else fv.style.display='none';
    document.getElementById('copa-input-local').value     = gl;
    document.getElementById('copa-input-visitante').value = gv;
    document.getElementById('copa-error').style.display   = 'none';
    document.getElementById('modal-overlay-copa').style.display = 'block';
    document.getElementById('modal-copa').style.display         = 'block';
    document.getElementById('copa-input-local').focus();
    document.getElementById('copa-input-local').select();
}

function cerrarModalCopa() {
    document.getElementById('modal-overlay-copa').style.display = 'none';
    document.getElementById('modal-copa').style.display         = 'none';
    copaPartidoActual = null;
}

async function guardarResultadoCopa() {
    const gl = parseInt(document.getElementById('copa-input-local').value);
    const gv = parseInt(document.getElementById('copa-input-visitante').value);
    if (isNaN(gl) || isNaN(gv) || gl < 0 || gv < 0) {
        document.getElementById('copa-error').textContent = 'Valores inválidos.';
        document.getElementById('copa-error').style.display = 'block';
        return;
    }
    const btn = document.getElementById('copa-btn-guardar');
    btn.textContent = 'Guardando...'; btn.disabled = true;
    try {
        const r = await fetch('/Copas/GuardarResultadoCopa', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ partidoId: copaPartidoActual, golesLocal: gl, golesVisitante: gv })
        });
        const d = await r.json();
        if (d.ok) { cerrarModalCopa(); location.reload(); }
        else {
            document.getElementById('copa-error').textContent = 'Error al guardar.';
            document.getElementById('copa-error').style.display = 'block';
        }
    } catch {
        document.getElementById('copa-error').textContent = 'Error de conexión.';
        document.getElementById('copa-error').style.display = 'block';
    }
    btn.textContent = 'Guardar'; btn.disabled = false;
}

document.querySelectorAll('.check-ronda').forEach(chk => {
    chk.addEventListener('change', async function() {
        const rondaId   = this.dataset.rondaId;
        const habilitada = this.checked;
        const r = await fetch('/Copas/ToggleRonda', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rondaId: parseInt(rondaId), habilitada })
        });
        const d = await r.json();
        if (!d.ok) this.checked = !habilitada;
        else location.reload();
    });
});

// Modal editar bracket
let editBracketId = null;
function abrirModalEditarBracket(id, local, visitante) {
    editBracketId = id;
    document.getElementById('edit-bracket-id').value = id;
    document.getElementById('edit-local-actual').textContent  = local || 'Por definir';
    document.getElementById('edit-visita-actual').textContent = visitante || 'Por definir';
    // Cargar equipos en selects
    fetch('/Admin/GetEquiposTodos')
        .then(r => r.json())
        .then(equipos => {
            ['edit-sel-local','edit-sel-visita'].forEach(selId => {
                const sel = document.getElementById(selId);
                sel.innerHTML = '<option value="0">-- Por definir --</option>';
                equipos.forEach(e => {
                    const opt = document.createElement('option');
                    opt.value = e.id; opt.textContent = e.nombre;
                    sel.appendChild(opt);
                });
            });
        });
    document.getElementById('modal-overlay-edit-bracket').style.display = 'block';
    document.getElementById('modal-edit-bracket').style.display = 'block';
}
function cerrarModalEditarBracket() {
    document.getElementById('modal-overlay-edit-bracket').style.display = 'none';
    document.getElementById('modal-edit-bracket').style.display = 'none';
    editBracketId = null;
}
async function guardarEditBracket() {
    const id      = document.getElementById('edit-bracket-id').value;
    const localId = document.getElementById('edit-sel-local').value;
    const visitId = document.getElementById('edit-sel-visita').value;
    const r = await fetch('/Copas/EditarBracket', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ partidoId: parseInt(id), localId: parseInt(localId), visitanteId: parseInt(visitId) })
    });
    const d = await r.json();
    if (d.ok) { cerrarModalEditarBracket(); location.reload(); }
    else alert('Error al guardar.');
}

// Registrar título de copa (admin)
async function registrarTituloCopa(equipoId, nombreEquipo, tipoTitulo, nombreTitulo) {
    if (!confirm(`¿Registrar "${nombreTitulo}" para ${nombreEquipo} en el palmarés?`)) return;
    const r = await fetch('/Admin/RegistrarTituloCopa', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ equipoId, tipoTitulo, nombreTitulo })
    });
    const d = await r.json();
    if (d.ok) alert('✅ Título registrado en el palmarés.');
    else alert('Error al registrar.');
}

document.addEventListener('keydown', e => {
    if (e.key === 'Escape') cerrarModalCopa();
    if (e.key === 'Enter' && copaPartidoActual) guardarResultadoCopa();
});
</script>
}
