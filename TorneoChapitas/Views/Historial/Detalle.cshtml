            <div class="tabla-wrapper">
                <table class="tabla-posiciones">
                    <thead>
                        <tr><th>#</th><th>Equipo</th><th>PJ</th><th>V</th><th>D</th><th>DG</th><th>PTS</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.ResultadosNacionalB)
                        {
                            <tr class="@(r.Campeon ? "zona-campeon" : r.Descendio ? "zona-descenso" : r.Ascendio ? "zona-ascenso" : "")"
                                style="cursor:pointer;" onclick="window.location='/Equipos/Detalle/@r.EquipoId'">
                                <td class="col-pos">@r.Posicion</td>
                                <td class="col-equipo">
                                    @if (!string.IsNullOrEmpty(r.FlagCode))
                                    { <img src="https://flagcdn.com/20x15/@(r.FlagCode).png" class="flag-img" alt="" onerror="this.style.display='none'" /> }
                                    @r.NombreEquipo
                                    @if (r.Campeon)   { <span style="margin-left:4px;font-size:11px;">🏆</span> }
                                    @if (r.Ascendio)  { <span style="margin-left:4px;font-size:11px;color:var(--color-green);">⬆</span> }
                                    @if (r.Descendio) { <span style="margin-left:4px;font-size:11px;color:var(--color-red);">⬇</span> }
                                </td>
                                <td class="col-num">@r.PartidosJugados</td>
                                <td class="col-num" style="color:var(--color-green);">@r.Ganados</td>
                                <td class="col-num" style="color:var(--color-red);">@r.Perdidos</td>
                                <td class="col-num">@(r.GolesFavor - r.GolesContra > 0 ? "+" : "")@(r.GolesFavor - r.GolesContra)</td>
                                <td class="col-pts" style="color:var(--color-gold);font-weight:700;">@r.Puntos</td>
                            </tr>
