@model TorneoAmigos.Models.DivisionViewModel
@{
    var esPrimera = Model.Division?.Id == 1;
    var controller = esPrimera ? "PrimeraDivision" : "NacionalB";
    var icono = esPrimera ? "🏆" : "🥈";
}
<div class="division-widget">
    <div class="widget-header">
        <span class="widget-title">@icono @Model.Division?.Nombre</span>
        <a asp-controller="@controller" asp-action="Posiciones" class="widget-link">Ver completa →</a>
    </div>
    <div class="tabla-wrapper">
        <table class="tabla-posiciones">
            <thead>
                <tr><th>#</th><th>Equipo</th><th>PJ</th><th>DIF</th><th>PTS</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var f in Model.TablaPosiciones)
                {
                    <tr class="zona-@f.Zona">
                        <td class="col-pos">@f.Posicion</td>
                        <td>
                            <a asp-controller="Equipos" asp-action="Detalle" asp-route-id="@f.EquipoId"
                               style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:6px;">
                            @if (!string.IsNullOrEmpty(f.FlagCode))
                            {
                                <img src="https://flagcdn.com/16x12/@(f.FlagCode).png"
                                     class="flag-sm" alt="" onerror="this.style.display='none'" />
                            }
                            @f.NombreEquipo
                            </a>
                        </td>
                        <td class="col-num">@f.PartidosJugados</td>
                        <td class="@(f.DiferenciaGoles > 0 ? "col-dif-pos" : f.DiferenciaGoles < 0 ? "col-dif-neg" : "col-dif-neu")">
                            @(f.DiferenciaGoles > 0 ? "+" : "")@f.DiferenciaGoles
                        </td>
                        <td class="col-pts">@f.Puntos</td>
                        <td style="padding:2px 4px;">
                            <div style="display:flex;gap:2px;">
                                @foreach (var r in f.Forma)
                                {
                                    <span style="width:14px;height:14px;border-radius:2px;display:inline-flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;background:@(r=="V" ? "var(--color-green)" : "var(--color-red)");color:#fff;">@r</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
