@model Noticia
@using TorneoAmigos.Models
@{
    ViewBag.Title = Model.Titulo;
    ViewBag.ActivePage = "noticias";
    var comentarios = ViewBag.Comentarios as List<Comentario> ?? new List<Comentario>();
    var esAdmin = User.IsInRole("Admin");
    var banderas = new Dictionary<string,string> {
        {"nl","🇳🇱"},{"dk","🇩🇰"},{"cr","🇨🇷"},{"it","🇮🇹"},{"us","🇺🇲"},
        {"ir","🇮🇷"},{"gb-wls","🏴󠁧󠁢󠁷󠁬󠁳󠁿"},{"be","🇧🇪"},{"ua","🇺🇦"},{"de","🇩🇪"},
        {"kr","🇰🇷"},{"ec","🇪🇨"},{"br","🇧🇷"},{"es","🇪🇸"},{"vn","🇻🇳"},
        {"co","🇨🇴"},{"ar","🇦🇷"},{"uy","🇺🇾"},{"ph","🇵🇭"},
        {"pl","🇵🇱"},{"se","🇸🇪"},{"sa","🇸🇦"},{"ma","🇲🇦"},{"jp","🇯🇵"},{"gb-eng","🏴󠁧󠁢󠁥󠁮󠁧󠁿"}
    };
}

<div style="max-width:760px;margin:0 auto;">
    <a asp-action="Index" style="display:inline-block;color:var(--color-muted);font-size:13px;margin:24px 0 20px;">
        ← Volver a noticias
    </a>
    <span class="noticia-badge @(Model.Tipo == "automatica" ? "badge-auto" : "badge-manual")"
          style="margin-bottom:16px;display:inline-block;">
        @(Model.Tipo == "automatica" ? "⚡ Generada automáticamente" : "✍️ Redacción")
    </span>

    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:12px;">
        <h1 style="font-family:var(--font-heading);font-size:28px;font-weight:700;color:var(--color-text);letter-spacing:1px;line-height:1.3;flex:1;">
            @Model.Titulo
        </h1>
        <button id="btn-compartir"
                style="flex-shrink:0;margin-top:4px;background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;padding:8px 14px;color:var(--color-muted);font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px;transition:border-color .15s;"
                onclick="compartirNoticia()">
            📤 <span id="btn-compartir-texto">Compartir</span>
        </button>
    </div>

    <div style="font-size:13px;color:var(--color-muted);margin-bottom:24px;">
        📅 @Model.CreatedAt.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-AR"))
        · ✍️ @Model.Autor
    </div>

    @if (!string.IsNullOrEmpty(Model.ImagenUrl))
    {
        <div id="img-wrapper" style="margin-bottom:28px;border-radius:12px;overflow:hidden;background:var(--color-bg2);border:1px solid var(--color-border);min-height:160px;display:flex;align-items:center;justify-content:center;">
            <div id="img-loader" style="text-align:center;padding:32px;color:var(--color-muted);">
                <div style="font-size:28px;margin-bottom:8px;">⚽</div>
                <p style="font-size:12px;">Cargando imagen...</p>
            </div>
            @if (Model.ImagenUrl.StartsWith("data:"))
            {
                <img id="noticia-img" src="/Noticias/Imagen/@Model.Id" alt="@Model.Titulo"
                     style="display:none;width:100%;max-height:420px;object-fit:cover;" />
            }
            else
            {
                <img id="noticia-img" src="@Model.ImagenUrl" alt="@Model.Titulo"
                     style="display:none;width:100%;max-height:420px;object-fit:cover;" />
            }
        </div>
    }

    <!-- Contenido con formato enriquecido -->
    <div id="noticia-contenido" style="font-size:16px;line-height:1.9;color:var(--color-text);margin-bottom:40px;"></div>

    <!-- COMENTARIOS -->
    <div style="border-top:1px solid var(--color-border);padding-top:28px;">
        <h3 style="font-family:var(--font-heading);font-size:15px;letter-spacing:2px;text-transform:uppercase;color:var(--color-gold);margin-bottom:20px;">
            💬 Comentarios (@comentarios.Count)
        </h3>
        @if (!comentarios.Any())
        {
            <p style="color:var(--color-muted);font-size:14px;margin-bottom:24px;">Sé el primero en comentar.</p>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:28px;">
                @foreach (var c in comentarios)
                {
                    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:10px;padding:14px 18px;">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                            @if (!string.IsNullOrEmpty(c.PaisFlag) && banderas.ContainsKey(c.PaisFlag))
                            {
                                var flagSrc = (c.PaisFlag == "gb-eng" || c.PaisFlag == "gb-wls" || c.PaisFlag == "gb-sct")
                                    ? "https://flagcdn.com/20x15/gb.png"
                                    : $"https://flagcdn.com/20x15/{c.PaisFlag}.png";
                                <img src="@flagSrc" class="flag-img" alt="" onerror="this.style.display='none'" />
                            }
                            <strong style="font-size:14px;color:var(--color-text);">@c.Autor</strong>
                            <span style="font-size:11px;color:var(--color-muted);margin-left:auto;">
                                @c.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </span>
                            @if (esAdmin)
                            {
                                <form method="post" asp-action="EliminarComentario" style="display:inline;margin-left:4px;">
                                    <input type="hidden" name="comentarioId" value="@c.Id" />
                                    <input type="hidden" name="noticiaId" value="@Model.Id" />
                                    <button type="submit" style="background:none;border:none;color:var(--color-red);cursor:pointer;font-size:13px;padding:0;" onclick="return confirm('¿Eliminar?')">✕</button>
                                </form>
                            }
                        </div>
                        <p style="font-size:14px;color:var(--color-text);line-height:1.6;margin:0;">@c.Contenido</p>
                    </div>
                }
            </div>
        }
        <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:20px;">
            <h4 style="font-family:var(--font-heading);font-size:13px;letter-spacing:1px;color:var(--color-muted);text-transform:uppercase;margin-bottom:16px;">
                Dejá tu comentario
            </h4>
            <form method="post" asp-action="AgregarComentario" asp-route-id="@Model.Id">
                <div style="display:flex;gap:10px;margin-bottom:12px;flex-wrap:wrap;">
                    <div style="flex:1;min-width:150px;">
                        <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:4px;">Tu nombre</label>
                        <input type="text" name="autor" required maxlength="50" class="form-control" placeholder="Ej: Nahuel" />
                    </div>
                    <div style="width:160px;">
                        <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:4px;">Tu país</label>
                        <select name="paisFlag" class="form-control">
                            <option value="">-- Sin bandera --</option>
                            <option value="ar">🇦🇷 Argentina</option>
                            <option value="uy">🇺🇾 Uruguay</option>
                            <option value="br">🇧🇷 Brasil</option>
                            <option value="co">🇨🇴 Colombia</option>
                            <option value="es">🇪🇸 España</option>
                            <option value="de">🇩🇪 Alemania</option>
                            <option value="it">🇮🇹 Italia</option>
                            <option value="fr">🇫🇷 Francia</option>
                            <option value="gb-eng">🏴󠁧󠁢󠁥󠁮󠁧󠁿 Inglaterra</option>
                            <option value="gb-wls">🏴󠁧󠁢󠁷󠁬󠁳󠁿 Gales</option>
                            <option value="nl">🇳🇱 Países Bajos</option>
                            <option value="be">🇧🇪 Bélgica</option>
                            <option value="pt">🇵🇹 Portugal</option>
                            <option value="us">🇺🇲 USA</option>
                            <option value="mx">🇲🇽 México</option>
                            <option value="jp">🇯🇵 Japón</option>
                            <option value="kr">🇰🇷 Corea</option>
                            <option value="ma">🇲🇦 Marruecos</option>
                            <option value="sa">🇸🇦 Arabia Saudita</option>
                            <option value="ua">🇺🇦 Ucrania</option>
                            <option value="pl">🇵🇱 Polonia</option>
                            <option value="se">🇸🇪 Suecia</option>
                            <option value="dk">🇩🇰 Dinamarca</option>
                            <option value="ph">🇵🇭 Filipinas</option>
                            <option value="vn">🇻🇳 Vietnam</option>
                            <option value="ec">🇪🇨 Ecuador</option>
                            <option value="cr">🇨🇷 Costa Rica</option>
                            <option value="ir">🇮🇷 Irán</option>
                        </select>
                    </div>
                </div>
                <div style="margin-bottom:12px;">
                    <label style="font-size:11px;color:var(--color-muted);letter-spacing:1px;display:block;margin-bottom:4px;">Comentario</label>
                    <textarea name="contenido" required maxlength="500" rows="3" class="form-control" placeholder="Máx. 500 caracteres..."></textarea>
                </div>
                <button type="submit" class="btn-primary" style="font-size:13px;padding:10px 20px;">
                    Publicar comentario
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ── Imagen ────────────────────────────────────────────────────
document.addEventListener("DOMContentLoaded", function () {
    const img = document.getElementById("noticia-img");
    if (img) {
        const loader  = document.getElementById("img-loader");
        const wrapper = document.getElementById("img-wrapper");
        function mostrarImagen() {
            if (loader)  loader.style.display = "none";
            img.style.display = "block";
            if (wrapper) wrapper.style.minHeight = "auto";
        }
        function mostrarError() {
            if (loader) loader.innerHTML = '<p style="font-size:12px;color:var(--color-muted);">No se pudo cargar la imagen.</p>';
            img.style.display = "none";
        }
        img.addEventListener("load",  mostrarImagen);
        img.addEventListener("error", mostrarError);
        if (img.complete && img.naturalWidth > 0) mostrarImagen();
        setTimeout(function() { if (!img.complete || img.naturalWidth === 0) mostrarError(); }, 15000);
    }

    // ── Formato enriquecido ───────────────────────────────────
    const contenido = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Contenido ?? ""));
    const el = document.getElementById('noticia-contenido');
    if (el) el.innerHTML = formatearTexto(contenido);
});

function formatearTexto(texto) {
    // Escapar HTML primero para seguridad
    const esc = texto
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');

    // Procesar línea por línea
    const lineas = esc.split('\n');
    const html = lineas.map(linea => {
        // # Título grande
        if (/^#{1}\s+/.test(linea)) {
            const t = linea.replace(/^#+\s+/, '');
            return `<h2 style="font-family:var(--font-heading);font-size:22px;color:var(--color-gold);margin:24px 0 8px;letter-spacing:1px;">${aplicarInline(t)}</h2>`;
        }
        // ## Título mediano
        if (/^#{2}\s+/.test(linea)) {
            const t = linea.replace(/^#+\s+/, '');
            return `<h3 style="font-family:var(--font-heading);font-size:17px;color:var(--color-text);margin:20px 0 6px;">${aplicarInline(t)}</h3>`;
        }
        // Línea vacía → separador
        if (linea.trim() === '') return '<div style="height:10px"></div>';
        // Párrafo normal
        return `<p style="margin:0 0 4px;">${aplicarInline(linea)}</p>`;
    }).join('');

    return html;
}

function aplicarInline(t) {
    return t
        // **negrita**
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        // *itálica* (solo si no es **)
        .replace(/\*([^*]+?)\*/g, '<em>$1</em>')
        // __subrayado__
        .replace(/__(.+?)__/g, '<u>$1</u>')
        // ~~tachado~~
        .replace(/~~(.+?)~~/g, '<s>$1</s>');
}

// ── Compartir ─────────────────────────────────────────────────
async function compartirNoticia() {
    const titulo = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Titulo));
    const url    = window.location.href;
    const btn    = document.getElementById('btn-compartir-texto');
    if (navigator.share) {
        try { await navigator.share({ title: titulo, text: "📰 " + titulo, url }); } catch(e) {}
        return;
    }
    try {
        await navigator.clipboard.writeText("📰 " + titulo + "\n" + url);
        btn.textContent = '¡Copiado!';
        setTimeout(() => btn.textContent = 'Compartir', 2000);
    } catch(e) {
        const ta = document.createElement('textarea');
        ta.value = "📰 " + titulo + "\n" + url;
        ta.style.cssText = 'position:fixed;opacity:0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        btn.textContent = '¡Copiado!';
        setTimeout(() => btn.textContent = 'Compartir', 2000);
    }
}
</script>
}
