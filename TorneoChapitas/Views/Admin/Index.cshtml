@section Scripts {
<style>
.toggle-switch {
    width: 48px; height: 26px; border-radius: 13px;
    background: var(--color-border); position: relative;
    cursor: pointer; transition: background .25s;
}
.toggle-switch.on { background: var(--color-gold); }
.toggle-knob {
    width: 20px; height: 20px; border-radius: 50%;
    background: #fff; position: absolute;
    top: 3px; left: 3px; transition: left .25s;
}
.toggle-switch.on .toggle-knob { left: 25px; }
</style>
<script>
// ── ENCUESTA ────────────────────────────────────────
function agregarOpcion() {
    const list = document.getElementById('enc-opciones-list');
    const n = list.querySelectorAll('.enc-opcion').length + 1;
    const inp = document.createElement('input');
    inp.type = 'text'; inp.className = 'enc-opcion form-control';
    inp.placeholder = `Opción ${n}`; inp.style.fontSize = '13px';
    list.appendChild(inp);
}

async function crearEncuestaManual() {
    const msg = document.getElementById('msg-enc-crear');
    const pregunta = document.getElementById('enc-pregunta').value.trim();
    const maxVotos = parseInt(document.getElementById('enc-maxvotos').value) || 1;
    const opciones = [...document.querySelectorAll('#enc-opciones-list .enc-opcion')]
        .map(i => i.value.trim()).filter(v => v.length > 0);
    if (!pregunta || opciones.length < 2) {
        msg.style.display = 'block'; msg.style.color = 'var(--color-red)';
        msg.textContent = 'Completá la pregunta y al menos 2 opciones.';
        return;
    }
    const r = await fetch('/Encuestas/CrearManual', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pregunta, maxVotos, opciones })
    });
    const d = await r.json();
    if (d.ok) location.reload();
    else { msg.style.display='block'; msg.style.color='var(--color-red)'; msg.textContent='Error al crear.'; }
}

async function toggleEncuesta(id, activa) {
    const idx = row.dataset.index;
    row.innerHTML = '';

    // Hidden input para el texto final
    const hidden = document.createElement('input');
    hidden.type = 'hidden'; hidden.className = 'enc-opcion-texto'; hidden.value = '';
    row.appendChild(hidden);

    // Trigger button
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'form-control';
    btn.style.cssText = 'flex:1;font-size:12px;text-align:left;display:flex;align-items:center;gap:8px;cursor:pointer;background:var(--color-bg3);border:1px solid var(--color-border);';
    btn.innerHTML = '<span class="dd-flag" style="font-size:14px;"></span><span class="dd-nombre" style="flex:1;">-- Texto libre --</span><span>▾</span>';
    row.appendChild(btn);

    // Text input for free text
    const txt = document.createElement('input');
    txt.type = 'text'; txt.placeholder = 'o escribí texto libre...';
    txt.className = 'form-control'; txt.style.cssText = 'flex:1;font-size:12px;display:none;';
    txt.addEventListener('input', () => { hidden.value = txt.value; });
    row.appendChild(txt);

    // Dropdown list
    const list = document.createElement('div');
    list.style.cssText = 'position:absolute;z-index:999;background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;max-height:220px;overflow-y:auto;min-width:220px;box-shadow:0 4px 20px rgba(0,0,0,.4);';
    list.style.display = 'none';
    document.body.appendChild(list);

    function buildList() {
        list.innerHTML = '';
        encEquipos.forEach(eq => {
            const item = document.createElement('div');
            item.style.cssText = 'padding:8px 12px;cursor:pointer;display:flex;align-items:center;gap:8px;font-size:13px;';
            item.onmouseenter = () => item.style.background = 'var(--color-bg3)';
            item.onmouseleave = () => item.style.background = '';
            if (eq.flag) {
                const img = document.createElement('img');
                img.src = `https://flagcdn.com/20x15/${eq.flag}.png`;
                img.style.cssText = 'width:20px;height:15px;border-radius:2px;';
                img.onerror = () => img.style.display = 'none';
                item.appendChild(img);
            } else {
                const sp = document.createElement('span'); sp.style.width = '20px'; item.appendChild(sp);
            }
            const name = document.createElement('span'); name.textContent = eq.nombre; item.appendChild(name);
            item.onclick = () => {
                if (!eq.id) {
                    // Text libre
                    btn.style.display = 'none';
                    txt.style.display = 'block';
                    txt.focus();
                    hidden.value = txt.value;
                } else {
                    btn.style.display = 'flex';
                    txt.style.display = 'none';
                    btn.querySelector('.dd-nombre').textContent = eq.nombre;
                    if (eq.flag) {
                        btn.querySelector('.dd-flag').innerHTML = `<img src="https://flagcdn.com/20x15/${eq.flag}.png" style="width:20px;height:15px;border-radius:2px;" onerror="this.style.display='none'" />`;
                    } else {
                        btn.querySelector('.dd-flag').innerHTML = '';
                    }
                    hidden.value = eq.nombre;
                }
                list.style.display = 'none';
            };
            list.appendChild(item);
        });
    }

    btn.onclick = (e) => {
        e.stopPropagation();
        buildList();
        const rect = btn.getBoundingClientRect();
        list.style.top  = (rect.bottom + window.scrollY) + 'px';
        list.style.left = rect.left + 'px';
        list.style.width = rect.width + 'px';
        list.style.display = list.style.display === 'none' ? 'block' : 'none';
    };
    document.addEventListener('click', () => list.style.display = 'none');
}

function agregarOpcion() {
    const list = document.getElementById('enc-opciones-list');
    const n = list.querySelectorAll('.enc-opcion-row').length;
    const div = document.createElement('div');
    div.className = 'enc-opcion-row';
    div.style.cssText = 'display:flex;gap:6px;align-items:center;position:relative;';
    div.dataset.index = n;
    list.appendChild(div);
    crearDropdownEquipo(div);
}

function initEncuestaDropdowns() {
    document.querySelectorAll('.enc-opcion-row').forEach(row => {
        row.style.position = 'relative';
        crearDropdownEquipo(row);
    });
}

async function crearEncuestaManual() {
    const msg = document.getElementById('msg-enc-crear');
    const pregunta = document.getElementById('enc-pregunta').value.trim();
    const maxVotos = parseInt(document.getElementById('enc-maxvotos').value) || 1;
    const opciones = [];
    document.querySelectorAll('#enc-opciones-list .enc-opcion-row').forEach(row => {
        // Try all inputs in the row, pick first non-empty value
        const inputs = row.querySelectorAll('input');
        let val = '';
        inputs.forEach(inp => { if (!val && inp.value.trim()) val = inp.value.trim(); });
        if (val) opciones.push(val);
    });
    if (!pregunta || opciones.length < 2) {
        msg.style.display='block'; msg.style.color='var(--color-red)';
        msg.textContent='Completá la pregunta y al menos 2 opciones.'; return;
    }
    const r = await fetch('/Encuestas/CrearManual', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pregunta, maxVotos, opciones })
    });
    const d = await r.json();
    if (d.ok) location.reload();
    else { msg.style.display='block'; msg.style.color='var(--color-red)'; msg.textContent='Error al crear.'; }
}

document.addEventListener('DOMContentLoaded', initEncuestaDropdowns);

async function toggleEncuesta(id, activa) {
    await fetch(`/Encuestas/Toggle?id=${id}&activa=${activa}`, { method: 'POST' });
    location.reload();
}

async function eliminarEncuesta(id) {
    if (!confirm('¿Eliminar esta encuesta y todos sus votos?')) return;
    await fetch('/Encuestas/Eliminar?id=' + id, { method: 'POST' });
    location.reload();
}

function agregarOpcion() {
    const list = document.getElementById('enc-opciones-list');
    const n = list.children.length + 1;
    const inp = document.createElement('input');
    inp.type = 'text'; inp.placeholder = `Opción ${n}`;
    inp.className = 'enc-opcion form-control'; inp.style.fontSize = '13px';
    list.appendChild(inp);
}

async function crearEncuestaManual() {
    const msg = document.getElementById('msg-enc-crear');
    const pregunta = document.getElementById('enc-pregunta').value.trim();
    const maxVotos = parseInt(document.getElementById('enc-maxvotos').value);
    const opciones = [...document.querySelectorAll('.enc-opcion')].map(i => i.value.trim()).filter(Boolean);
    if (!pregunta || opciones.length < 2) { msg.style.display='block'; msg.style.color='var(--color-red)'; msg.textContent='Completá la pregunta y al menos 2 opciones.'; return; }
    const r = await fetch('/Encuestas/CrearManual', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pregunta, maxVotos, opciones })
    });
    const d = await r.json();
    if (d.ok) location.reload();
    else { msg.style.display='block'; msg.style.color='var(--color-red)'; msg.textContent='Error al crear.'; }
}

async function generarReducido() {
    const msg = document.getElementById('msg-reducido');
    if (!confirm('¿Generar las semifinales del reducido con las posiciones actuales?')) return;
    const r = await fetch('/Admin/GenerarReducido', { method: 'POST' });
    const d = await r.json();
    msg.style.display = 'block';
    msg.style.color = d.ok ? 'var(--color-green)' : 'var(--color-red)';
    msg.textContent = d.msg;
    if (d.ok) setTimeout(() => location.reload(), 1500);
}

async function generarFinalReducido() {
    const local = parseInt(document.getElementById('sel-final-local').value);
    const visit = parseInt(document.getElementById('sel-final-visit').value);
    const msg = document.getElementById('msg-reducido');
    if (!local || !visit || local === visit) { msg.style.display='block'; msg.style.color='var(--color-red)'; msg.textContent='Elegí dos equipos distintos.'; return; }
    const r = await fetch('/Admin/GenerarFinalReducido', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ local, visitante: visit })
    });
    const d = await r.json();
    msg.style.display = 'block';
    msg.style.color = d.ok ? 'var(--color-green)' : 'var(--color-red)';
    msg.textContent = d.ok ? '✅ Final del reducido generada.' : '⚠️ Error al generar.';
    if (d.ok) setTimeout(() => location.reload(), 1500);
}

async function generarPromocion() {
    const local = parseInt(document.getElementById('sel-prom-local').value);
    const visit = parseInt(document.getElementById('sel-prom-visit').value);
    const msg = document.getElementById('msg-reducido');
    if (!local || !visit || local === visit) { msg.style.display='block'; msg.style.color='var(--color-red)'; msg.textContent='Elegí dos equipos distintos.'; return; }
    const r = await fetch('/Admin/GenerarPromocion', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ local, visitante: visit })
    });
    const d = await r.json();
    msg.style.display = 'block';
    msg.style.color = d.ok ? 'var(--color-green)' : 'var(--color-red)';
    msg.textContent = d.ok ? '✅ Partido de promoción generado.' : '⚠️ Error al generar.';
    if (d.ok) setTimeout(() => location.reload(), 1500);
}

async function regenerarFixture() {
    const msg = document.getElementById('msg-borrar-fixture');
    if (!confirm('¿Regenerar el fixture con los equipos actuales?\nSolo funciona si no hay partidos jugados.')) return;
    const r = await fetch('/Admin/RegenerarFixture', { method: 'POST' });
    const d = await r.json();
    msg.style.display = 'block';
    msg.style.color = d.ok ? 'var(--color-green)' : 'var(--color-red)';
    msg.textContent = d.msg;
    if (d.ok) setTimeout(() => location.reload(), 1500);
}

async function togglePrimeraC(el) {
    const activa = !el.classList.contains('on');
    const r = await fetch('/Admin/TogglePrimeraC', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ activa })
    });
    const d = await r.json();
    if (d.ok) location.reload();
}

async function retirarJugador() {
    const id = document.getElementById('sel-retirar').value;
    const msg = document.getElementById('msg-retirar');
    if (!id) { msg.style.display='block'; msg.style.color='var(--color-red)'; msg.textContent='Elegí un jugador.'; return; }
    if (!confirm('¿Retirar este jugador? Sus estadísticas se conservan.')) return;
    const r = await fetch('/Admin/RetirarJugador?id=' + id, { method: 'POST' });
    const d = await r.json();
    msg.style.display='block'; msg.style.color=d.ok?'var(--color-green)':'var(--color-red)';
    msg.textContent = d.ok ? '✅ Jugador retirado.' : '⚠️ Error.';
    if (d.ok) setTimeout(() => location.reload(), 1000);
}

async function reactivarJugador() {
    const id = document.getElementById('sel-reactivar')?.value;
    const msg = document.getElementById('msg-reactivar');
    if (!id) return;
    const r = await fetch('/Admin/ReactivarJugador?id=' + id, { method: 'POST' });
    const d = await r.json();
    msg.style.display='block'; msg.style.color=d.ok?'var(--color-green)':'var(--color-red)';
    msg.textContent = d.ok ? '✅ Jugador reactivado.' : '⚠️ Error.';
    if (d.ok) setTimeout(() => location.reload(), 1000);
}

async function borrarFixture() {
    if (!confirm('¿Borrar el fixture completo?\nSolo funciona si no hay partidos jugados.')) return;
    const msg = document.getElementById('msg-borrar-fixture');
    const r = await fetch('/Admin/BorrarFixture', { method: 'POST' });
    const d = await r.json();
    msg.style.display = 'block';
    msg.style.color = d.ok ? 'var(--color-green)' : 'var(--color-red)';
    msg.textContent = d.msg;
    if (d.ok) setTimeout(() => location.reload(), 1500);
}

async function guardarConfigTemporada() {
    const msg = document.getElementById('msg-config');
    const data = {
        cantDescensos:       parseInt(document.getElementById('cfg-descensos').value),
        cantAscensos:        parseInt(document.getElementById('cfg-ascensos').value),
        tienePromocion:      document.getElementById('cfg-promocion').checked,
        posPromocionPrimera: parseInt(document.getElementById('cfg-pos-primera')?.value || 8),
        posPromocionB:       parseInt(document.getElementById('cfg-pos-b')?.value || 3)
    };
    const r = await fetch('/Admin/ActualizarConfigTemporada', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });
    const d = await r.json();
    msg.style.display = 'block';
    msg.style.color = d.ok ? 'var(--color-green)' : 'var(--color-red)';
    msg.textContent = d.ok ? '✅ Configuración guardada.' : '⚠️ Error al guardar.';
}

// Sin descensos toggle
document.getElementById('chk-sin-descensos').addEventListener('change', function() {
    document.getElementById('seccion-descensos').style.display = this.checked ? 'none' : '';
});

async function guardarCierre() {
    const msg = document.getElementById('msg-cierre');
    const data = {
        campeonCopaId:      parseInt(document.getElementById('sel-campeon-copa').value) || 0,
        campeonSupercopaId: parseInt(document.getElementById('sel-campeon-supercopa').value) || 0,
        campeonPrimeraId:   parseInt(document.getElementById('sel-campeon-primera').value) || 0,
        campeonBId:         parseInt(document.getElementById('sel-campeon-b').value) || 0,
        ascenso1Id:         parseInt(document.getElementById('sel-ascenso-1').value) || 0,
        ascenso2Id:         parseInt(document.getElementById('sel-ascenso-2').value) || 0,
        ascenso3Id:         parseInt(document.getElementById('sel-ascenso-3').value) || 0,
        descenso1Id:        parseInt(document.getElementById('sel-descenso-1').value) || 0,
        descenso2Id:        parseInt(document.getElementById('sel-descenso-2').value) || 0,
        descensoPromoId:    parseInt(document.getElementById('sel-descenso-promo').value) || 0,
        campeonCId:         parseInt(document.getElementById('sel-campeon-c')?.value  || 0) || 0,
        ascensoCId1:        parseInt(document.getElementById('sel-ascenso-c1')?.value || 0) || 0,
        ascensoCId2:        parseInt(document.getElementById('sel-ascenso-c2')?.value || 0) || 0,
        descensoB1Id:       parseInt(document.getElementById('sel-descenso-b1')?.value || 0) || 0,
        descensoB2Id:       parseInt(document.getElementById('sel-descenso-b2')?.value || 0) || 0,
        sinDescensos:       document.getElementById('chk-sin-descensos').checked
    };

    const r = await fetch('/Admin/GuardarCierre', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    });
    const d = await r.json();
    msg.style.display = 'block';
    msg.style.color = d.ok ? 'var(--color-green)' : 'var(--color-red)';
    msg.textContent = d.ok ? '✅ Borrador guardado correctamente.' : '⚠️ Error al guardar.';
    if (d.ok) setTimeout(() => location.reload(), 1000);
}

async function confirmarFinalizar() {
    if (!confirm('¿Finalizar la temporada? Esta acción no se puede deshacer.\n\nSe usarán los datos del borrador guardado.')) return;

    const r = await fetch('/Admin/FinalizarTemporada', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sinDescensos: document.getElementById('chk-sin-descensos').checked })
    });
    const d = await r.json();
    if (d.ok) { alert('✅ Temporada finalizada correctamente.'); location.reload(); }
    else alert('Error: ' + d.msg);
}
</script>
