@model HomeViewModel
@{
    ViewBag.Title = "Inicio";
    ViewBag.ActivePage = "home";
}

<!-- HERO -->
<div class="home-hero">
    <div class="home-hero-content">
        <div class="home-hero-badge">
            <img src="~/img/aac-logo.png" alt="AAC"
                 style="width:76px;height:76px;border-radius:50%;object-fit:cover;" />
        </div>
        <div class="home-hero-text">
            <h1>TORNEO <span>CHAPITAS</span></h1>
            <p>Organización: <span>AAC</span> · Asociación Argentina de Chapitas</p>
        </div>
    </div>
    <div class="home-hero-ball"></div>
</div>

<!-- STATS -->
<div class="stats-bar">
    <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-info">
            <div class="stat-label">Partidos jugados</div>
            <div class="stat-value">@Model.TotalPartidosJugados</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">⚽</div>
        <div class="stat-info">
            <div class="stat-label">Goles totales</div>
            <div class="stat-value">@Model.TotalGoles</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-info">
            <div class="stat-label">Equipos</div>
            <div class="stat-value">@(Model.PrimeraDivision.Equipos.Count + Model.NacionalB.Equipos.Count + (Model.PrimeraC?.Equipos.Count ?? 0))</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">🏆</div>
        <div class="stat-info">
            <div class="stat-label">Divisiones</div>
            <div class="stat-value">@(ViewBag.PrimeraCActiva == true ? 3 : 2)</div>
        </div>
    </div>
</div>

<!-- CARRUSEL DE NOTICIAS -->
@if (Model.UltimasNoticias.Any())
{
    <div class="carrusel-section">
        <div class="carrusel-header">
            <h2 class="carrusel-titulo">📰 Últimas Noticias</h2>
            <a asp-controller="Noticias" asp-action="Index" class="carrusel-ver-mas">Ver todas →</a>
        </div>
        <div class="carrusel-wrapper">
            <button class="carrusel-btn carrusel-prev" onclick="moverCarrusel(-1)">‹</button>
            <div class="carrusel-track-outer">
                <div class="carrusel-track" id="carruselTrack">
                    @foreach (var n in Model.UltimasNoticias)
                    {
                        <div class="carrusel-slide">
                            <a asp-controller="Noticias" asp-action="Detalle" asp-route-id="@n.Id"
                               class="carrusel-slide-inner">
                                <div class="carrusel-img"
                                     style="@(!string.IsNullOrEmpty(n.ImagenUrl) && n.ImagenUrl != "HAS_IMAGE" ? $"background-image:url(\'{n.ImagenUrl}\')" : "background-color:var(--color-bg3);display:flex;align-items:center;justify-content:center")">
                                    @if (string.IsNullOrEmpty(n.ImagenUrl) || n.ImagenUrl == "HAS_IMAGE") { <span style="font-size:28px;">📰</span> }
                                </div>
                                <div class="carrusel-body">
                                    <span class="noticia-badge @(n.Tipo == "automatica" ? "badge-auto" : "badge-manual")" style="font-size:10px;">
                                        @(n.Tipo == "automatica" ? "⚡ Auto" : "✍️")
                                    </span>
                                    <h3 class="carrusel-noticia-titulo">@n.Titulo</h3>
                                    <p class="carrusel-noticia-fecha">@n.CreatedAt.ToString("dd/MM/yyyy")</p>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
            <button class="carrusel-btn carrusel-next" onclick="moverCarrusel(1)">›</button>
        </div>
        <div class="carrusel-dots" id="carruselDots"></div>
    </div>
}

<!-- MINI TABLAS -->
<div class="home-sections">
    @await Html.PartialAsync("_MiniTabla", Model.PrimeraDivision)
    @await Html.PartialAsync("_MiniTabla", Model.NacionalB)
    @if (ViewBag.PrimeraCActiva == true && Model.PrimeraC != null && Model.PrimeraC.Equipos.Any())
    {
        @await Html.PartialAsync("_MiniTabla", Model.PrimeraC)
    }
</div>

@{
    var encuestas   = ViewBag.Encuestas   as List<Encuesta>          ?? new();
    var banderas    = new Dictionary<string,string> {
        {"nl","🇳🇱"},{"dk","🇩🇰"},{"cr","🇨🇷"},{"it","🇮🇹"},{"us","🇺🇲"},
        {"ir","🇮🇷"},{"gb-wls","🏴"},{"be","🇧🇪"},{"ua","🇺🇦"},{"de","🇩🇪"},
        {"kr","🇰🇷"},{"ec","🇪🇨"},{"br","🇧🇷"},{"es","🇪🇸"},{"vn","🇻🇳"},
        {"co","🇨🇴"},{"ar","🇦🇷"},{"uy","🇺🇾"},{"ph","🇵🇭"},
        {"pl","🇵🇱"},{"se","🇸🇪"},{"sa","🇸🇦"},{"ma","🇲🇦"},{"jp","🇯🇵"},
        {"gb-eng","🏴"},{"pt","🇵🇹"},{"tr","🇹🇷"},{"ng","🇳🇬"}
    };
}

<!-- ENCUESTAS + RANKING FIFA -->
<div style="max-width:960px;margin:32px auto 0;padding:0 16px;">
<div style="display:grid;grid-template-columns:1fr;gap:24px;" id="enc-ranking-grid">
<style>#enc-ranking-grid{grid-template-columns:1fr;}@@media(min-width:700px){#enc-ranking-grid{grid-template-columns:1fr 1fr;}}</style>

    <!-- ENCUESTAS -->
    <div>
        @if (encuestas.Any())
        {
            <h2 style="font-family:var(--font-heading);font-size:13px;letter-spacing:3px;color:var(--color-gold);text-transform:uppercase;margin-bottom:16px;">🗳️ Encuestas</h2>
            <div style="display:flex;flex-direction:column;gap:16px;">
                @foreach (var enc in encuestas)
                {
                    <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:12px;padding:18px;" id="enc-@enc.Id">
                        <div style="font-size:13px;font-weight:600;color:var(--color-text);margin-bottom:12px;">@enc.Pregunta</div>
                        @if (enc.MaxVotos > 1)
                        {
                            <p style="font-size:11px;color:var(--color-muted);margin-bottom:10px;">Podés elegir hasta @enc.MaxVotos opciones</p>
                        }
                        <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:12px;">
                            @foreach (var op in enc.Opciones.OrderByDescending(o => o.Votos))
                            {
                                var pct = enc.TotalVotos > 0 ? (int)(100.0 * op.Votos / enc.TotalVotos) : 0;
                                <div style="cursor:pointer;" onclick="votar(@enc.Id, @op.Id)">
                                    <div style="display:flex;align-items:center;gap:6px;margin-bottom:3px;">
                                        @if (!string.IsNullOrEmpty(op.FlagCode) && banderas.ContainsKey(op.FlagCode))
                                        { <span style="font-size:13px;">@banderas[op.FlagCode]</span> }
                                        <span style="font-size:12px;color:var(--color-text);">@op.Texto</span>
                                        <span style="font-size:11px;color:var(--color-muted);margin-left:auto;">@pct%</span>
                                    </div>
                                    <div style="height:5px;border-radius:3px;background:var(--color-bg3);">
                                        <div style="width:@(pct)%;height:100%;background:var(--color-gold);border-radius:3px;"></div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div style="display:flex;gap:6px;align-items:center;">
                            <input type="text" placeholder="Tu nombre" id="autor-@enc.Id" maxlength="30"
                                   class="form-control" style="flex:1;font-size:12px;" />
                            <span style="font-size:10px;color:var(--color-muted);white-space:nowrap;">@enc.TotalVotos votos</span>
                        </div>
                        <p id="msg-enc-@enc.Id" style="font-size:11px;margin-top:5px;display:none;"></p>
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
async function votar(encuestaId, opcionId) {
    const autor = document.getElementById('autor-' + encuestaId)?.value?.trim();
    const msg   = document.getElementById('msg-enc-' + encuestaId);
    if (!autor) { msg.style.display='block'; msg.style.color='var(--color-red)'; msg.textContent='Ingresá tu nombre para votar.'; return; }

    const r = await fetch('/Encuestas/Votar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ encuestaId, opcionId, autor })
    });
    const d = await r.json();
    msg.style.display = 'block';
    msg.style.color   = d.ok ? 'var(--color-green)' : 'var(--color-red)';
    msg.textContent   = d.msg;
    if (d.ok) setTimeout(() => location.reload(), 800);
}
</script>
<script>
(function() {
    const track = document.getElementById('carruselTrack');
    if (!track) return;

    const slides        = Array.from(track.querySelectorAll('.carrusel-slide'));
    const dotsContainer = document.getElementById('carruselDots');
    const totalSlides   = slides.length;
    let current  = 0;
    let autoTimer;

    function getSV() {
        return window.innerWidth < 600 ? 1 : window.innerWidth < 900 ? 2 : 3;
    }

    function getMaxSlide() {
        return Math.max(0, totalSlides - getSV());
    }

    function buildDots() {
        const pages = Math.ceil(totalSlides / getSV());
        dotsContainer.innerHTML = '';
        for (let i = 0; i < pages; i++) {
            const d = document.createElement('span');
            d.className = 'carrusel-dot' + (i === 0 ? ' active' : '');
            d.onclick = () => goTo(i * getSV());
            dotsContainer.appendChild(d);
        }
    }

    function updateDots() {
        const sv    = getSV();
        const page  = Math.floor(current / sv);
        document.querySelectorAll('.carrusel-dot').forEach((d, i) =>
            d.classList.toggle('active', i === page));
    }

    function goTo(idx) {
        const max = getMaxSlide();
        // Clamp — no ir más allá del último slide
        current = Math.max(0, Math.min(idx, max));
        // Cada slide ocupa 100/sv % del contenedor visible
        const sv       = getSV();
        const pctPerSlide = 100 / sv;
        track.style.transform = `translateX(-${current * pctPerSlide}%)`;
        updateDots();
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function resetTimer() {
        clearInterval(autoTimer);
        autoTimer = setInterval(() => {
            if (current >= getMaxSlide()) goTo(0); else next();
        }, 5000);
    }

    window.moverCarrusel = function(dir) {
        if (dir > 0) next(); else prev();
        resetTimer();
    };

    // Touch swipe
    let txStart = 0;
    track.addEventListener('touchstart', e => { txStart = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', e => {
        const diff = txStart - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) {
            if (diff > 0) next(); else prev();
            resetTimer();
        }
    });

    window.addEventListener('resize', () => { buildDots(); goTo(0); });

    buildDots();
    resetTimer();
})();


</script>
}
