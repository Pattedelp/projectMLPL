@model TemporadaDetalleViewModel
@{
    ViewBag.Title = Model.Temporada.Nombre;
    var partidosPrimera  = ViewBag.PartidosPrimera  as List<HistoricoPartido> ?? new();
    var partidosNacional = ViewBag.PartidosNacional as List<HistoricoPartido> ?? new();
    var partidosPrimeraC = ViewBag.PartidosPrimeraC as List<HistoricoPartido> ?? new();
    bool tienePrimeraC   = Model.ResultadosPrimeraC.Any() || partidosPrimeraC.Any();

    List<(int Fecha, List<HistoricoPartido> Partidos)> AgruparPorFecha(List<HistoricoPartido> partidos, int equiposPorFecha) {
        var result = new List<(int, List<HistoricoPartido>)>();
        if (!partidos.Any()) return result;
        bool tieneFechas = partidos.Any(p => p.FechaNumero > 0);
        if (tieneFechas) {
            foreach (var g in partidos.GroupBy(p => p.FechaNumero).OrderBy(g => g.Key))
                result.Add((g.Key, g.ToList()));
        } else {
            int fechaNum = 1;
            for (int i = 0; i < partidos.Count; i += equiposPorFecha) {
                result.Add((fechaNum++, partidos.Skip(i).Take(equiposPorFecha).ToList()));
            }
        }
        return result;
    }

    int eqPrimera  = Model.ResultadosPrimera.Count;
    int eqNacional = Model.ResultadosNacionalB.Count;
    int eqC        = Model.ResultadosPrimeraC.Count;
    int ppfPrimera  = eqPrimera  > 0 ? eqPrimera / 2  : 5;
    int ppfNacional = eqNacional > 0 ? eqNacional / 2 : 5;
    int ppfC        = eqC        > 0 ? eqC / 2        : 3;

    var fechasPrimera  = AgruparPorFecha(partidosPrimera.Where(p => p.Torneo == "Liga").ToList(), ppfPrimera);
    var fechasNacional = AgruparPorFecha(partidosNacional.Where(p => p.Torneo == "Liga").ToList(), ppfNacional);
    var fechasPrimeraC = AgruparPorFecha(partidosPrimeraC.Where(p => p.Torneo == "Liga").ToList(), ppfC);
}

<div class="page-hero">
    <div class="page-hero-icon">📅</div>
    <div class="page-hero-text">
        <h1>@Model.Temporada.Nombre</h1>
        <p>@Model.Temporada.FechaInicio?.ToString("MMM yyyy") — @Model.Temporada.FechaFin?.ToString("MMM yyyy")</p>
    </div>
</div>

<a asp-action="Index" style="display:inline-block;color:var(--color-muted);font-size:13px;margin-bottom:20px;">
    ← Volver al historial
</a>

<!-- TABS -->
<div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;">
    <button onclick="showTab('primera')"  id="tab-primera"  class="tab-btn active">🏆 Primera División</button>
    <button onclick="showTab('nacional')" id="tab-nacional" class="tab-btn">🥈 Primera Nacional</button>
    @if (tienePrimeraC)
    {
        <button onclick="showTab('primerac')" id="tab-primerac" class="tab-btn">🏟️ Primera C</button>
    }
</div>

@{
    void TablaPos(List<TemporadaResultado> resultados) {
        <div class="tabla-wrapper">
            <table class="tabla-posiciones">
                <thead><tr><th>#</th><th>Equipo</th><th>PJ</th><th>V</th><th>D</th><th>DG</th><th>PTS</th></tr></thead>
                <tbody>
                    @foreach (var r in resultados)
                    {
                        <tr class="@(r.Campeon ? "zona-campeon" : r.Descendio ? "zona-descenso" : r.Ascendio ? "zona-ascenso" : "")"
                            style="cursor:pointer;" onclick="window.location='/Equipos/Detalle/@r.EquipoId'">
                            <td class="col-pos">@r.Posicion</td>
                            <td class="col-equipo">
                                @if (!string.IsNullOrEmpty(r.FlagCode))
                                { <img src="https://flagcdn.com/20x15/@(r.FlagCode).png" class="flag-img" alt="" onerror="this.style.display='none'" /> }
                                @r.NombreEquipo
                                @if (r.Campeon)   { <span style="font-size:11px;margin-left:3px;">🏆</span> }
                                @if (r.Ascendio)  { <span style="font-size:11px;margin-left:3px;color:var(--color-green);">⬆</span> }
                                @if (r.Descendio) { <span style="font-size:11px;margin-left:3px;color:var(--color-red);">⬇</span> }
                            </td>
                            <td class="col-num">@r.PartidosJugados</td>
                            <td class="col-num" style="color:var(--color-green);">@r.Ganados</td>
                            <td class="col-num" style="color:var(--color-red);">@r.Perdidos</td>
                            <td class="col-num">@(r.GolesFavor - r.GolesContra >= 0 ? "+" : "")@(r.GolesFavor - r.GolesContra)</td>
                            <td class="col-pts" style="color:var(--color-gold);font-weight:700;">@r.Puntos</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    void ResultadosFechas(List<(int Fecha, List<HistoricoPartido> Partidos)> fechas, List<HistoricoPartido> todosPartidos) {
        if (!fechas.Any() && !todosPartidos.Any(p => p.Torneo != "Liga")) {
            <p style="color:var(--color-muted);font-size:13px;">No hay resultados registrados.</p>
            return;
        }
        foreach (var (numFecha, partidos) in fechas) {
            <div style="background:var(--color-bg2);border:1px solid var(--color-border);border-radius:8px;overflow:hidden;margin-bottom:8px;">
                <div style="background:var(--color-bg3);padding:6px 14px;font-size:11px;letter-spacing:1px;color:var(--color-muted);text-transform:uppercase;">
                    Fecha @numFecha
                </div>
                @foreach (var p in partidos) {
                    bool lg = p.GolesLocal > p.GolesVisitante;
                    <div style="display:flex;align-items:center;padding:8px 14px;gap:8px;border-top:1px solid var(--color-border);font-size:13px;">
                        <div style="flex:1;text-align:right;display:flex;align-items:center;justify-content:flex-end;gap:6px;">
                            <span style="font-weight:@(lg ? "700" : "400");color:@(lg ? "var(--color-text)" : "var(--color-muted)");">@p.NombreLocal</span>
                            @if (!string.IsNullOrEmpty(p.FlagLocal))
                            { <img src="https://flagcdn.com/16x12/@(p.FlagLocal).png" style="border-radius:1px;" alt="" onerror="this.style.display='none'" /> }
                        </div>
                        <div style="font-family:var(--font-heading);font-size:16px;font-weight:700;background:var(--color-bg3);border-radius:6px;padding:2px 12px;min-width:55px;text-align:center;">
                            @p.GolesLocal - @p.GolesVisitante
                        </div>
                        <div style="flex:1;display:flex;align-items:center;gap:6px;">
                            @if (!string.IsNullOrEmpty(p.FlagVisitante))
                            { <img src="https://flagcdn.com/16x12/@(p.FlagVisitante).png" style="border-radius:1px;" alt="" onerror="this.style.display='none'" /> }
                            <span style="font-weight:@(!lg ? "700" : "400");color:@(!lg ? "var(--color-text)" : "var(--color-muted)");">@p.NombreVisitante</span>
                        </div>
                    </div>
                }
            </div>
        }
        PartidosEspeciales(todosPartidos);
    }

    void PartidosEspeciales(List<HistoricoPartido> todosPartidos) {
        var grupos = todosPartidos
            .Where(p => p.Torneo != "Liga")
            .GroupBy(p => p.Torneo)
            .OrderBy(g => g.Key == "Reducido (Semifinal)" ? 0 : g.Key == "Reducido (Final)" ? 1 : 2)
            .ToList();
        foreach (var grupo in grupos) {
            <div style="background:var(--color-bg2);border:1px solid rgba(58,130,200,0.4);border-radius:8px;overflow:hidden;margin-bottom:8px;margin-top:8px;">
                <div style="background:rgba(58,130,200,0.15);padding:6px 14px;font-size:11px;letter-spacing:1px;color:#3a82c8;text-transform:uppercase;">
                    @grupo.Key
                </div>
                @foreach (var p in grupo) {
                    bool lg = p.GolesLocal > p.GolesVisitante;
                    <div style="display:flex;align-items:center;padding:8px 14px;gap:8px;border-top:1px solid var(--color-border);font-size:13px;">
                        <div style="flex:1;text-align:right;display:flex;align-items:center;justify-content:flex-end;gap:6px;">
                            <span style="font-weight:@(lg ? "700" : "400");color:@(lg ? "var(--color-text)" : "var(--color-muted)");">@p.NombreLocal</span>
                            @if (!string.IsNullOrEmpty(p.FlagLocal))
                            { <img src="https://flagcdn.com/16x12/@(p.FlagLocal).png" style="border-radius:1px;" alt="" onerror="this.style.display='none'" /> }
                        </div>
                        <div style="font-family:var(--font-heading);font-size:16px;font-weight:700;background:var(--color-bg3);border-radius:6px;padding:2px 12px;min-width:55px;text-align:center;">
                            @p.GolesLocal - @p.GolesVisitante
                        </div>
                        <div style="flex:1;display:flex;align-items:center;gap:6px;">
                            @if (!string.IsNullOrEmpty(p.FlagVisitante))
                            { <img src="https://flagcdn.com/16x12/@(p.FlagVisitante).png" style="border-radius:1px;" alt="" onerror="this.style.display='none'" /> }
                            <span style="font-weight:@(!lg ? "700" : "400");color:@(!lg ? "var(--color-text)" : "var(--color-muted)");">@p.NombreVisitante</span>
                        </div>
                    </div>
                }
            </div>
        }
    }
}

<!-- PRIMERA DIVISIÓN -->
<div id="tab-primera-content">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;" class="det-grid">
        <div>
            <h3 style="font-family:var(--font-heading);font-size:12px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:12px;">Posiciones Finales</h3>
            @{ TablaPos(Model.ResultadosPrimera); }
        </div>
        <div>
            <h3 style="font-family:var(--font-heading);font-size:12px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:12px;">Resultados</h3>
            @{ ResultadosFechas(fechasPrimera, partidosPrimera); }
        </div>
    </div>
</div>

<!-- PRIMERA NACIONAL -->
<div id="tab-nacional-content" style="display:none;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;" class="det-grid">
        <div>
            <h3 style="font-family:var(--font-heading);font-size:12px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:12px;">Posiciones Finales</h3>
            @{ TablaPos(Model.ResultadosNacionalB); }
        </div>
        <div>
            <h3 style="font-family:var(--font-heading);font-size:12px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:12px;">Resultados</h3>
            @{ ResultadosFechas(fechasNacional, partidosNacional); }
        </div>
    </div>
</div>

<!-- PRIMERA C NACIONAL -->
@if (tienePrimeraC)
{
    <div id="tab-primerac-content" style="display:none;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;" class="det-grid">
            <div>
                <h3 style="font-family:var(--font-heading);font-size:12px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:12px;">Posiciones Finales</h3>
                @{ TablaPos(Model.ResultadosPrimeraC); }
            </div>
            <div>
                <h3 style="font-family:var(--font-heading);font-size:12px;letter-spacing:2px;color:var(--color-gold);text-transform:uppercase;margin-bottom:12px;">Resultados</h3>
                @{ ResultadosFechas(fechasPrimeraC, partidosPrimeraC); }
            </div>
        </div>
    </div>
}

<style>
.tab-btn { padding:8px 16px;border-radius:8px;background:var(--color-bg2);border:1px solid var(--color-border);color:var(--color-muted);font-size:13px;font-weight:500;cursor:pointer; }
.tab-btn.active { background:var(--color-gold);color:var(--color-bg);border-color:var(--color-gold); }
@@media (max-width:700px) { .det-grid { grid-template-columns: 1fr !important; } }
</style>

@section Scripts {
<script>
function showTab(tab) {
    document.getElementById('tab-primera-content').style.display   = tab === 'primera'  ? 'block' : 'none';
    document.getElementById('tab-nacional-content').style.display  = tab === 'nacional' ? 'block' : 'none';
    const tabC = document.getElementById('tab-primerac-content');
    if (tabC) tabC.style.display = tab === 'primerac' ? 'block' : 'none';
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    const btn = document.getElementById('tab-' + tab);
    if (btn) btn.classList.add('active');
}
</script>
}
